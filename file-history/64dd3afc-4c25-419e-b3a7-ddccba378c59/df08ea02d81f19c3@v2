<?php

namespace App\Models;

use Illuminate\Database\Eloquent\Model;
use Illuminate\Support\Str;

class Employee extends Model
{
    protected $fillable = [
        'customer_id', 'name', 'title', 'bio', 'avatar',
        'email', 'phone', 'linkedin', 'github', 'twitter', 'website',
        'slug', 'active',
    ];

    protected function casts(): array
    {
        return ['active' => 'boolean'];
    }

    public function customer()
    {
        return $this->belongsTo(Customer::class);
    }

    public function skills()
    {
        return $this->hasMany(EmployeeSkill::class)->orderBy('sort_order');
    }

    public function experiences()
    {
        return $this->hasMany(EmployeeExperience::class)->orderBy('sort_order');
    }

    public function portfolio()
    {
        return $this->hasMany(EmployeePortfolio::class)->orderBy('sort_order');
    }

    public static function generateSlug(string $name, int $customerId, ?int $excludeId = null): string
    {
        $base = Str::slug($name);
        $slug = $base;
        $i = 1;

        while (static::where('customer_id', $customerId)
            ->where('slug', $slug)
            ->when($excludeId, fn ($q) => $q->where('id', '!=', $excludeId))
            ->exists()
        ) {
            $slug = "{$base}-{$i}";
            $i++;
        }

        return $slug;
    }
}

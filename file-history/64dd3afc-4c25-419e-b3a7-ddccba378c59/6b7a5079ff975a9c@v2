<?php

namespace App\Http\Controllers;

use App\Models\Customer;
use App\Models\Employee;

class VCardController extends Controller
{
    public function show(string $customerSlug, string $employeeSlug)
    {
        $customer = Customer::where('slug', $customerSlug)->where('active', true)->firstOrFail();
        $employee = Employee::where('customer_id', $customer->id)
            ->where('slug', $employeeSlug)
            ->where('active', true)
            ->with(['skills', 'experiences', 'portfolio'])
            ->firstOrFail();

        return view('vcard.show', compact('customer', 'employee'));
    }
}

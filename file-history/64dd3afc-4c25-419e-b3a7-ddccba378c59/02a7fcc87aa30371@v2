<?php

namespace App\Http\Controllers\Admin;

use App\Http\Controllers\Controller;
use App\Models\Customer;
use App\Models\Employee;
use App\Models\User;
use Illuminate\Support\Facades\Auth;

class DashboardController extends Controller
{
    public function index()
    {
        $user = Auth::user();

        if ($user->isSuperAdmin()) {
            $stats = [
                'admins'     => User::where('role', 'admin')->count(),
                'customers'  => Customer::count(),
                'employees'  => Employee::count(),
                'active'     => Employee::where('active', true)->count(),
            ];
            $recentCustomers = Customer::with('user')->latest()->limit(5)->get();
            $recentEmployees = Employee::with('customer.user')->latest()->limit(5)->get();
        } else {
            $stats = [
                'customers'   => $user->customers()->count(),
                'employees'   => Employee::whereHas('customer', fn ($q) => $q->where('user_id', $user->id))->count(),
                'seats_used'  => $user->seatsUsed(),
                'seats_total' => $user->seats_total,
            ];
            $recentCustomers = $user->customers()->latest()->limit(5)->get();
            $recentEmployees = Employee::whereHas('customer', fn ($q) => $q->where('user_id', $user->id))
                ->with('customer')
                ->latest()
                ->limit(5)
                ->get();
        }

        return view('admin.dashboard', compact('stats', 'recentCustomers', 'recentEmployees'));
    }
}

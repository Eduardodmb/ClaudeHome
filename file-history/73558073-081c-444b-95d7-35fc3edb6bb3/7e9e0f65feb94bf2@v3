<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action to show partner's checklist -->
    <record id="action_partner_subcontractor_checklist" model="ir.actions.act_window">
        <field name="name">Subcontractor Checklist</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'form_view_initial_mode': 'edit'}</field>
    </record>

    <record id="view_partner_form_subcontractor_requirements" model="ir.ui.view">
        <field name="name">res.partner.form.subcontractor.requirements</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <field name="vat" position="after">
                <field name="show_subcontractor_requirements" invisible="1"/>
            </field>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button"
                        type="action"
                        name="%(contacts_subcontractor_requirements.action_partner_subcontractor_checklist)d"
                        icon="fa-check-square-o"
                        invisible="not show_subcontractor_requirements">
                    <field name="subcontractor_requirements_state"
                           widget="badge"
                           decoration-success="subcontractor_requirements_state == 'met'"
                           decoration-warning="subcontractor_requirements_state == 'incomplete'"
                           decoration-danger="subcontractor_requirements_state == 'none'"/>
                </button>
            </xpath>
            <field name="contact_type_id" position="after">
                <field name="subcontractor_requirements_state"
                       string="Subcontractor requirements"
                       widget="badge"
                       decoration-success="subcontractor_requirements_state == 'met'"
                       decoration-warning="subcontractor_requirements_state == 'incomplete'"
                       invisible="not show_subcontractor_requirements"/>
            </field>
            <xpath expr="//notebook" position="inside">
                <page string="Requirements Checklist"
                      name="subcontractor_requirements"
                      invisible="not show_subcontractor_requirements">
                    <group>
                        <group>
                            <field name="subcontractor_requirements_state" readonly="1" widget="badge"/>
                        </group>
                        <group>
                            <button name="%(contacts_subcontractor_requirements.action_subcontractor_requirement_template_item)d"
                                    string="Manage Global Template"
                                    type="action"
                                    class="btn-link"
                                    icon="fa-cog"/>
                        </group>
                    </group>
                    <group string="Requirements Checklist">
                        <p class="text-muted">
                            This checklist is automatically synced from the global subcontractor requirements template.
                            Mark items as Done or N/A to track compliance.
                        </p>
                    </group>
                    <field name="subcontractor_requirement_line_ids"
                           nolabel="1">
                        <list editable="bottom" create="false" delete="false">
                            <field name="sequence" widget="handle"/>
                            <field name="name" readonly="1"/>
                            <field name="description" optional="show" readonly="1"/>
                            <field name="is_optional" readonly="1" optional="show" string="Optional"/>
                            <field name="done" widget="boolean_toggle"/>
                            <field name="not_applicable" widget="boolean_toggle" string="N/A"/>
                            <field name="attachment_ids" widget="many2many_binary" optional="show"/>
                            <field name="is_active" readonly="1" invisible="1"/>
                        </list>
                        <form>
                            <sheet>
                                <group>
                                    <field name="name" readonly="1"/>
                                    <field name="description" readonly="1"/>
                                    <field name="is_optional" readonly="1"/>
                                    <field name="done"/>
                                    <field name="not_applicable"/>
                                </group>
                                <group string="Attachments">
                                    <field name="attachment_ids" widget="many2many_binary" nolabel="1"/>
                                </group>
                            </sheet>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

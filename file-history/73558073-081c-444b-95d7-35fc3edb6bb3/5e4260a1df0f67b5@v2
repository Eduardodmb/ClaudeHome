@echo off
REM Quick launcher for export_modules.ps1
REM Usage: export_modules.bat [database_name]

setlocal

set DB_NAME=%1
if "%DB_NAME%"=="" set DB_NAME=odoo

echo.
echo =====================================================
echo   Exporting Odoo Modules
echo =====================================================
echo.
echo Database: %DB_NAME%
echo.

powershell.exe -ExecutionPolicy Bypass -File "%~dp0export_modules.ps1" -DatabaseName "%DB_NAME%"

if %ERRORLEVEL% EQU 0 (
    echo.
    echo =====================================================
    echo   Export completed successfully!
    echo =====================================================
) else (
    echo.
    echo =====================================================
    echo   Export failed - check errors above
    echo =====================================================
)

echo.
pause

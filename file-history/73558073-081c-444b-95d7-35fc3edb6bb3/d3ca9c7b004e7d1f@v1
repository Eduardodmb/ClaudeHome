<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="edit_project_inherit_kickoff" model="ir.ui.view">
        <field name="name">project.project.kickoff.checklist.form</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            
            <xpath expr="//notebook" position="inside">
                <page string="Kick Off Checklist" name="kickoff_checklist">
                    <button 
                        name="populate_kickoff_checklist" 
                        type="object" 
                        string="Generate Checklist from Template" 
                        class="oe_highlight"
                        confirm="Are you sure you want to generate the checklist? This will only run if the checklist is currently empty."
                    />
                    <field name="kickoff_item_ids">
                        <list>
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="date_required"/>
                            <field name="status"/>
                            <field name="attachment_ids" widget="many2many_binary"/>
                            <field name="project_id" invisible="1"/> 
                            <field name="acg_txt"/>
                            <field name="customer_txt"/>
                            <field name="subcontractor_txt"/>
                        </list>
                        <form>
                            <group>
                                <field name="name"/>
                                <field name="date_required"/>
                                <field name="status"/>
                                <field name="acg_txt" widget="html" style="min-height: 300px;"/>
                                <field name="customer_txt" widget="html" style="min-height: 300px;"/>
                                <field name="subcontractor_txt" widget="html" style="min-height: 300px;"/>
                            </group>
                            <field name="description"/>
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </form>
                    </field>
                </page>
            </xpath>

        </field>
    </record>
    <record id="project_kickoff_template_item_action" model="ir.actions.act_window">
        <field name="name">Kickoff Template Items</field>
        <field name="res_model">project.kickoff.template.item</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create the first Kickoff Template Item
            </p>
        </field>
    </record>

    <menuitem 
        id="menu_project_kickoff_template" 
        name="Kickoff Checklist Template" 
        parent="project.menu_project_config" 
        action="project_kickoff_template_item_action" 
        sequence="10"/>
</odoo>
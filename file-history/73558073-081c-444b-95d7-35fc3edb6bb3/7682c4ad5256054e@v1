from odoo import models, _
from markupsafe import Markup
from odoo.tools.misc import format_date

class MailActivitySchedule(models.TransientModel):
    """
    Activity Plan Execution Override
    -------------------------------
    This wizard handles the transition from an 'Activity Plan' blueprint to 
    actual 'mail.activity' records. We override action_schedule_plan to 
    force-inject our ACGLP custom fields during the batch creation process.
    """
    _inherit = "mail.activity.schedule"

    def action_schedule_plan(self):
        """
        The core execution method triggered when a user clicks 'Launch Plan'.
        """
        # 1. Identify which records (Employees/Departments) are receiving the plan
        applied_on = self._get_applied_on_records()
        for record in applied_on:
            body = _('The plan "%(plan_name)s" has been started', plan_name=self.plan_id.name)
            activity_descriptions = []
            # 2. Iterate through each activity defined in the Plan Template
            for template in self._plan_filter_activity_templates_to_schedule():
                if template.responsible_type == 'on_demand':
                    responsible = self.plan_on_demand_user_id
                else:
                    responsible = template._determine_responsible(self.plan_on_demand_user_id, record)['responsible']

                date_deadline = template._get_date_deadline(self.plan_date)

                # build values including your custom fields
                # 3. CRITICAL STEP: Build the 'extra_vals' dictionary
                # This is where we bridge the gap between Template and Activity.
                # Standard Odoo ignore these fields; we explicitly extract them here.
                extra_vals = {}
                if hasattr(template, "group_id") and template.group_id:
                    extra_vals["group_id"] = template.group_id.id
                if hasattr(template, "target_document_item_id") and template.target_document_item_id:
                    extra_vals["target_document_item_id"] = template.target_document_item_id.id
                # 4. Create the activity record on the target document
                # We unpack (**extra_vals) to pass our custom fields into the create method
                extra_vals = {
                    "target_document_item_id": template.target_document_item_id.id if template.target_document_item_id else False,
                    "group_id": template.group_id.id if template.group_id else False,
                    "certification_name_id": [(6, 0, template.certification_name_ids.ids)] if template.certification_name_ids else [(6, 0, [])],
                }

                record.activity_schedule(
                    activity_type_id=template.activity_type_id.id,
                    automated=False,
                    summary=template.summary,
                    note=template.note,
                    user_id=responsible.id,
                    date_deadline=date_deadline,
                    **extra_vals,
                )
                # 5. Build a formatted list for the Chatter message
                activity_descriptions.append(
                    _('%(activity)s, assigned to %(name)s, due on the %(deadline)s',
                      activity=template.summary or template.activity_type_id.name,
                      name=responsible.name, deadline=format_date(self.env, date_deadline))
                )
            # 6. Post a summary message to the record's chatter using Markup (Safe HTML)
            if activity_descriptions:
                body += Markup('<ul>%s</ul>') % (
                    Markup().join(Markup('<li>%s</li>') % d for d in activity_descriptions)
                )
            record.message_post(body=body)
        # 7. Maintain standard Odoo UX: Return the user to the record they were viewing
        # keep same return behavior
        if len(applied_on) == 1:
            return {
                'type': 'ir.actions.act_window',
                'res_model': self.res_model,
                'res_id': applied_on.id,
                'name': applied_on.display_name,
                'view_mode': 'form',
                'views': [(False, "form")],
            }
        # If multiple records were selected, return a list view of those records
        return {
            'type': 'ir.actions.act_window',
            'res_model': self.res_model,
            'name': _('Launch Plans'),
            'view_mode': 'list,form',
            'target': 'current',
            'domain': [('id', 'in', applied_on.ids)],
        }

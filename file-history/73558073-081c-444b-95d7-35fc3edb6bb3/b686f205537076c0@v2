<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Subcontractor Rating Info to Partner Form -->
    <record id="view_partner_form_subcontractor_rating" model="ir.ui.view">
        <field name="name">res.partner.form.subcontractor.rating</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Add smart buttons -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button"
                        type="object"
                        name="action_view_subcontractor_evaluations"
                        icon="fa-star"
                        invisible="subcontractor_total_evaluations == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="subcontractor_avg_rating" widget="float"/>
                        </span>
                        <span class="o_stat_text">
                            Subcontractor Rating
                        </span>
                    </div>
                </button>
                <button class="oe_stat_button"
                        type="object"
                        name="action_view_subcontractor_evaluations"
                        icon="fa-check-circle"
                        invisible="subcontractor_total_evaluations == 0">
                    <field name="subcontractor_total_evaluations" widget="statinfo" string="Evaluations"/>
                </button>
            </xpath>

            <!-- Add rating display in supplier info section -->
            <xpath expr="//page[@name='sales_purchases']//group[@name='purchase']" position="inside">
                <group string="Subcontractor Performance" invisible="subcontractor_total_evaluations == 0">
                    <field name="subcontractor_rating_display" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>

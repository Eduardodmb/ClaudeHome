<odoo>
    <record id="view_project_project_subcontractor_list" model="ir.ui.view">
        <field name="name">project.project.subcontractor.list</field>
        <field name="model">project.project.subcontractor</field>
        <field name="arch" type="xml">
            <list string="Subcontractors">
                <field name="sequence" widget="handle"/>
                <field name="partner_id"/>
                <field name="trade"/>
                <field name="status"/>
                <field name="amount"/>
                <field name="quote_date"/>
                <field name="po"/>
                <field name="package_status"/>
                <field name="overall_rating" optional="show" widget="float" decoration-success="overall_rating >= 4" decoration-warning="overall_rating >= 2 and overall_rating &lt; 4" decoration-danger="overall_rating &lt; 2"/>
                <field name="is_evaluated" invisible="1"/>
                <field name="extra_attachment_ids" widget="many2many_binary"/>
            </list>
        </field>
    </record>

    <record id="view_project_project_subcontractor_form" model="ir.ui.view">
        <field name="name">project.project.subcontractor.form</field>
        <field name="model">project.project.subcontractor</field>
        <field name="arch" type="xml">
            <form string="Subcontractor">
                <header>
                    <button name="action_evaluate_subcontractor"
                            string="Evaluate Performance"
                            type="object"
                            class="btn-primary"
                            invisible="is_evaluated"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_evaluate_subcontractor" icon="fa-star">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="overall_rating" widget="float"/>
                                </span>
                                <span class="o_stat_text">Rating</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" readonly="1"/>
                            <field name="partner_id"/>
                            <field name="partner_rating_info" readonly="1"/>
                            <field name="trade"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="quote_date"/>
                            <field name="po"/>
                            <field name="package_status"/>
                            <field name="extra_attachment_ids" widget="many2many_binary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                        <page string="Performance Evaluation" name="evaluation">
                            <group>
                                <group string="Ratings">
                                    <field name="performance_rating"/>
                                    <field name="quality_rating"/>
                                    <field name="communication_rating"/>
                                    <field name="timeliness_rating"/>
                                    <field name="overall_rating" readonly="1" widget="float" string="Overall Average"/>
                                </group>
                                <group string="Evaluation Details">
                                    <field name="evaluation_date"/>
                                    <field name="evaluated_by"/>
                                    <field name="is_evaluated" invisible="1"/>
                                </group>
                            </group>
                            <group>
                                <field name="evaluation_notes" placeholder="Add any additional comments about this subcontractor's performance..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="project_project_form_inherit_subcontractors" model="ir.ui.view">
        <field name="name">project.project.form.inherit.subcontractors</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Subcontractors" name="subcontractors_tab">
                    <field name="subcontractor_line_ids"
                           context="{'default_project_id': id}"
                           mode="list,form">
                        <list editable="bottom" string="Subcontractors">
                            <field name="sequence" widget="handle"/>
                            <field name="partner_id"/>
                            <field name="partner_rating_info" optional="show" readonly="1"/>
                            <field name="trade"/>
                            <field name="status"/>
                            <field name="amount"/>
                            <field name="quote_date"/>
                            <field name="po"/>
                            <field name="package_status"/>
                            <field name="performance_rating" optional="hide"/>
                            <field name="quality_rating" optional="hide"/>
                            <field name="communication_rating" optional="hide"/>
                            <field name="timeliness_rating" optional="hide"/>
                            <field name="overall_rating" optional="show" decoration-success="overall_rating >= 4" decoration-warning="overall_rating >= 2 and overall_rating &lt; 4" decoration-danger="overall_rating &lt; 2"/>
                            <field name="is_evaluated" invisible="1"/>
                            <field name="extra_attachment_ids" widget="many2many_binary"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Evaluation Wizard Form -->
    <record id="view_project_subcontractor_evaluation_form" model="ir.ui.view">
        <field name="name">project.project.subcontractor.evaluation.form</field>
        <field name="model">project.project.subcontractor</field>
        <field name="arch" type="xml">
            <form string="Evaluate Subcontractor">
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="project_id" readonly="1"/>
                            <field name="trade" readonly="1"/>
                        </group>
                        <group>
                            <field name="evaluation_date"/>
                            <field name="evaluated_by"/>
                        </group>
                    </group>
                    <group string="Performance Ratings">
                        <group>
                            <field name="performance_rating" required="1"/>
                            <field name="quality_rating" required="1"/>
                        </group>
                        <group>
                            <field name="communication_rating" required="1"/>
                            <field name="timeliness_rating" required="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="overall_rating" readonly="1" string="Overall Average Rating"/>
                    </group>
                    <group>
                        <field name="evaluation_notes" placeholder="Add comments about performance, quality, issues, or recommendations..."/>
                    </group>
                </sheet>
                <footer>
                    <button string="Save Evaluation" class="btn-primary" special="save"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!--
    Partner view extensions removed - now provided by subcontractor_evaluation module.
    The shared module provides smart buttons and rating display on partner forms.
    -->
</odoo>
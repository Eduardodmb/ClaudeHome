<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report Definition -->
    <record id="action_report_kickoff_checklist" model="ir.actions.report">
        <field name="name">Kickoff Checklist</field>
        <field name="model">project.project</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">project_kickoff_checklist.report_kickoff_checklist_document</field>
        <field name="report_file">project_kickoff_checklist.report_kickoff_checklist_document</field>
        <field name="binding_model_id" ref="project.model_project_project"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Kickoff Checklist - %s' % (object.name)</field>
    </record>

    <!-- Report Template -->
    <template id="report_kickoff_checklist_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="oe_structure"/>

                        <!-- Header -->
                        <h2 class="text-center">
                            <strong>Kick Off Checklist</strong>
                        </h2>
                        <h3 class="text-center">
                            <span t-field="doc.name"/>
                        </h3>

                        <div class="row mt-4 mb-4">
                            <div class="col-6">
                                <strong>Project:</strong> <span t-field="doc.name"/><br/>
                                <strong>Customer:</strong> <span t-field="doc.partner_id"/><br/>
                                <t t-if="doc.date_start">
                                    <strong>Start Date:</strong> <span t-field="doc.date_start"/><br/>
                                </t>
                            </div>
                            <div class="col-6">
                                <t t-if="doc.user_id">
                                    <strong>Project Manager:</strong> <span t-field="doc.user_id"/><br/>
                                </t>
                                <t t-if="doc.x_contract_amount">
                                    <strong>Contract Amount:</strong> <span t-field="doc.x_contract_amount"/><br/>
                                </t>
                            </div>
                        </div>

                        <!-- Checklist Table -->
                        <table class="table table-sm table-bordered" style="page-break-inside: avoid;">
                            <thead style="background-color: #4472C4; color: white;">
                                <tr>
                                    <th style="width: 3%;">#</th>
                                    <th style="width: 25%;">Item Name</th>
                                    <th style="width: 10%;">Date Required</th>
                                    <th style="width: 8%;">Status</th>
                                    <th style="width: 18%;">ACG Response</th>
                                    <th style="width: 18%;">Customer Response</th>
                                    <th style="width: 18%;">Subcontractor Response</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.kickoff_item_ids.sorted(lambda x: x.sequence)" t-as="item">
                                    <tr>
                                        <td><span t-field="item.sequence"/></td>
                                        <td><strong><span t-field="item.name"/></strong></td>
                                        <td><span t-field="item.date_required"/></td>
                                        <td>
                                            <t t-if="item.status == 'completed'">
                                                <span class="badge badge-success">Completed</span>
                                            </t>
                                            <t t-elif="item.status == 'in_progress'">
                                                <span class="badge badge-info">In Progress</span>
                                            </t>
                                            <t t-elif="item.status == 'on_hold'">
                                                <span class="badge badge-warning">On Hold</span>
                                            </t>
                                            <t t-elif="item.status == 'not_applicable'">
                                                <span class="badge badge-secondary">N/A</span>
                                            </t>
                                            <t t-else="">
                                                <span class="badge badge-light">Pending</span>
                                            </t>
                                        </td>
                                        <td><span t-field="item.acg_txt"/></td>
                                        <td><span t-field="item.customer_txt"/></td>
                                        <td><span t-field="item.subcontractor_txt"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- Summary Section -->
                        <div class="row mt-4" style="page-break-inside: avoid;">
                            <div class="col-12">
                                <h4>Summary</h4>
                                <t t-set="total_items" t-value="len(doc.kickoff_item_ids)"/>
                                <t t-set="completed_items" t-value="len(doc.kickoff_item_ids.filtered(lambda x: x.status == 'completed'))"/>
                                <t t-set="pending_items" t-value="len(doc.kickoff_item_ids.filtered(lambda x: x.status == 'pending'))"/>
                                <t t-set="in_progress_items" t-value="len(doc.kickoff_item_ids.filtered(lambda x: x.status == 'in_progress'))"/>

                                <p>
                                    <strong>Total Items:</strong> <t t-esc="total_items"/><br/>
                                    <strong>Completed:</strong> <t t-esc="completed_items"/>
                                    (<t t-esc="round(completed_items * 100.0 / total_items if total_items > 0 else 0, 1)"/>%)<br/>
                                    <strong>In Progress:</strong> <t t-esc="in_progress_items"/><br/>
                                    <strong>Pending:</strong> <t t-esc="pending_items"/><br/>
                                </p>
                            </div>
                        </div>

                        <div class="oe_structure"/>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================ -->
    <!-- ACTIONS - Define these first so they can be referenced later -->
    <!-- ============================================================ -->

    <!-- Full Screen Checklist View -->
    <record id="view_kickoff_checklist_tree_fullscreen" model="ir.ui.view">
        <field name="name">project.kickoff.item.tree.fullscreen</field>
        <field name="model">project.kickoff.item</field>
        <field name="arch" type="xml">
            <list editable="bottom" multi_edit="1">
                <field name="sequence" widget="handle"/>
                <field name="name" required="1"/>
                <field name="description" optional="hide"/>
                <field name="date_required" optional="show"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'completed'"
                       decoration-info="status == 'in_progress'"
                       decoration-warning="status == 'on_hold'"
                       decoration-muted="status == 'not_applicable'"/>
                <field name="attachment_ids" widget="many2many_binary" optional="hide"/>
                <field name="acg_txt" widget="html" optional="show"/>
                <field name="customer_txt" widget="html" optional="show"/>
                <field name="subcontractor_txt" widget="html" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_kickoff_checklist_form_fullscreen" model="ir.ui.view">
        <field name="name">project.kickoff.item.form.fullscreen</field>
        <field name="model">project.kickoff.item</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="date_required"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="ACG Response">
                            <field name="acg_txt" widget="html" options="{'height': 400}"/>
                        </page>
                        <page string="Customer Response">
                            <field name="customer_txt" widget="html" options="{'height': 400}"/>
                        </page>
                        <page string="Subcontractor Response">
                            <field name="subcontractor_txt" widget="html" options="{'height': 400}"/>
                        </page>
                        <page string="Description/Notes">
                            <field name="description" widget="html" options="{'height': 400}"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kickoff_checklist_search" model="ir.ui.view">
        <field name="name">project.kickoff.item.search</field>
        <field name="model">project.kickoff.item</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="project_id"/>
                <field name="status"/>
                <filter string="Pending" name="filter_pending" domain="[('status', '=', 'pending')]"/>
                <filter string="In Progress" name="filter_in_progress" domain="[('status', '=', 'in_progress')]"/>
                <filter string="Completed" name="filter_completed" domain="[('status', '=', 'completed')]"/>
                <filter string="On Hold" name="filter_on_hold" domain="[('status', '=', 'on_hold')]"/>
                <group string="Group By">
                    <filter name="group_by_project" string="Project" context="{'group_by': 'project_id'}"/>
                    <filter name="group_by_status" string="Status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_kickoff_checklist_fullscreen" model="ir.actions.act_window">
        <field name="name">Kick Off Checklist - Full Screen</field>
        <field name="res_model">project.kickoff.item</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_kickoff_checklist_search"/>
        <field name="context">{
            'search_default_project_id': active_id,
            'default_project_id': active_id,
        }</field>
        <field name="domain">[('project_id', '=', active_id)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No checklist items found for this project
            </p>
            <p>
                Click "Generate Checklist" to populate from template
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- INHERITED VIEWS - Now we can safely reference the actions   -->
    <!-- ============================================================ -->

    <record id="edit_project_inherit_kickoff" model="ir.ui.view">
        <field name="name">project.project.kickoff.checklist.form</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">
                <page string="Kick Off Checklist" name="kickoff_checklist">
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="populate_kickoff_checklist"
                            type="object"
                            string="Generate Checklist"
                            class="oe_highlight"
                            confirm="Are you sure you want to generate the checklist? This will only run if the checklist is currently empty."
                        />
                        <button
                            name="%(action_kickoff_checklist_fullscreen)d"
                            type="action"
                            string="Open Full Screen"
                            class="btn-primary"
                            icon="fa-expand"
                        />
                        <button
                            name="action_export_checklist_excel"
                            type="object"
                            string="Export to Excel"
                            class="btn-secondary"
                            icon="fa-file-excel-o"
                        />
                        <button
                            name="action_print_checklist"
                            type="object"
                            string="Print Checklist"
                            class="btn-secondary"
                            icon="fa-print"
                        />
                    </div>
                    <field name="kickoff_item_ids">
                        <list editable="bottom" multi_edit="1">
                            <field name="sequence" widget="handle"/>
                            <field name="name" required="1"/>
                            <field name="description" optional="hide"/>
                            <field name="date_required" optional="show"/>
                            <field name="status" widget="badge"
                                   decoration-success="status == 'completed'"
                                   decoration-info="status == 'in_progress'"
                                   decoration-warning="status == 'on_hold'"
                                   decoration-muted="status == 'not_applicable'"/>
                            <field name="attachment_ids" widget="many2many_binary" optional="hide"/>
                            <field name="project_id" column_invisible="1"/>
                            <field name="acg_txt" widget="html" optional="show"/>
                            <field name="customer_txt" widget="html" optional="show"/>
                            <field name="subcontractor_txt" widget="html" optional="show"/>
                        </list>
                        <form>
                            <group>
                                <field name="name"/>
                                <field name="date_required"/>
                                <field name="status"/>
                                <field name="acg_txt" widget="html" style="min-height: 300px;"/>
                                <field name="customer_txt" widget="html" style="min-height: 300px;"/>
                                <field name="subcontractor_txt" widget="html" style="min-height: 300px;"/>
                            </group>
                            <field name="description"/>
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </form>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

    <!-- ============================================================ -->
    <!-- TEMPLATE ITEMS CONFIGURATION                                 -->
    <!-- ============================================================ -->

    <record id="project_kickoff_template_item_action" model="ir.actions.act_window">
        <field name="name">Kickoff Template Items</field>
        <field name="res_model">project.kickoff.template.item</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create the first Kickoff Template Item
            </p>
        </field>
    </record>

    <menuitem
        id="menu_project_kickoff_template"
        name="Kickoff Checklist Template"
        parent="project.menu_project_config"
        action="project_kickoff_template_item_action"
        sequence="10"/>
</odoo>

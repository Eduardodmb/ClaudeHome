<odoo>

    <record id="view_department_main_activity_tree" model="ir.ui.view">
        <field name="name">department.main.activity.tree</field>
        <field name="model">department.main.activity</field>
        <field name="arch" type="xml">
            <list string="Main Activities" decoration-danger="state == 'overdue'" decoration-success="state == 'completed'" decoration-muted="state == 'cancelled'">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="responsible_id" widget="many2one_avatar_user"/>
                <field name="next_due_date"/>
                <field name="state" widget="badge" decoration-danger="state == 'overdue'" decoration-success="state == 'completed'" decoration-warning="state == 'in_progress'" decoration-info="state == 'pending'" decoration-muted="state == 'cancelled'"/>
                <field name="is_recurring" widget="boolean_toggle"/>
                <field name="recurrence_type" optional="hide"/>
                <field name="document_id" optional="hide"/>
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_department_main_activity_form" model="ir.ui.view">
        <field name="name">department.main.activity.form</field>
        <field name="model">department.main.activity</field>
        <field name="arch" type="xml">
            <form string="Main Activity">
                <header>
                    <button name="action_mark_in_progress" string="Start" type="object" class="oe_highlight" invisible="state not in ['pending']"/>
                    <button name="action_mark_completed" string="Mark as Completed" type="object" class="oe_highlight" invisible="state in ['completed', 'cancelled']"/>
                    <button name="action_mark_cancelled" string="Cancel" type="object" invisible="state in ['completed', 'cancelled']"/>
                    <button name="action_reopen" string="Reopen" type="object" invisible="state not in ['completed', 'cancelled']"/>
                    <button name="action_open_document" string="Open Document" type="object" class="btn-link" invisible="not document_id" icon="fa-external-link"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_document" type="object" class="oe_stat_button" icon="fa-file-text-o" invisible="not document_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Open</span>
                                <span class="o_stat_text">Document</span>
                            </div>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="department_id"/>
                            <field name="responsible_id" widget="many2one_avatar_user"/>
                            <field name="document_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="next_due_date"/>
                            <field name="completion_date" readonly="1"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Details" name="details">
                            <group>
                                <field name="description" widget="html" nolabel="1" placeholder="Describe the activity, its purpose, and any special instructions..."/>
                            </group>
                        </page>
                        <page string="Recurrence" name="recurrence">
                            <group>
                                <group>
                                    <field name="is_recurring" widget="boolean_toggle"/>
                                    <field name="recurrence_type" invisible="not is_recurring" required="is_recurring"/>

                                    <field name="recurrence_interval" invisible="not is_recurring or recurrence_type != 'simple'" required="is_recurring and recurrence_type == 'simple'"/>
                                    <field name="recurrence_unit" invisible="not is_recurring or recurrence_type != 'simple'" required="is_recurring and recurrence_type == 'simple'"/>

                                    <field name="recurrence_weekdays" invisible="not is_recurring or recurrence_type != 'weekly'" required="is_recurring and recurrence_type == 'weekly'"/>

                                    <field name="recurrence_day_of_month" invisible="not is_recurring or recurrence_type != 'monthly_day'" required="is_recurring and recurrence_type == 'monthly_day'"/>

                                    <field name="recurrence_week_of_month" invisible="not is_recurring or recurrence_type != 'monthly_weekday'" required="is_recurring and recurrence_type == 'monthly_weekday'"/>
                                    <field name="recurrence_weekday_of_month" invisible="not is_recurring or recurrence_type != 'monthly_weekday'" required="is_recurring and recurrence_type == 'monthly_weekday'"/>

                                    <field name="recurrence_end_date" invisible="not is_recurring"/>
                                </group>
                                <group>
                                    <field name="reminder_days_before"/>
                                </group>
                            </group>
                            <group invisible="not is_recurring">
                                <div class="alert alert-info" role="alert">
                                    <strong>Recurrence Info:</strong> This activity will automatically reset to "Pending" when marked as completed, with the next due date calculated based on the recurrence settings. If a recurrence end date is set and reached, the activity will be archived.
                                </div>
                            </group>
                        </page>
                        <page string="Additional Info" name="additional">
                            <group>
                                <group>
                                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color', 'no_create_edit': True}"/>
                                    <field name="sequence"/>
                                    <field name="mail_activity_id" readonly="1" string="Linked Activity"/>
                                </group>
                            </group>
                            <group>
                                <field name="notes" placeholder="Add any additional notes, observations, or updates here..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_department_main_activity_kanban" model="ir.ui.view">
        <field name="name">department.main.activity.kanban</field>
        <field name="model">department.main.activity</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column" default_group_by="state">
                <field name="name"/>
                <field name="responsible_id"/>
                <field name="next_due_date"/>
                <field name="state"/>
                <field name="is_recurring"/>
                <field name="recurrence_type"/>
                <field name="tag_ids"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                <div class="mt-2">
                                    <i class="fa fa-user"/> <field name="responsible_id"/>
                                </div>
                                <div class="mt-1">
                                    <i class="fa fa-calendar"/> <field name="next_due_date"/>
                                    <t t-if="record.is_recurring.raw_value">
                                        <i class="fa fa-refresh ms-2" title="Recurring"/>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_department_main_activity_calendar" model="ir.ui.view">
        <field name="name">department.main.activity.calendar</field>
        <field name="model">department.main.activity</field>
        <field name="arch" type="xml">
            <calendar string="Main Activities Calendar"
                      date_start="next_due_date"
                      color="state"
                      mode="month"
                      event_open_popup="true"
                      quick_create="false">
                <field name="name"/>
                <field name="responsible_id"/>
                <field name="state"/>
                <field name="department_id"/>
                <field name="is_recurring"/>
            </calendar>
        </field>
    </record>

    <record id="view_department_main_activity_search" model="ir.ui.view">
        <field name="name">department.main.activity.search</field>
        <field name="model">department.main.activity</field>
        <field name="arch" type="xml">
            <search string="Main Activities">
                <field name="name"/>
                <field name="department_id"/>
                <field name="responsible_id"/>
                <field name="document_id"/>
                <filter string="Pending" name="filter_pending" domain="[('state', '=', 'pending')]"/>
                <filter string="In Progress" name="filter_in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Overdue" name="filter_overdue" domain="[('state', '=', 'overdue')]"/>
                <filter string="Completed" name="filter_completed" domain="[('state', '=', 'completed')]"/>
                <separator/>
                <filter string="Recurring" name="filter_recurring" domain="[('is_recurring', '=', True)]"/>
                <separator/>
                <filter string="My Activities" name="filter_my_activities" domain="[('responsible_id', '=', uid)]"/>
                <separator/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Responsible" name="group_responsible" context="{'group_by': 'responsible_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'state'}"/>
                    <filter string="Recurrence Type" name="group_recurrence" context="{'group_by': 'recurrence_type'}"/>
                    <filter string="Due Date" name="group_due_date" context="{'group_by': 'next_due_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_department_main_activity" model="ir.actions.act_window">
        <field name="name">Main Activities</field>
        <field name="res_model">department.main.activity</field>
        <field name="view_mode">kanban,calendar,list,form</field>
        <field name="context">{
            'search_default_filter_pending': 1,
            'search_default_filter_in_progress': 1,
            'group_by': 'department_id'
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Main Activity
            </p>
            <p>
                Track recurring and one-time activities assigned to departments.<br/>
                Link activities to documents, set due dates, and monitor completion.
            </p>
        </field>
    </record>

    <record id="action_my_main_activities" model="ir.actions.act_window">
        <field name="name">My Main Activities</field>
        <field name="res_model">department.main.activity</field>
        <field name="view_mode">kanban,calendar,list,form</field>
        <field name="domain">[('responsible_id', '=', uid)]</field>
        <field name="context">{
            'search_default_filter_pending': 1,
            'search_default_filter_in_progress': 1,
            'search_default_filter_overdue': 1
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No activities assigned to you
            </p>
            <p>
                This view shows all main activities where you are the responsible person.
            </p>
        </field>
    </record>


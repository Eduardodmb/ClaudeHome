    <record id="view_hr_department_main_activities_form_inherit" model="ir.ui.view">
        <field name="name">hr.department.form.inherit.main.activities</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='department_notes_tab']" position="after">
                <page string="Main Activities" name="main_activities_tab">
                    <field name="main_activity_ids" context="{'default_department_id': id}">
                        <list decoration-danger="state == 'overdue'" decoration-success="state == 'completed'" decoration-muted="state == 'cancelled'">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="responsible_id" widget="many2one_avatar_user"/>
                            <field name="next_due_date"/>
                            <field name="state" widget="badge" decoration-danger="state == 'overdue'" decoration-success="state == 'completed'" decoration-warning="state == 'in_progress'"/>
                            <field name="is_recurring" widget="boolean_toggle"/>
                            <field name="recurrence_type" optional="hide"/>
                            <field name="document_id" optional="hide"/>
                            <button name="action_mark_completed" string="Complete" type="object" class="btn-success" invisible="state in ['completed', 'cancelled']" icon="fa-check"/>
                            <button name="action_open_document" string="Open Doc" type="object" class="btn-link" invisible="not document_id" icon="fa-external-link"/>
                        </list>

                        <form string="Main Activity">
                            <header>
                                <button name="action_mark_in_progress" string="Start" type="object" class="oe_highlight" invisible="state not in ['pending']"/>
                                <button name="action_mark_completed" string="Mark as Completed" type="object" class="oe_highlight" invisible="state in ['completed', 'cancelled']"/>
                                <button name="action_mark_cancelled" string="Cancel" type="object" invisible="state in ['completed', 'cancelled']"/>
                                <button name="action_reopen" string="Reopen" type="object" invisible="state not in ['completed', 'cancelled']"/>
                                <field name="state" widget="statusbar" statusbar_visible="pending,in_progress,completed"/>
                            </header>
                            <sheet>
                                <group>
                                    <group>
                                        <field name="name"/>
                                        <field name="responsible_id" widget="many2one_avatar_user"/>
                                        <field name="document_id"/>
                                    </group>
                                    <group>
                                        <field name="next_due_date"/>
                                        <field name="completion_date" readonly="1"/>
                                    </group>
                                </group>
                                <notebook>
                                    <page string="Details">
                                        <field name="description" widget="html" placeholder="Activity details..."/>
                                    </page>
                                    <page string="Recurrence">
                                        <group>
                                            <group>
                                                <field name="is_recurring" widget="boolean_toggle"/>
                                                <field name="recurrence_type" invisible="not is_recurring" required="is_recurring"/>

                                                <field name="recurrence_interval" invisible="not is_recurring or recurrence_type != 'simple'" required="is_recurring and recurrence_type == 'simple'"/>
                                                <field name="recurrence_unit" invisible="not is_recurring or recurrence_type != 'simple'" required="is_recurring and recurrence_type == 'simple'"/>

                                                <field name="recurrence_weekdays" invisible="not is_recurring or recurrence_type != 'weekly'" required="is_recurring and recurrence_type == 'weekly'"/>

                                                <field name="recurrence_day_of_month" invisible="not is_recurring or recurrence_type != 'monthly_day'" required="is_recurring and recurrence_type == 'monthly_day'"/>

                                                <field name="recurrence_week_of_month" invisible="not is_recurring or recurrence_type != 'monthly_weekday'" required="is_recurring and recurrence_type == 'monthly_weekday'"/>
                                                <field name="recurrence_weekday_of_month" invisible="not is_recurring or recurrence_type != 'monthly_weekday'" required="is_recurring and recurrence_type == 'monthly_weekday'"/>

                                                <field name="recurrence_end_date" invisible="not is_recurring"/>
                                            </group>
                                            <group>
                                                <field name="reminder_days_before"/>
                                            </group>
                                        </group>
                                        <group invisible="not is_recurring">
                                            <div class="alert alert-info" role="alert">
                                                <strong>Recurrence Info:</strong> This activity will automatically reset to "Pending" when marked as completed, with the next due date calculated based on the recurrence settings.
                                            </div>
                                        </group>
                                    </page>
                                </notebook>
                            </sheet>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_department_main_activity_tag_tree" model="ir.ui.view">
        <field name="name">department.main.activity.tag.tree</field>
        <field name="model">department.main.activity.tag</field>
        <field name="arch" type="xml">
            <list string="Activity Tags" editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="action_department_main_activity_tag" model="ir.actions.act_window">
        <field name="name">Activity Tags</field>
        <field name="res_model">department.main.activity.tag</field>
        <field name="view_mode">list,form</field>
    </record>


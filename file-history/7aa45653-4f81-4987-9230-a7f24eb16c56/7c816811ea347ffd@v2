<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bd_sourcesought_lead_tree" model="ir.ui.view">
        <field name="name">bd.sourcesought.lead.list</field>
        <field name="model">bd.sourcesought.lead</field>
        <field name="arch" type="xml">
            <list string="Sources Sought (BD)">
                <field name="ss_internal_id"/>
                <field name="name"/>
                <field name="stage_id"/>
                <field name="daily_search_lead_id"/>
                <field name="crm_lead_id" optional="show"/>
                <field name="solicitation_key_normalized" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_bd_sourcesought_lead_form" model="ir.ui.view">
        <field name="name">bd.sourcesought.lead.form</field>
        <field name="model">bd.sourcesought.lead</field>
        <field name="arch" type="xml">
            <form string="Sources Sought (BD)">
                <header>
                    <button name="action_promote_to_estimating"
                            string="Promote to Estimating"
                            type="object"
                            class="oe_highlight"
                            invisible="crm_lead_id"/>
                    <field name="stage_id" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <!-- Invisible: recomputes when activities change (chatter / list) so Planned/Done o2m reload -->
                    <field name="activity_state" invisible="1"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_daily_search"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-search"
                                string="Daily Search">
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="ss_internal_id" readonly="1"/>
                            <field name="name"/>
                            <field name="daily_search_lead_id" readonly="1"/>
                            <field name="crm_lead_id" readonly="1"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                            <field name="mail_history_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Email — custom subject match lines (SS BD Pre-Estimating)" name="bd_mail_subjects_block">
                        <field name="bd_mail_routing_custom_subject" widget="text" nolabel="1" colspan="2"
                               placeholder="One line per subject fragment; OR match (substring), de-duplicated on save…"/>
                    </group>
                    <notebook>
                        <page string="Activities" name="activities">
                            <div class="d-flex justify-content-end mb-2">
                                <button name="action_add_activity_from_tab"
                                        type="object"
                                        string="Add activity"
                                        class="btn-primary"
                                        icon="fa-plus"/>
                            </div>
                            <separator string="Planned"/>
                            <field name="planned_tab_activity_ids"
                                   nolabel="1"
                                   context="{
                                    'default_res_model': 'bd.sourcesought.lead',
                                    'default_res_model_id': %(bd_sourcesought.model_bd_sourcesought_lead)d,
                                    'default_res_id': id,
                                    'default_custom_state': 'planned',
                                    'default_active': True,
                                    'active_id': id,
                                    'active_model': 'bd.sourcesought.lead',
                                    'mail_create_nosubscribe': True,
                                    'mail_create_nolog': True,
                                    'active_test': True
                                }">
                                <list create="1"
                                      default_order="date_deadline asc, id desc"
                                      editable="bottom"
                                      decoration-bf="activity_type_id.category == 'meeting'"
                                      decoration-danger="date_deadline &lt; current_date and custom_state != 'done'"
                                      decoration-warning="date_deadline == current_date and custom_state != 'done'">
                                    <field name="res_model" column_invisible="True"/>
                                    <field name="res_model_id" column_invisible="True"/>
                                    <field name="activity_type_id"/>
                                    <field name="summary"/>
                                    <field name="note_display" string="Note"/>
                                    <field name="date_deadline"/>
                                    <field name="user_id"/>
                                    <field name="custom_state" widget="selection_toggle"
                                           decoration-info="custom_state == 'planned'"
                                           decoration-danger="custom_state == 'cancelled'"/>
                                    <button name="action_open_as_wizard" type="object" icon="fa-external-link" title="Open full wizard"/>
                                </list>
                            </field>
                            <separator string="Done" class="mt-3"/>
                            <field name="done_tab_activity_ids"
                                   nolabel="1"
                                   context="{
                                    'default_res_model': 'bd.sourcesought.lead',
                                    'default_res_model_id': %(bd_sourcesought.model_bd_sourcesought_lead)d,
                                    'default_res_id': id,
                                    'active_id': id,
                                    'active_model': 'bd.sourcesought.lead',
                                    'mail_create_nosubscribe': True,
                                    'mail_create_nolog': True,
                                    'active_test': False
                                }">
                                <list create="0"
                                      editable="bottom"
                                      default_order="completed_date desc, id desc"
                                      decoration-bf="activity_type_id.category == 'meeting'"
                                      decoration-success="custom_state == 'done'">
                                    <field name="res_model" column_invisible="True"/>
                                    <field name="res_model_id" column_invisible="True"/>
                                    <field name="activity_type_id"/>
                                    <field name="summary"/>
                                    <field name="note_display" string="Note"/>
                                    <field name="date_deadline"/>
                                    <field name="user_id"/>
                                    <field name="custom_state" widget="selection_toggle"
                                           decoration-success="custom_state == 'done'"
                                           decoration-info="custom_state == 'planned'"
                                           decoration-danger="custom_state == 'cancelled'"/>
                                    <field name="completed_date" optional="show" widget="datetime"/>
                                    <button name="action_open_as_wizard" type="object" icon="fa-external-link" title="Open full wizard"/>
                                </list>
                            </field>
                        </page>
                        <page string="Mail history" name="mail_history">
                            <header>
                                <button name="action_graph_fetch_mails_by_custom_subjects"
                                        type="object"
                                        string="Fetch from mailbox (Graph)"
                                        class="btn-secondary"
                                        icon="fa-cloud-download"
                                        help="Reads the same shared mailbox as Project mail (staged UPN, or project_mail_history.graph_shared_mailbox in Settings). Keeps messages that match the custom subject lines (OR) above on this record; creates rows with inline AI summary when the Graph service is configured."/>
                                <button name="action_generate_ai_summaries"
                                        type="object"
                                        string="Generate AI Summaries"
                                        class="btn-primary"
                                        icon="fa-magic"
                                        help="Generate AI summaries for mail history lines on this record that still need a summary."/>
                            </header>
                            <field name="mail_history_ids" nolabel="1" options="{'no_create': True}">
                                <list create="0" default_order="date desc, id desc">
                                    <field name="date"/>
                                    <field name="name" string="Subject"/>
                                    <field name="email_from" string="From"/>
                                    <field name="action_task_html" string="Summary" widget="html" class="text-break"/>
                                    <field name="needs_summary" string="Needs summary" optional="hide"/>
                                    <field name="crm_lead_id" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Field history" name="field_history">
                            <field name="field_history_ids" nolabel="1">
                                <list>
                                    <field name="create_date"/>
                                    <field name="field_name"/>
                                    <field name="old_value"/>
                                    <field name="new_value"/>
                                    <field name="user_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_bd_sourcesought_lead_search" model="ir.ui.view">
        <field name="name">bd.sourcesought.lead.search</field>
        <field name="model">bd.sourcesought.lead</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="ss_internal_id"/>
                <field name="solicitation_key_normalized"/>
                <field name="daily_search_lead_id"/>
                <field name="crm_lead_id"/>
                <field name="calendar_due_datetime"/>
                <filter string="Not promoted" name="not_promoted" domain="[('crm_lead_id', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="view_bd_sourcesought_lead_kanban" model="ir.ui.view">
        <field name="name">bd.sourcesought.lead.kanban</field>
        <field name="model">bd.sourcesought.lead</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column" quick_create="false">
                <field name="stage_id"/>
                <field name="color"/>
                <field name="name"/>
                <field name="ss_internal_id"/>
                <field name="daily_search_lead_id"/>
                <field name="crm_lead_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_color_{{ record.color.raw_value }}">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="ss_internal_id"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="name"/>
                            </div>
                            <div t-if="record.crm_lead_id.raw_value" class="text-success small">
                                Promoted
                            </div>
                            <div>
                                <field name="daily_search_lead_id"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_bd_sourcesought_lead_calendar" model="ir.ui.view">
        <field name="name">bd.sourcesought.lead.calendar</field>
        <field name="model">bd.sourcesought.lead</field>
        <field name="arch" type="xml">
            <calendar string="Sources Sought (BD)" date_start="calendar_due_datetime" color="stage_id" quick_create="false" mode="month" event_open_popup="true">
                <field name="name"/>
                <field name="ss_internal_id"/>
                <field name="daily_search_lead_id"/>
            </calendar>
        </field>
    </record>

    <record id="action_bd_sourcesought_lead" model="ir.actions.act_window">
        <field name="name">Sources Sought (BD)</field>
        <field name="res_model">bd.sourcesought.lead</field>
        <field name="view_mode">kanban,list,calendar,form</field>
        <field name="search_view_id" ref="view_bd_sourcesought_lead_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Sources Sought (BD) record from Daily Search (Vehicle Type = Sources Sought).
            </p>
        </field>
    </record>
</odoo>

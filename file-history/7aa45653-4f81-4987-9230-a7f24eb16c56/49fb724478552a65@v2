<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add "Lessons Learned" tab to Project form: list all fields except lead_id -->
    <record id="view_project_form_lessons_learned_tab" model="ir.ui.view">
        <field name="name">project.project.form.lessons.learned.tab</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='settings']" position="after">
                <page name="lessons_learned" string="Lessons Learned" sequence="1500">
                    <button name="action_lesson_learned_new" type="object" string="New Lesson" class="btn-secondary" icon="fa-plus"/>
                    <field name="lesson_ids" nolabel="1">
                        <list editable="top" create="1" delete="1">
                            <button name="action_view_lesson" type="object" icon="fa-arrow-right" title="View lesson" class="btn-link"/>
                            <field name="name"/>
                            <field name="project_id" readonly="1"/>
                            <field name="lesson_date"/>
                            <field name="lesson_user_id" widget="many2one_avatar_user"/>
                            <field name="create_uid" widget="many2one_avatar_user" string="Recorded by (system)" optional="hide"/>
                            <field name="create_date" widget="date" string="Recorded on" optional="hide"/>
                            <field name="department_id"/>
                            <field name="creator_department_id" optional="hide"/>
                            <field name="job_category"/>
                            <field name="state"/>
                            <field name="issue"/>
                            <field name="corrective_action"/>
                            <field name="tag_ids" widget="many2many_tags" optional="hide"/>
                            <field name="employee_id" optional="hide"/>
                            <field name="preventive_measure" optional="hide"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Activities tab to HR Applicant -->
    <record id="hr_applicant_view_form_activities" model="ir.ui.view">
        <field name="name">hr.applicant.form.activities</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Activities" name="recruitment_activities">
                    <field name="activity_ids" context="{
                        'default_res_model': 'hr.applicant',
                        'default_res_id': id,
                        'active_id': id,
                        'active_model': 'hr.applicant',
                        'default_custom_state': 'planned'
                    }">
                        <list editable="bottom" create="1" decoration-bf="activity_type_id.category == 'meeting'">
                            <field name="res_model" column_invisible="True"/>
                            <field name="res_model_id" column_invisible="True"/>
                            <field name="activity_type_id" string="Activity Type"/>
                            <field name="summary" string="Summary"/>
                            <field name="target_department_id" string="Target Department" placeholder="Select Department..." column_invisible="context.get('default_res_model') != 'hr.department'"/>
                            <field name="target_document_item_id" string="Target Document" placeholder="Select Document..."/>
                            <field name="custom_state" string="Status" widget="badge" decoration-success="custom_state == 'done'" decoration-info="custom_state == 'planned'" decoration-danger="custom_state == 'cancelled'"/>
                            <field name="date_deadline" string="Due Date"/>
                            <field name="user_id" string="Assigned to"/>
                            <button name="action_open_as_wizard" type="object" icon="fa-external-link" string="Open" title="Open Activity Wizard" class="btn-primary"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

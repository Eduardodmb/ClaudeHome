<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="project_view_form_inherit_budget_fields" model="ir.ui.view">
        <field name="name">project.project.form.budget.fields</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            
            <xpath expr="//page[@name='contract_info']" position="after">
                
                <page string="Budget &amp; SOW" name="budget_sow_tab" sequence="500">
                    <group string="Scope of Work (SOW) &amp; Budget Details">
                        
                        <field name="x_sow_description" colspan="4" placeholder="1. Detailed description of the Scope of Work..."/>
                        
                        <field name="x_expected_performance" colspan="4" placeholder="2. Expected performance metrics or goals per person..."/>
                        
                        <group string="Effort Estimation" colspan="2">
                            <field name="x_working_days_budget"/>
                            <field name="x_hrs_on_site_budget"/>
                        </group>
                        
                        <group string="Equipment and Notes" colspan="2">
                            <field name="x_special_equipment_budget"/>
                            <field name="x_special_notes_budget"/>
                        </group>
                        
                    </group>
                </page>
                
            </xpath>
            
        </field>
    </record>
</odoo>
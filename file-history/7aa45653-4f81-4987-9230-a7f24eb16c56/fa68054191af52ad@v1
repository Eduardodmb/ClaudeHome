<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_activity_table_form_stage_plans" model="ir.ui.view">
        <field name="name">project.project.activity.table.form.stage.plans</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project_custom_fields.view_project_activity_table_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='planned_tab_activity_ids']" position="attributes">
                <attribute name="context">{
                    'default_res_model': 'project.project',
                    'default_res_model_id': %(project.model_project_project)d,
                    'default_res_id': id,
                    'default_is_closing_checklist': False,
                    'default_custom_state': 'planned',
                    'default_active': True,
                    'mail_create_nosubscribe': True,
                    'mail_create_nolog': True,
                    'active_test': True
                }</attribute>
            </xpath>
            <xpath expr="//field[@name='done_tab_activity_ids']" position="attributes">
                <attribute name="context">{
                    'default_res_model': 'project.project',
                    'default_res_model_id': %(project.model_project_project)d,
                    'default_res_id': id,
                    'default_is_closing_checklist': False,
                    'mail_create_nosubscribe': True,
                    'mail_create_nolog': True,
                    'active_test': False
                }</attribute>
            </xpath>

            <xpath expr="//page[@name='activities_table_tab']" position="after">
                <page string="Closing Checklist" name="closing_checklist_tab">
                    <div class="d-flex justify-content-end mb-2">
                        <button name="action_add_closing_activity_from_tab" type="object" string="Add activity" class="btn-primary" icon="fa-plus"/>
                    </div>

                    <separator string="Planned"/>

                    <field name="closing_planned_tab_activity_ids" nolabel="1"
                        context="{
                            'default_res_model': 'project.project',
                            'default_res_model_id': %(project.model_project_project)d,
                            'default_res_id': id,
                            'default_is_closing_checklist': True,
                            'default_custom_state': 'planned',
                            'default_active': True,
                            'mail_create_nosubscribe': True,
                            'mail_create_nolog': True,
                            'active_test': True
                        }">
                        <list create="1" default_order="date_deadline asc, id desc"
                            decoration-bf="activity_type_id.category == 'meeting'"
                            editable="bottom"
                            decoration-danger="date_deadline &lt; current_date and custom_state != 'done'"
                            decoration-warning="date_deadline == current_date and custom_state != 'done'">
                            <field name="res_model" column_invisible="True"/>
                            <field name="res_model_id" column_invisible="True"/>
                            <field name="activity_type_id"/>
                            <field name="summary"/>
                            <field name="note_display" string="Note"/>
                            <field name="target_department_id" placeholder="Select Department..." column_invisible="context.get('default_res_model') != 'hr.department'"/>
                            <field name="target_document_item_id" placeholder="Select Document..."/>
                            <field name="custom_state" widget="selection_toggle"
                                decoration-success="custom_state == 'done'"
                                decoration-info="custom_state == 'planned'"
                                decoration-danger="custom_state == 'cancelled'"/>
                            <field name="date_deadline"/>
                            <field name="user_id"/>
                            <field name="calendar_start" optional="show"/>
                            <field name="activity_tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" optional="show"/>
                            <button name="action_open_as_wizard" type="object" icon="fa-external-link" title="Open full wizard"/>
                        </list>
                    </field>

                    <separator string="Done" class="mt-3"/>

                    <field name="closing_done_tab_activity_ids" nolabel="1"
                        context="{
                            'default_res_model': 'project.project',
                            'default_res_model_id': %(project.model_project_project)d,
                            'default_res_id': id,
                            'default_is_closing_checklist': True,
                            'mail_create_nosubscribe': True,
                            'mail_create_nolog': True,
                            'active_test': False
                        }">
                        <list create="0" default_order="completed_date desc, id desc"
                            decoration-bf="activity_type_id.category == 'meeting'"
                            decoration-success="custom_state == 'done'">
                            <field name="res_model" column_invisible="True"/>
                            <field name="res_model_id" column_invisible="True"/>
                            <field name="activity_type_id"/>
                            <field name="summary"/>
                            <field name="note_display" string="Note"/>
                            <field name="target_department_id" placeholder="Select Department..." column_invisible="context.get('default_res_model') != 'hr.department'"/>
                            <field name="target_document_item_id" placeholder="Select Document..."/>
                            <field name="custom_state" widget="badge" decoration-success="custom_state == 'done'" decoration-info="custom_state == 'planned'" decoration-danger="custom_state == 'cancelled'"/>
                            <field name="date_deadline"/>
                            <field name="user_id"/>
                            <field name="completed_date" optional="show"/>
                            <field name="calendar_start" optional="show"/>
                            <field name="activity_tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" optional="show"/>
                            <button name="action_open_as_wizard" type="object" icon="fa-external-link" title="Open full wizard"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

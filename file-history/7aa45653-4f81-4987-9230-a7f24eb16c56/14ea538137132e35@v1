<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Central inherit target (`view_department_form_inherit_custom`) for department form extensions.
        Provides `activities_table_tab` (Tickets) expected by project, meetings, notes, certifications, etc.
        (Content matches the former ticket_system tab; ticket_system no longer loads a duplicate view.)
    -->
    <record id="view_department_form_inherit_custom" model="ir.ui.view">
        <field name="name">hr.department.form.inherit.custom.anchor</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">
            <!-- Odoo 18 core hr.department form has no notebook; insert after the main sheet group. -->
            <xpath expr="//sheet/group" position="after">
                <notebook name="hr_department_form_tabs">
                <page string="Tickets" name="activities_table_tab">
                    <field name="activity_ids"
                        context="{
                            'default_res_model': 'hr.department',
                            'default_res_model_id': %(hr.model_hr_department)d,
                            'default_res_id': id,
                            'mail_create_nosubscribe': True,
                            'mail_create_nolog': True,
                        }">
                        <list decoration-muted="custom_state == 'done'"
                              decoration-danger="custom_state == 'cancelled'"
                              default_order="date_deadline desc"
                              editable="bottom">
                            <field name="res_model" column_invisible="True"/>
                            <field name="res_model_id" column_invisible="True"/>
                            <field name="activity_type_id"/>
                            <field name="summary"/>
                            <field name="custom_state" widget="badge" decoration-success="custom_state == 'done'" decoration-info="custom_state == 'planned'" decoration-danger="custom_state == 'cancelled'"/>
                            <field name="date_deadline"/>
                            <field name="user_id"/>
                            <button name="action_open_as_wizard" type="object" icon="fa-external-link" title="Open full wizard"/>
                        </list>
                    </field>
                </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>

<odoo>
    <record id="mail_activity_schedule_update_view_form" model="ir.ui.view">
        <field name="name">mail.activity.schedule.update.view.form</field>
        <field name="model">mail.activity.schedule.update</field>
        <field name="arch" type="xml">
            <form string="Update Details">
                <group>
                    <field name="schedule_id" invisible="1"/>
                    <field name="date"/>
                    <field name="user_id" readonly="1"/>
                </group>
                <group>
                    <field name="note" placeholder="Enter update notes here..."/>
                </group>
            </form>
        </field>
    </record>
    
    <record id="action_open_schedule_update" model="ir.actions.act_window">
        <field name="name">Update Details</field>
        <field name="res_model">mail.activity.schedule.update</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="mail_activity_schedule_update_view_form"/>
        <field name="target">new</field>
    </record>
    
    <record id="mail_activity_schedule_view_form_inherit_updates" model="ir.ui.view">
        <field name="name">mail.activity.schedule.view.form.inherit.updates</field>
        <field name="model">mail.activity.schedule</field>
        <field name="inherit_id" ref="mail.mail_activity_schedule_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <!-- <sheet> -->
                    <group string="Update Logs" name="Logs" invisible="not id">
                        <field name="update_line_ids" nolabel="1">
                            <list editable="bottom">
                                <button name="%(action_open_schedule_update)d" 
                                        type="action" 
                                        icon="fa-external-link" 
                                        title="Open in popup"/>
                                <field name="schedule_id" column_invisible="1"/>
                                <field name="date"/>
                                <field name="user_id" readonly="1"/>
                                <field name="note"/>
                            </list>
                        </field>
                    </group>
                <!-- </sheet> -->
            </xpath>
        </field>
    </record>
    <record id="mail_activity_update_view_form" model="ir.ui.view">
        <field name="name">mail.activity.update.view.form</field>
        <field name="model">mail.activity.update</field>
        <field name="arch" type="xml">
            <form string="Update Details">
                <sheet>
                    <group>
                        <group>
                            <field name="activity_id" invisible="1"/>
                            <field name="date"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="notify_creator" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="note" placeholder="Enter update notes here..."/>
                        </page>
                        <page string="Attachments">
                            <field name="attachment_ids" widget="many2many_binary" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="action_open_activity_update" model="ir.actions.act_window">
        <field name="name">Update Details</field>
        <field name="res_model">mail.activity.update</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="mail_activity_update_view_form"/>
        <field name="target">new</field>
    </record>
    
    <record id="mail_activity_view_form_popup_updates" model="ir.ui.view">
        <field name="name">mail.activity.view.form.popup.updates</field>
        <field name="model">mail.activity</field>
        <field name="inherit_id" ref="mail.mail_activity_view_form_popup"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <!-- <sheet> -->
                    <group string="Update Logs" invisible="not id">
                        <field name="update_line_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="activity_id" column_invisible="1"/>
                                <field name="date" string="Date"/>
                                <field name="user_id" string="User" readonly="1"/>
                                <field name="note" string="Update Note"/>
                                <field name="notify_creator" string="Notify Creator" widget="boolean_toggle" optional="show"/>
                                <field name="attachment_ids" string="Attachments" widget="many2many_binary" optional="show"/>
                                <button name="%(action_open_activity_update)d"
                                        type="action"
                                        icon="fa-external-link"
                                        string=""
                                        title="Open in popup"/>
                            </list>
                        </field>
                    </group>
                <!-- </sheet> -->
            </xpath>
        </field>
    </record>
</odoo>
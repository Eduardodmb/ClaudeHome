<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Simple Creation Form: Hide alias fields and add duplicate warning -->
    <record id="hr_job_simple_form_inherit" model="ir.ui.view">
        <field name="name">hr.job.simple.form.inherit</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr_recruitment.hr_job_simple_form"/>
        <field name="arch" type="xml">
            <!-- Hide alias fields -->
            <xpath expr="//label[@for='alias_name']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//div[@name='alias_def']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Add duplicate warning after name field -->
            <field name="name" position="after">
                <field name="similar_job_ids" invisible="1"/>
                <div class="alert alert-warning" role="alert" invisible="not similar_job_ids">
                    <strong>Warning:</strong> Similar job positions already exist:
                    <field name="similar_job_ids" widget="many2many_tags" readonly="1"/>
                </div>
            </field>
        </field>
    </record>

    <!-- Kanban View: Add Settings button directly on card -->
    <record id="view_hr_job_kanban_inherit" model="ir.ui.view">
        <field name="name">hr.job.kanban.inherit</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr_recruitment.view_hr_job_kanban"/>
        <field name="arch" type="xml">
            <!-- Add default order to show open positions first -->
            <xpath expr="//kanban" position="attributes">
                <attribute name="default_order">recruitment_status desc, name</attribute>
            </xpath>

            <!-- Add Settings button to kanban card footer -->
            <xpath expr="//div[@name='kanban_boxes']" position="after">
                <div class="row g-0 mt-2">
                    <button name="edit_job" type="open" class="btn btn-sm btn-secondary w-100" groups="hr_recruitment.group_hr_recruitment_user">
                        <i class="fa fa-cog"/> Settings
                    </button>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Main Form View: Add status header and three new tabs -->
    <record id="view_hr_job_form_inherit" model="ir.ui.view">
        <field name="name">hr.job.form.inherit</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr.view_hr_job_form"/>
        <field name="arch" type="xml">
            <!-- Add recruitment status to header -->
            <header position="inside">
                <button name="action_open_position_wizard"
                        string="Open Position"
                        type="object"
                        class="btn-primary"
                        invisible="recruitment_status == 'open'"
                        help="Open this position and set vacancy count"/>
                <button name="action_open_position_wizard"
                        string="Update Vacancies"
                        type="object"
                        class="btn-secondary"
                        invisible="recruitment_status != 'open'"
                        help="Update the number of vacancies"/>
                <field name="recruitment_status" widget="statusbar" statusbar_visible="open,closed"/>
            </header>

            <!-- Rename Job Summary tab to Job Description -->
            <xpath expr="//page[@name='job_description_page']" position="attributes">
                <attribute name="string">Job Description</attribute>
            </xpath>

            <!-- Add recruitment status field in form body for easy access -->
            <xpath expr="//field[@name='department_id']" position="after">
                <field name="recruitment_status"/>
            </xpath>

            <!-- Hide Industry field -->
            <xpath expr="//field[@name='industry_id']" position="replace"/>

            <!-- Hide Email Alias fields -->
            <xpath expr="//label[@for='alias_name']" position="replace"/>
            <xpath expr="//div[@name='alias_def']" position="replace"/>

            <!-- Add Publication History tab -->
            <xpath expr="//notebook" position="inside">

                <!-- Add Phone Screen Questions tab -->
                <page string="Phone Screen Questions" name="phone_screen">
                    <group>
                        <button name="action_sync_phone_screen_to_applicants"
                                string="Sync to Applicants"
                                type="object"
                                class="btn-primary"
                                help="Add missing phone screen answer lines for all applicants on this job"/>
                    </group>
                    <field name="phone_screen_question_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="question"/>
                            <field name="question_type"/>
                            <field name="expected_answer"/>
                            <field name="is_mandatory"/>
                        </list>
                    </field>
                </page>

                

                <!-- Add Recruitment Checklist Templates tab -->
                <page string="Recruitment Checklist" name="recruitment_checklist">
                    <group>
                        <button name="action_populate_default_checklist"
                                string="Load Default Checklist Templates"
                                type="object"
                                class="btn-primary"
                                invisible="checklist_template_ids"
                                help="Populate with the 12 standard recruitment checklist items"/>
                    </group>
                    <field name="checklist_template_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="status"
                                   decoration-info="status == 'draft'"
                                   decoration-warning="status == 'pending_approval'"
                                   decoration-success="status == 'approved'"
                                   optional="show"/>
                            <field name="sharepoint_url" widget="url" optional="show"/>
                            <field name="attachment_filename" optional="show" string="Document"/>
                            <field name="attachment_count" optional="hide" string="Multiple Files"/>
                            <field name="description" optional="hide"/>
                        </list>
                        <form>
                            <header>
                                <field name="status" widget="statusbar" statusbar_visible="draft,pending_approval,approved"/>
                            </header>
                            <sheet>
                                <group>
                                    <group>
                                        <field name="name"/>
                                        <field name="sequence"/>
                                    </group>
                                    <group>
                                        <field name="sharepoint_url" widget="url"/>
                                    </group>
                                </group>
                                <group>
                                    <group string="Upload Document">
                                        <field name="attachment_filename" invisible="1"/>
                                        <field name="attachment" string="Attached Document" filename="attachment_filename"/>
                                    </group>
                                </group>
                                <notebook>
                                    <page string="Multiple Attachments" name="attachments">
                                        <field name="attachment_ids" widget="many2many_binary" string="Upload Multiple Documents"/>
                                    </page>
                                    <page string="Description" name="description">
                                        <field name="description" placeholder="Additional information about this checklist item..."/>
                                    </page>
                                </notebook>
                            </sheet>
                        </form>
                    </field>
                </page>

                <!-- Add Quiz Questions tab -->
                <page string="Quiz Questions" name="quiz">
                    <field name="quiz_question_ids">
                        <list>
                            <field name="sequence" widget="handle"/>
                            <field name="question"/>
                            <field name="question_type"/>
                            <field name="points"/>
                        </list>
                        <form>
                            <group>
                                <group>
                                    <field name="sequence"/>
                                    <field name="question"/>
                                    <field name="question_type"/>
                                    <field name="points"/>
                                </group>
                                <group>
                                    <field name="option_a" invisible="question_type != 'multiple_choice'"/>
                                    <field name="option_b" invisible="question_type != 'multiple_choice'"/>
                                    <field name="option_c" invisible="question_type != 'multiple_choice'"/>
                                    <field name="option_d" invisible="question_type != 'multiple_choice'"/>
                                    <field name="correct_answer"/>
                                    <field name="answer_text" invisible="question_type not in ['short_answer', 'essay']"/>
                                </group>
                                <group>
                                    <field name="attachment_ids" widget="many2many_binary" options="{'accepted_file_extensions': '*'}"/>
                                </group>
                            </group>
                        </form>
                    </field>
                </page>

                <page string="Publication History" name="publication_history">
                    <field name="publication_history_ids" readonly="1">
                        <list create="0" edit="0" delete="0">
                            <field name="action" decoration-success="action == 'published'" decoration-muted="action == 'unpublished'"/>
                            <field name="timestamp"/>
                            <field name="user_id"/>
                            <field name="notes"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Search View: Add recruitment status filters -->
    <record id="view_job_filter_inherit" model="ir.ui.view">
        <field name="name">hr.job.search.inherit</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr_recruitment.view_job_filter_recruitment"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='my_favorite_jobs']" position="after">
                <filter string="Open Positions" name="recruitment_open" domain="[('recruitment_status', '=', 'open')]"/>
                <filter string="Closed Positions" name="recruitment_closed" domain="[('recruitment_status', '=', 'closed')]"/>
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="recruitment_status"/>
            </xpath>
        </field>
    </record>

    <!-- List View: Add recruitment status column with decorations and sort by status -->
    <record id="hr_job_view_tree_inherit" model="ir.ui.view">
        <field name="name">hr.job.tree.inherit</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr_recruitment.hr_job_view_tree_inherit"/>
        <field name="arch" type="xml">
            <!-- Add default order to show open positions first -->
            <xpath expr="//list" position="attributes">
                <attribute name="default_order">recruitment_status desc, name</attribute>
            </xpath>

            <field name="department_id" position="after">
                <field name="recruitment_status"
                       decoration-success="recruitment_status == 'open'"
                       decoration-muted="recruitment_status == 'closed'"
                       optional="show"/>
            </field>
        </field>
    </record>

    <!-- Override all Job Positions actions to show only open positions by default -->

    <!-- Main action (kanban view for recruitment users) -->
    <record id="hr_recruitment.action_hr_job" model="ir.actions.act_window">
        <field name="context">{'search_default_recruitment_open': 1}</field>
    </record>

    <!-- Interviewer action (kanban view for interviewers) -->
    <record id="hr_recruitment.action_hr_job_interviewer" model="ir.actions.act_window">
        <field name="context">{'create': False, 'search_default_recruitment_open': 1}</field>
    </record>

    <!-- Config action (list view in configuration menu) -->
    <record id="hr_recruitment.action_hr_job_config" model="ir.actions.act_window">
        <field name="context">{'search_default_in_recruitment': 1, 'search_default_recruitment_open': 1}</field>
    </record>

    <!-- Server Action: Sync Employee Positions to Recruitment -->
    <record id="action_server_sync_employee_positions" model="ir.actions.server">
        <field name="name">Sync Employee Positions to Recruitment</field>
        <field name="model_id" ref="hr.model_hr_job"/>
        <field name="binding_model_id" ref="hr.model_hr_job"/>
        <field name="binding_view_types">list,kanban</field>
        <field name="state">code</field>
        <field name="code">
action = model.action_sync_employee_positions_to_recruitment()
        </field>
    </record>
</odoo>

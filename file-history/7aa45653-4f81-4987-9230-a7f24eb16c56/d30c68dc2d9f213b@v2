<?xml version="1.0" encoding="utf-8"?>
<!--
  Project form: Marketing notebook page.

  - Anchored after project_custom_fields' "Project Contacts" tab so the xpath
    stays stable (module depends on project_custom_fields).
  - Past Performance list is restricted to group_past_performance_user so users
    without model access do not hit AccessError on the embedded One2many.
  - Marketing gallery: favorites list + refresh / add-favorites + upload wizards.
-->
<odoo>
    <record id="view_project_form_marketing" model="ir.ui.view">
        <field name="name">project.project.form.marketing</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='contacts']" position="after">
                <page name="marketing" string="Marketing" sequence="2000">
                    <group
                        string="Past Performance"
                        groups="project_past_performance.group_past_performance_user"
                    >
                        <field
                            name="past_performance_ids"
                            nolabel="1"
                            context="{'default_project_id': id, 'tree_view_ref': 'project_past_performance.view_past_performance_tree'}"
                        />
                    </group>
                    <separator string="Customer Feedback"/>
                    <div class="text-muted">Not implemented yet.</div>
                    <separator string="Project photo favorites"/>
                    <group>
                        <div colspan="2" class="text-muted mb-2">
                            Favorites shown below. Refresh discovers images from configured sources; then add them to favorites or upload new files.
                        </div>
                        <div colspan="2" class="mb-2">
                            <button
                                name="action_refresh_marketing_gallery"
                                type="object"
                                string="Refresh from sources"
                                class="btn-secondary me-2"
                                help="Scan configured models and add image attachments to this gallery."
                            />
                            <button
                                name="action_open_marketing_gallery_add_favorites_wizard"
                                type="object"
                                string="Add photos to favorites"
                                class="btn-primary me-2"
                                help="Choose from discovered photos that are not in favorites yet."
                            />
                            <button
                                name="action_open_marketing_gallery_upload_photos_wizard"
                                type="object"
                                string="Upload new photos"
                                class="btn-secondary"
                                help="Attach a new image to this project and optionally add it to favorites."
                            />
                        </div>
                        <field
                            name="marketing_gallery_photo_ids"
                            nolabel="1"
                            colspan="2"
                            domain="[('is_starred', '=', True)]"
                            context="{'default_project_id': id, 'default_is_starred': True, 'list_view_ref': 'project_past_performance.view_project_marketing_gallery_photo_tree_favorites'}"
                        />
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

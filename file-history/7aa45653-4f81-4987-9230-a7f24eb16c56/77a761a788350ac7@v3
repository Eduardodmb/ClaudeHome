<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_form_tab_ordering" model="ir.ui.view">
        <field name="name">project.project.form.tab.ordering</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">

            <!-- HIDE SETTINGS TAB -->
            <xpath expr="//page[@name='settings']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- SET TAB SEQUENCE FOR ORDERING -->
            <!-- Note: Lower sequence numbers appear first -->

            <!-- 1. NOTES (project_notes_tab from project_notes module) -->
            <xpath expr="//page[@name='project_notes_tab']" position="attributes">
                <attribute name="sequence">1</attribute>
            </xpath>

            <!-- 2. TEAM -->
            <xpath expr="//page[@name='TEAM']" position="attributes">
                <attribute name="sequence">2</attribute>
            </xpath>

            <!-- 3. CONTRACT INFO -->
            <xpath expr="//page[@name='contract_info']" position="attributes">
                <attribute name="sequence">3</attribute>
            </xpath>

            <!-- 4. PROJECT CONTACTS -->
            <xpath expr="//page[@name='contacts']" position="attributes">
                <attribute name="sequence">4</attribute>
            </xpath>

            <!-- 5. BUDGET & SOW -->
            <xpath expr="//page[@name='budget_sow_tab']" position="attributes">
                <attribute name="sequence">5</attribute>
            </xpath>

            <!-- 6. KICK OFF CHECKLIST -->
            <xpath expr="//page[@name='kickoff_checklist']" position="attributes">
                <attribute name="sequence">6</attribute>
            </xpath>

            <!-- 7. CERTIFICATIONS -->
            <xpath expr="//page[@name='certifications']" position="attributes">
                <attribute name="sequence">7</attribute>
            </xpath>

            <!-- 8. DELIVERABLES -->
            <xpath expr="//page[@name='deliverables']" position="attributes">
                <attribute name="sequence">8</attribute>
            </xpath>

            <!-- 9. ACTIVITIES -->
            <xpath expr="//page[@name='contact_tasks']" position="attributes">
                <attribute name="sequence">9</attribute>
            </xpath>

            <!-- 10. MAIL HISTORY -->
            <xpath expr="//page[@name='mail_history']" position="attributes">
                <attribute name="sequence">10</attribute>
            </xpath>

            <!-- 11. MEETINGS -->
            <xpath expr="//page[@name='project_meetings']" position="attributes">
                <attribute name="sequence">11</attribute>
            </xpath>

            <!-- 12. SUBCONTRACTORS -->
            <xpath expr="//page[@name='subcontractors_tab']" position="attributes">
                <attribute name="sequence">12</attribute>
            </xpath>

            <!-- 13. TECHNICIAN DAILY REPORTS -->
            <xpath expr="//page[@name='technician_daily_reports']" position="attributes">
                <attribute name="sequence">13</attribute>
            </xpath>

            <!-- 14. INCIDENT REPORTS -->
            <xpath expr="//page[@name='incidents']" position="attributes">
                <attribute name="sequence">14</attribute>
            </xpath>

            <!-- 15. LESSONS LEARNED -->
            <xpath expr="//page[@name='lessons_learned']" position="attributes">
                <attribute name="sequence">15</attribute>
            </xpath>

            <!-- 16. CAPA -->
            <xpath expr="//page[@name='capa']" position="attributes">
                <attribute name="sequence">16</attribute>
            </xpath>

            <!-- 17. QA (Quality Assurance) -->
            <xpath expr="//page[@name='quality_assurance']" position="attributes">
                <attribute name="sequence">17</attribute>
            </xpath>

            <!-- 18. BONDING -->
            <xpath expr="//page[@name='bonding']" position="attributes">
                <attribute name="sequence">18</attribute>
            </xpath>

            <!-- 19. CLOSING CHECKLIST - Not yet implemented -->
            <!-- <xpath expr="//page[@name='closing_checklist']" position="attributes">
                <attribute name="sequence">19</attribute>
            </xpath> -->

            <!-- 20. MARKETING -->
            <xpath expr="//page[@name='marketing']" position="attributes">
                <attribute name="sequence">20</attribute>
            </xpath>

            <!-- 21. WARRANTIES - Not yet implemented -->
            <!-- <xpath expr="//page[@name='warranties']" position="attributes">
                <attribute name="sequence">21</attribute>
            </xpath> -->

            <!-- 22. FINANCIAL DASHBOARD -->
            <xpath expr="//page[@name='financial_dashboard']" position="attributes">
                <attribute name="sequence">22</attribute>
            </xpath>

            <!-- 23. SETTINGS (hidden - moved to end just in case visibility needs to be toggled) -->
            <!-- Settings tab is hidden above, but if it needs to be shown, it will appear last -->

            <!-- 24. APPOINTMENTS -->
            <xpath expr="//page[@name='appointments_page']" position="attributes">
                <attribute name="sequence">24</attribute>
            </xpath>

        </field>
    </record>
</odoo>

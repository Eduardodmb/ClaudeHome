<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_change_order" model="ir.actions.act_window">
        <field name="name">Change Orders</field>
        <field name="res_model">change.order</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_group_month': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Project Change Order
            </p>
        </field>
    </record>

    <record id="action_change_order_status" model="ir.actions.act_window">
        <field name="name">Change Order Statuses</field>
        <field name="res_model">change.order.status</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Status
            </p>
        </field>
    </record>

    <record id="action_change_order_area" model="ir.actions.act_window">
        <field name="name">Areas Responsible</field>
        <field name="res_model">change.order.area</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Area
            </p>
        </field>
    </record>

    <record id="action_change_order_tag" model="ir.actions.act_window">
        <field name="name">Change Order Tags</field>
        <field name="res_model">change.order.tag</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Tag
            </p>
        </field>
    </record>

    <record id="view_change_order_tree" model="ir.ui.view">
        <field name="name">change.order.list</field>
        <field name="model">change.order</field>
        <field name="arch" type="xml">
            <list string="Change Orders"
                  decoration-bf="status.name in ('Approved', 'Completed')"
                  default_order="submittal_date desc">
                <field name="change_order_id" />
                <field name="name" />
                <field name="project_id" />
                <field name="lead_id" />
                <field name="status" widget="badge" />
                <field name="dollar_amount" sum="Total Amount"/>
                <field name="x_bom_summary_modified_total"
                        string="BOM Modified Total"
                        widget="monetary"
                        options="{'currency_field': 'company_currency'}"
                        optional="show"/>
                <field name="x_bom_summary_total_current_expense"
                        string="BOM Current"
                        widget="monetary"
                        options="{'currency_field': 'company_currency'}"
                        optional="show"/>
                <field name="x_bom_summary_balance_grand"
                        string="BOM Balance"
                        widget="monetary"
                        options="{'currency_field': 'company_currency'}"
                        optional="show"/>
                <field name="submittal_date" />
                <field name="submittal_month" optional="hide"/>
                <field name="submittal_quarter" optional="hide"/>
                <field name="approval_date" />
                <field name="area_responsible" />
                <field name="paid" />
                <field name="external_internal"/>
            </list>
        </field>
    </record>

    <record id="view_change_order_search" model="ir.ui.view">
        <field name="name">change.order.search</field>
        <field name="model">change.order</field>
        <field name="arch" type="xml">
            <search string="Change Orders">
                <field name="change_order_id"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="lead_id"/>
                <field name="status"/>
                <field name="external_internal"/>
                <separator/>
                <filter string="External" name="filter_external" domain="[('external_internal', '=', 'external')]"/>
                <filter string="Internal" name="filter_internal" domain="[('external_internal', '=', 'internal')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Month" name="group_month" context="{'group_by': 'submittal_month'}"/>
                    <filter string="Quarter" name="group_quarter" context="{'group_by': 'submittal_quarter'}"/>
                    <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'external_internal'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_change_order_form" model="ir.ui.view">
        <field name="name">change.order.form</field>
        <field name="model">change.order</field>
        <field name="arch" type="xml">
            <form string="Change Order">
                <header>
                    <button name="action_regenerate_id" 
                        string="Regenerate ID" 
                        type="object" 
                        class="btn-secondary" 
                        icon="fa-refresh"
                        invisible="not id"
                        confirm="Are you sure you want to recalculate the ID? This will update the sequence based on the current Project or Lead."/>
                    <field name="stage_id" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="change_order_id" readonly="1" />
                        </h1>
                        <h2>
                            <field name="name" placeholder="Change Order Title/Subject" />
                        </h2>
                    </div>
                    
                    <group>
                        <group>
                            <field name="project_id" string="Project" /> 
                            <field name="stage_id" string="Kanban Stage" />
                            <field name="lead_id" string = "Lead/Opportunity"/>
                            <field name="change_order_by" />
                            <field name="area_responsible" />
                            <field name="external_internal"/>
                            <field name="asana_link" widget="url"/>
                            <field name="sharepoint_link" widget="url"/>
                        </group>
                        <group>
                            <field name="dollar_amount" widget="monetary" />
                            <field name="paid" />
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" />
                        </group>
                        <group string="Stage Gates (Approver Only)">
                            <group>
                                <field name="x_checklist" groups="project_change_order.group_change_order_approver"/>
                                <field name="x_scope_debrief" groups="project_change_order.group_change_order_approver"/>
                                <field name="x_bom_review" groups="project_change_order.group_change_order_approver"/>
                            </group>
                            <group>
                                <field name="x_final_proposal" groups="project_change_order.group_change_order_approver"/>
                                <field name="x_final_review" groups="project_change_order.group_change_order_approver"/>
                                <field name="x_sent_proposal" groups="project_change_order.group_change_order_approver"/>
                            </group>
                        </group>
                    </group>
                    
                    <group string="Dates &amp; Approvals">
                        <group>
                            <field name="submittal_date" />
                            <field name="approval_date" />
                        </group>
                        <group>
                            <field name="approved_by" />
                            <field name="status"/>
                        </group>
                    </group>
                    
                    <group string="SOW/Details">
                        <field name="comments" placeholder="Detailed description of the change order..." nolabel="1"/>
                    </group>
                    
                    <group string="Root Cause">
                        <field name="root_cause" placeholder="Analyze the root cause of this change order." nolabel="1" />
                        </group>
                    <notebook>
                        <page string="Activities" name="activities_table_tab">
                            <field name="activity_ids" 
                                context="{
                                        'default_res_model': 'change.order',
                                        'default_res_model_id': %(project_change_order.model_change_order)d,
                                        'default_res_id': id,
                                        'active_id': id,
                                        'active_model': 'change.order',
                                        'mail_create_nosubscribe': True,
                                        'mail_create_nolog': True
                                }">
                                <list
                                    decoration-bf="activity_type_id.category == 'meeting'"
                                    editable="top"
                                    default_order="id desc"
                                >
                                    <field name="res_model" column_invisible="True"/>
                                    <field name="res_model_id" column_invisible="True"/>
                                    <field name="activity_type_id"/>
                                    <field name="summary"/>
                                    <field name="note_display" string="Note"/>
                                    <field name="target_department_id" placeholder="Select Department..." column_invisible="context.get('default_res_model') != 'hr.department'"/>
                                    <field name="target_document_item_id" placeholder="Select Document..."/>
                                    <field name="custom_state" widget="badge" decoration-success="custom_state == 'done'" decoration-info="custom_state == 'planned'" decoration-danger="custom_state == 'cancelled'"/>
                                    <field name="date_deadline"/>
                                    <field name="user_id"/>
                                    <button name="action_open_as_wizard" type="object" icon="fa-external-link" title="Open full wizard"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_change_order_kanban" model="ir.ui.view">
        <field name="name">change.order.kanban</field>
        <field name="model">change.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column" quick_create="false">
                <field name="stage_id" options='{"group_by_tooltip": {"description": "Stage description"}}'/>
                <field name="color"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="#{!selection_mode ? 'oe_kanban_color_' + kanban_getcolor(record.color.raw_value) : ''} oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <strong class="o_kanban_record_title">
                                        <field name="change_order_id"/>: <field name="name"/>
                                    </strong>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="project_id"/>
                                    <div class="text-muted"><field name="dollar_amount" widget="monetary"/></div>
                                    <div>Status: <field name="status"/></div> 
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="priority" widget="priority"/>
                                        <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <menuitem id="menu_change_order_root" 
              name="Change Orders" 
              sequence="30"/>
    
    <menuitem id="menu_change_order" 
              name="Change Orders" 
              parent="menu_change_order_root" 
              action="action_change_order" 
              sequence="1"/>

    <menuitem id="menu_change_order_config" 
              name="Configuration" 
              parent="menu_change_order_root" 
              sequence="100"/>

    <menuitem id="menu_change_order_status" 
              name="Statuses" 
              parent="menu_change_order_config" 
              action="action_change_order_status" 
              sequence="1"/>
    
    <menuitem id="menu_change_order_area" 
              name="Areas Responsible" 
              parent="menu_change_order_config" 
              action="action_change_order_area" 
              sequence="2"/>
    
    <menuitem id="menu_change_order_tag" 
              name="Tags" 
              parent="menu_change_order_config" 
              action="action_change_order_tag" 
              sequence="3"/>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_employee_form_inherit_growthplan_activities_tab" model="ir.ui.view">
        <field name="name">hr.employee.form.activities.tab</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

        <!-- Add a new tab inside the main notebook -->
        <xpath expr="//notebook" position="inside">
            <page string="Activities" name="activities_tab">
                    <div class="mb-2">
                        <button name="action_open_activities_bulk_edit"
                                type="object"
                                string="Open for Bulk Edit"
                                icon="fa-external-link"
                                class="btn-primary"
                                help="Open activities in a new window with checkboxes for bulk editing"/>
                    </div>
                    <field name="activity_ids"
                    context="{
                        'default_res_model': 'hr.employee',
                        'default_res_id': id,
                        'default_res_model_id': %(hr.model_hr_employee)d,
                        'active_id': id,
                        'active_model': 'hr.employee',
                        'mail_create_nosubscribe': True, 'mail_create_nolog': True
                    }">
                    <list create="1"
                        decoration-bf="activity_type_id.category == 'meeting'">
                        <header>
                            <button name="action_bulk_edit"
                                    type="object"
                                    string="Bulk Edit"
                                    icon="fa-edit"/>
                        </header>
                            <field name="res_model" column_invisible="True"/>
                            <field name="res_model_id" column_invisible="True"/>
                            <field name="activity_type_id"/>
                            <field name="summary"/>
                            <field name="target_department_id" placeholder="Select Department..." column_invisible="context.get('default_res_model') != 'hr.department'"/>
                            <field name="target_document_item_id" placeholder="Select Document..."/>
                            <field name="custom_state" widget="badge" decoration-success="custom_state == 'done'" decoration-info="custom_state == 'planned'" decoration-danger="custom_state == 'cancelled'"/>
                            <field name="date_deadline"/>
                            <field name="user_id"/>
                            <button name="action_open_as_wizard" type="object" icon="fa-external-link" title="Open full wizard"/>
                    </list>
                </field>
            </page>
        </xpath>

        </field>
    </record>

</odoo>

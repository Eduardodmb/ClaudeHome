<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="edit_project_inherit_contract_info" model="ir.ui.view">
        <field name="name">project.project.contract.info.form</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/> 
        <field name="arch" type="xml">
            
            <xpath expr="//page[@name='description']" position="after">
                <page string="Contract Info" name="contract_info">
                    <group>
                        <group string="General Information">
                            <field name="name" string="Official Contract Name"/>
                            <field name="x_customer_name" string="Customer Name"/>
                            <field name="stage_id" string="Stage"/>
                            <field name="type_name_id" string="Type"/>
                            <field name="category_id" string="Category"/>
                            <field name="sharepoint_url" string="Link to Files" widget="url"/>
                            <field name="int_kick_off" string="EST -> PROJ Handout"/>
                            <field name="x_qb_job_id"/>
                            </group>                        <group string="Financials">
                            <field name="award_amount" string="Award Amount"/>
                            <field name="x_contract_amount" string="Final Amount"/>
                            <field name="contract_po" string="Contract Number/ Purchase Order Number:"/>
                            <field name="award_date" string="Award sign date"/>
                        </group>
                    </group>

                    <group>
                        <group string="Performance &amp; Dates">
                            <field name="date_start" string="Start Date"/>
                            <field name="date" string="End Date"/>
                            <field name="duration" string="Duration (Days)" readonly="1"/>
                            <label for="date_start" string="Period of performance"/>
                            <div class="o_row">
                                <field name="date_start" nolabel="1"/>
                                <span>to:</span>
                                <field name="date" nolabel="1"/>
                            </div>
                            <field name="closure_date" string="End POP (as per contract)"/>
                        </group>
                        <group string="Location &amp; Responsibility">
                            <field name="location" string="Location of job"/>
                            <field name="pm_office_manager_id" string="PM Site"/>
                            <field name="project_engineer_id" string="Dept. ACG Multiple"/>
                            <label for="x_job_classification" string="Job classification"/>
                            <div>
                                <field name="x_job_classification" nolabel="1" placeholder="e.g. Telecom 8a AZ"/>
                                <div class="text-muted small mt-1">
                                    Note: Type (Cons / Telecom / OSP), 8a (Y/N), ACG Office that received the award (TX, NM, AZ).
                                    Example: Telecom 8a AZ
                                </div>
                            </div>
                        </group>
                    </group>

                    <group>
                        <group string="Compliance &amp; Status">
                            <field name="certified_payroll" string="Certified Payroll Y/N"/>
                            <field name="wage_det_id" string="Wage Determination ID" invisible="not certified_payroll"/>
                            <field name="x_pay_scale_file" filename="x_pay_scale_filename" widget="binary" string="Upload Pay Scale" invisible="not certified_payroll"/>
                            <field name="x_pay_scale_filename" invisible="1"/>
                            <field name="x_wage_det_selected_roles" widget="text" placeholder="Enter selected roles..." options="{'rows': 5}" invisible="not certified_payroll"/>
                            <field name="x_socio_status" string="Socio-economic status? HUB/WO/8A"/>
                            <field name="x_dpas_rating" string="DPAS Rating Y/N"/>
                            <field name="x_dpas_number" string="DPAS Number" invisible="not x_dpas_rating" required="x_dpas_rating"/>
                        </group>
                        <group string="Bonding &amp; Tax">
                            <field name="x_bonding_required" string="Bonding Y/N"/>
                            <field name="x_bonding_type" invisible="not x_bonding_required"/>
                            <field name="x_tax_exempt" string="Tax Exempt Y/N"/>
                            <field name="x_tax_exempt_file" filename="x_tax_exempt_filename" widget="binary" string="Upload Tax Exempt Form" invisible="not x_tax_exempt"/>
                            <field name="x_tax_exempt_filename" invisible="1"/>
                            <field name="x_tax_exempt_amount" string="Tax Amount" invisible="not x_tax_exempt"/>
                        </group>
                    </group>

                    <group string="Subcontractors">
                        <field name="x_subcontractor_required" string="Subcontractors Y/N"/>
                        <field name="x_subcontractor_level_contract" string="Subcontractor Level" invisible="not x_subcontractor_required"/>
                        <field name="subcontractor_line_ids" nolabel="1" invisible="not x_subcontractor_required">
                            <list editable="bottom">
                                <field name="partner_id"/>
                                <field name="trade"/>
                                <field name="amount"/>
                                <field name="status"/>
                            </list>
                        </field>
                    </group>

                    <group string="SCOPE OF WORK &amp; POINT OF CONTACT">
                        <field name="x_sow_description" string="SOW"/>
                        <field name="x_special_notes_budget" string="Comments"/>
                        <field name="x_poc_line_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="partner_id" string="Contact" context="{'show_contact_info': True}"/>
                                <field name="email" string="Email"/>
                                <field name="phone" string="Phone"/>
                                <field name="poc_type" string="Role"/>
                            </list>
                        </field>
                    </group>
                </page>
            </xpath>

        </field>
    </record>
</odoo>
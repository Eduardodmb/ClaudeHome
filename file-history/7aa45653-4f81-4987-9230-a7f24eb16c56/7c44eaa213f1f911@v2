<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_applicant_view_form_tracker" model="ir.ui.view">
        <field name="name">hr.applicant.form.tracker</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Tracker" name="tracker">

                    <!-- Basic Info Section -->
                    <group string="Basic Information">
                        <group>
                            <field name="indeed_zip_source"/>
                            <field name="ranking"/>
                            <field name="job_post_salary"/>
                        </group>
                        <group>
                            <field name="current_salary"/>
                            <field name="desired_salary"/>
                            <field name="negotiable"/>
                        </group>
                    </group>

                    <separator string="1. Phone Screen"/>
                    <group>
                        <group>
                            <field name="phone_screen_date"/>
                            <field name="phone_screen_by"/>
                            <field name="currently_working"/>
                            <field name="can_travel"/>
                        </group>
                        <group>
                            <field name="need_relocate"/>
                            <field name="desired_schedule"/>
                            <field name="migration_status"/>
                            <field name="background_check"/>
                        </group>
                    </group>

                    <group string="Experience">
                        <group>
                            <field name="experience_estimating"/>
                            <field name="experience_projects"/>
                            <field name="experience_office"/>
                            <field name="experience_field"/>
                            <field name="federal_state_experience"/>
                        </group>
                        <group>
                            <field name="years_experience"/>
                            <field name="similar_experience" placeholder="Describe similar experience..."/>
                            <field name="type_projects" placeholder="Type and size of projects..."/>
                            <field name="area_expertise" placeholder="Area of expertise and strengths..."/>
                        </group>
                    </group>

                    <group string="Software Knowledge">
                        <group>
                            <field name="software_asana"/>
                            <field name="software_autocad"/>
                            <field name="software_bluebeam"/>
                        </group>
                        <group>
                            <field name="software_procore"/>
                            <field name="software_rsmeans"/>
                        </group>
                    </group>

                    <group string="Certifications">
                        <group>
                            <field name="certifications_safety"/>
                            <field name="certifications_qa"/>
                        </group>
                        <group>
                            <field name="certifications_usace"/>
                            <field name="certifications_pm"/>
                        </group>
                    </group>

                    <group>
                        <field name="goals" placeholder="Career goals..."/>
                        <field name="reason_left_job" placeholder="Reason for leaving previous job..."/>
                    </group>

                    <group string="Interview Details">
                        <group>
                            <field name="interview_availability"/>
                            <field name="interview_type"/>
                        </group>
                    </group>

                    <separator string="Phone Call Notes"/>
                    <field name="phone_call_notes" nolabel="1"/>

                    <!-- Interview Setup Section -->
                    <separator string="2. Interview Setup"/>
                    <group>
                        <group>
                            <field name="interview_setup_by"/>
                            <field name="interview_datetime"/>
                            <field name="interviewer_id"/>
                            <field name="acg_application_form"/>
                        </group>
                        <group>
                            <field name="wpm_test_score"/>
                            <field name="excel_rating"/>
                            <field name="test_sow_rfi"/>
                            <field name="test_outlook"/>
                            <field name="test_track_activities"/>
                        </group>
                    </group>
                    <group>
                        <field name="other_tests" placeholder="Specify other tests..."/>
                    </group>

                    <!-- HR Interview Section -->
                    <separator string="3. HR Interview Questions"/>
                    <group>
                        <group>
                            <field name="hr_manage_stress" placeholder="Response..."/>
                            <field name="hr_no_instructions" placeholder="Response..."/>
                            <field name="hr_follow_up" placeholder="Response..."/>
                            <field name="hr_hours_worked" placeholder="Response..."/>
                            <field name="hr_saturdays"/>
                            <field name="hr_make_things_happen" placeholder="Response..."/>
                        </group>
                        <group>
                            <field name="hr_learn_new_programs" placeholder="Response..."/>
                            <field name="hr_arrive_on_time"/>
                            <field name="hr_reliable_transport"/>
                            <field name="hr_organize_day" placeholder="Response..."/>
                            <field name="hr_track_activities" placeholder="Response..."/>
                        </group>
                    </group>

                    <!-- Recommendations -->
                    <separator string="Recommendations"/>
                    <group>
                        <field name="ana_recommendation" nolabel="1" placeholder="Ana's recommendation..."/>
                    </group>
                    <group>
                        <field name="hr_recommendation" nolabel="1" placeholder="HR recommendation for candidate position..."/>
                    </group>

                    <!-- Supervisor Interview Section -->
                    <separator string="4. Supervisor Interview"/>
                    <group>
                        <group>
                            <field name="supervisor_interview_date"/>
                        </group>
                        <group>
                            <field name="supervisor_interview_by"/>
                        </group>
                    </group>

                    <group string="4.1 Estimating Activities">
                        <group>
                            <field name="est_reading_contract"/>
                            <field name="est_understand_sow"/>
                            <field name="est_create_bom"/>
                            <field name="est_takeoff_tools"/>
                            <field name="est_find_subcontractors"/>
                            <field name="est_subcontractor_pricing"/>
                            <field name="est_trade_codes"/>
                        </group>
                        <group>
                            <field name="est_bonding"/>
                            <field name="est_submit_proposal"/>
                            <field name="est_write_sow"/>
                            <field name="est_winning_rate"/>
                            <field name="est_timeframe"/>
                            <field name="est_multiple_proposals"/>
                        </group>
                    </group>

                    <group string="4.2 Office Documentation / Project Management">
                        <group>
                            <field name="doc_daily_reports"/>
                            <field name="doc_closing_day"/>
                            <field name="doc_submittals"/>
                            <field name="doc_meeting_minutes"/>
                            <field name="doc_adobe_editing"/>
                            <field name="doc_reading_contract"/>
                            <field name="doc_process_development"/>
                        </group>
                        <group>
                            <field name="doc_procedures"/>
                            <field name="doc_templates"/>
                            <field name="doc_safety_docs"/>
                            <field name="doc_em385"/>
                            <field name="doc_safety_toolbox"/>
                            <field name="doc_permits"/>
                        </group>
                    </group>

                    <group string="4.3 Telecom Trades Experience">
                        <group>
                            <field name="telecom_fiber_types"/>
                            <field name="telecom_splicing"/>
                            <field name="telecom_fiber_testers"/>
                            <field name="telecom_underground"/>
                            <field name="telecom_handholes"/>
                            <field name="telecom_aerial"/>
                        </group>
                        <group>
                            <field name="telecom_access_control"/>
                            <field name="telecom_audio_video"/>
                            <field name="telecom_cat6"/>
                            <field name="telecom_cat6_diff"/>
                            <field name="telecom_tools" placeholder="List tools..."/>
                        </group>
                    </group>

                    <group string="4.4 IT Experience">
                        <group>
                            <field name="it_cybersecurity"/>
                            <field name="it_servers"/>
                            <field name="it_programming"/>
                            <field name="it_languages" placeholder="Programming languages..." invisible="it_programming != 'yes'"/>
                            <field name="it_networking"/>
                        </group>
                        <group>
                            <field name="it_switches"/>
                            <field name="it_ms_accounts"/>
                            <field name="it_ms_teams"/>
                            <field name="it_scrum"/>
                        </group>
                    </group>

                    <group string="4.5 Other Office Experience">
                        <group>
                            <field name="office_accounting"/>
                            <field name="office_ga_oh_profit"/>
                            <field name="office_purchasing"/>
                            <field name="office_sales"/>
                        </group>
                        <group>
                            <field name="office_business_dev"/>
                            <field name="office_scheduling"/>
                            <field name="office_recruiting"/>
                        </group>
                    </group>

                    <separator string="Supervisor Recommendation"/>
                    <field name="supervisor_recommendation" nolabel="1" placeholder="Supervisor's recommendation..."/>

                    <!-- Final Documentation Section -->
                    <separator string="5. Final Documentation"/>
                    <group>
                        <field name="final_outcome" nolabel="1" placeholder="Final outcome from interviewer..."/>
                    </group>

                    <group>
                        <group>
                            <field name="platform_updated"/>
                            <field name="asana_updated"/>
                        </group>
                        <group>
                            <field name="final_decision"/>
                        </group>
                    </group>

                    <separator string="Open Items"/>
                    <field name="open_items" nolabel="1" placeholder="List open items..."/>

                </page>
            </xpath>
        </field>
    </record>
</odoo>

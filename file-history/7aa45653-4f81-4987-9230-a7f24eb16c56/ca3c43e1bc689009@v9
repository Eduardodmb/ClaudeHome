<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Activities tab to HR Applicant -->
    <record id="hr_applicant_view_form_activities" model="ir.ui.view">
        <field name="name">hr.applicant.form.activities</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Activities" name="recruitment_activities">
                    <field name="activity_ids" context="{
                        'default_res_model': 'hr.applicant',
                        'default_res_id': id,
                        'active_id': id,
                        'active_model': 'hr.applicant',
                        'default_custom_state': 'planned'
                    }">
                        <list decoration-bf="activity_type_id.category == 'meeting'">
                            <field name="res_model" column_invisible="True"/>
                            <field name="res_model_id" column_invisible="True"/>
                            <field name="activity_type_id"/>
                            <field name="summary"/>
                            <field name="target_department_id" placeholder="Select Department..." column_invisible="context.get('default_res_model') != 'hr.department'"/>
                            <field name="target_document_item_id" placeholder="Select Document..."/>
                            <field name="custom_state" widget="badge" decoration-success="custom_state == 'done'" decoration-info="custom_state == 'planned'" decoration-danger="custom_state == 'cancelled'"/>
                            <field name="date_deadline"/>
                            <field name="user_id"/>
                        </list>
                        <form>
                            <sheet>
                                <group>
                                    <group>
                                        <field name="activity_type_id"/>
                                        <field name="summary"/>
                                        <field name="date_deadline"/>
                                        <field name="user_id"/>
                                    </group>
                                    <group>
                                        <field name="custom_state"/>
                                        <field name="target_department_id"/>
                                        <field name="target_document_item_id"/>
                                    </group>
                                </group>
                                <group>
                                    <field name="note" placeholder="Activity notes..."/>
                                </group>
                            </sheet>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

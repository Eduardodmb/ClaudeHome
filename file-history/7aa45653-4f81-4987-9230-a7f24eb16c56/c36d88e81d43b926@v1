<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_form_incident_tab" model="ir.ui.view">
        <field name="name">project.project.form.incident.tab</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='settings']" position="after">
                <page name="incidents" string="Incident Reports">
                    <field name="incident_ids" nolabel="1">
                        <list editable="top" create="1" delete="1" decoration-danger="state == 'closed'">
                            <button name="action_view_incident" type="object" icon="fa-arrow-right" title="View incident" class="btn-link"/>
                            <field name="name"/>
                            <field name="incident_type_id"/>
                            <field name="project_id" column_invisible="1"/>
                            <field name="employee_id"/>
                            <field name="department_id"/>
                            <field name="amount" widget="monetary"/>
                            <field name="currency_id" column_invisible="1"/>
                            <field name="state" widget="badge" decoration-success="state == 'open'" decoration-danger="state == 'closed'"/>
                            <field name="create_uid" widget="many2one_avatar_user" optional="hide"/>
                            <field name="create_date" widget="datetime" optional="hide"/>
                            <field name="description" optional="hide"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

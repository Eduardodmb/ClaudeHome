<?xml version="1.0" encoding="utf-8"?>
<odoo>

     <record id="view_hr_employee_growth_plan_form_activites" model="ir.ui.view">
        <field name="name">hr.employee.growth.plan.form.activities</field>
        <field name="model">hr.employee.growth.plan</field>
        <field name="inherit_id" ref="hr_employee_growth.view_hr_employee_growth_plan_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook/page[1]" position="replace">
                <page string="Activities" name="activities_table_tab">
                    <field name="activity_ids" 
                        context="{
                            'default_res_model': 'hr.employee.growth.plan',
                            'default_res_model_id': %(hr_employee_growth.model_hr_employee_growth_plan)d,
                            'default_res_id': id,
                            'active_id': id,
                            'active_model': 'hr.employee.growth.plan'
                        }">
                        <list editable="bottom" decoration-bf="activity_type_id.category == 'meeting'">
                            <field name="res_model" column_invisible="True"/>
                            <field name="res_model_id" column_invisible="True"/>
                            <field name="activity_type_id"/>
                            <field name="summary"/>
                            <field name="target_department_id" placeholder="Select Department..." column_invisible="context.get('default_res_model') != 'hr.department'"/>
                            <field name="target_document_item_id" placeholder="Select Document..."/>
                            <field name="custom_state" widget="badge" decoration-success="custom_state == 'done'" decoration-info="custom_state == 'planned'" decoration-danger="custom_state == 'cancelled'"/>
                            <field name="date_deadline"/>
                            <field name="user_id"/>
                            <button name="%(action_open_activity_wizard)d" type="action" icon="fa-external-link" title="Open full wizard"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>

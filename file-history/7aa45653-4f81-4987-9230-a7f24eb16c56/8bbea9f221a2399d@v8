<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_department_project_form_activities" model="ir.ui.view">
        <field name="name">hr.department.project.form.activities</field>
        <field name="model">hr.department.project</field>
        <field name="inherit_id" ref="employees_department_custom_fields.hr_department_project_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Activities" name="activities_table_tab">
                    <field name="activity_ids" context="{'default_res_model':'hr.department.project',
                    'default_res_id':id,
                    'active_id':id,
                    'active_model':'hr.department.project',
                    'from_department_project':True}">
                        <list decoration-bf="activity_type_id.category == 'meeting'">
                            <field name="res_model" column_invisible="True"/>
                            <field name="res_model_id" column_invisible="True"/>
                            <field name="activity_type_id"/>
                            <field name="summary"/>
                            <field name="target_department_id" placeholder="Select Department..." column_invisible="context.get('default_res_model') != 'hr.department'"/>
                            <field name="target_document_item_id" placeholder="Select Document..."/>
                            <field name="custom_state" widget="badge" decoration-success="custom_state == 'done'" decoration-info="custom_state == 'planned'" decoration-danger="custom_state == 'cancelled'"/>
                            <field name="date_deadline"/>
                            <field name="user_id"/>
                        </list>
                        <form>
                            <sheet>
                                <group>
                                    <group>
                                        <field name="activity_type_id"/>
                                        <field name="summary"/>
                                        <field name="date_deadline"/>
                                        <field name="user_id"/>
                                    </group>
                                    <group>
                                        <field name="custom_state"/>
                                        <field name="target_department_id"/>
                                        <field name="target_document_item_id"/>
                                    </group>
                                </group>
                                <group>
                                    <field name="note" placeholder="Activity notes..."/>
                                </group>
                            </sheet>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
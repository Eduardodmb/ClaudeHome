<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- CAPA tab on project form: list CAPA for this project (no Project column) -->
    <record id="view_project_form_capa_tab" model="ir.ui.view">
        <field name="name">project.project.form.capa.tab</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='settings']" position="after">
                <page name="capa" string="CAPA">
                    <button name="action_capa_new" type="object" string="New CAPA" class="btn-secondary" icon="fa-plus"/>
                    <field name="capa_ids" nolabel="1">
                        <list editable="top" create="1" delete="1" default_order="capa_date desc">
                            <button name="action_view_capa" type="object" icon="fa-arrow-right" title="Open CAPA" class="btn-link"/>
                            <field name="capa_title"/>
                            <field name="capa_user_id" widget="many2one_avatar_user"/>
                            <field name="capa_date"/>
                            <field name="create_uid" string="Recorded by (system)" widget="many2one_avatar_user" optional="hide"/>
                            <field name="create_date" string="Recorded on" widget="date" optional="hide"/>
                            <field name="completion_date" widget="date" optional="hide"/>
                            <field name="state" widget="badge"
                                   decoration-muted="state == 'draft'"
                                   decoration-warning="state == 'open'"
                                   decoration-info="state == 'in_progress'"
                                   decoration-success="state == 'closed'"/>
                            <field name="cause_reason" optional="hide"/>
                            <field name="area_responsible"/>
                            <field name="root_cause"/>
                            <field name="amount"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

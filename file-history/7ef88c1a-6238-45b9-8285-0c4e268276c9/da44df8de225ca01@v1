    def _compute_next_duedate(self):
        today = fields.Date.context_today(self)
        for lead in self:
            candidates = []
            if (
                lead.submission_date
                and not lead.submission_done
                and not lead.submission_na
            ):
                candidates.append(lead.submission_date)
            if lead.next_visit and not lead.visit_done and not lead.visit_na:
                candidates.append(lead.next_visit)
            if lead.qa_date and not lead.qa_done and not lead.qa_na:
                candidates.append(lead.qa_date)
            upcoming = []
            for dt in candidates:
                line_day = fields.Datetime.context_timestamp(lead, dt).date()
                if line_day >= today:
                    upcoming.append(dt)
            lead.next_duedate = min(upcoming) if upcoming else False


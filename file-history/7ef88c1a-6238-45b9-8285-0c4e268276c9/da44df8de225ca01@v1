    )
    def _crm_check_milestone_na_vs_done(self):
        for lead in self:
            if lead.submission_done and lead.submission_na:
                raise ValidationError(_("Submission cannot be both done and N/A."))
            if lead.visit_done and lead.visit_na:
                raise ValidationError(_("Site visit cannot be both done and N/A."))
            if lead.qa_done and lead.qa_na:
                raise ValidationError(_("Q&A cannot be both done and N/A."))

    def _crm_apply_milestone_write_vals(self, vals):
        """Keep N/A vs done mutually exclusive; stamp completed by/on when checked."""
        triples = (
            ("submission_done", "submission_na", "submission_done_at", "submission_done_by"),
            ("visit_done", "visit_na", "visit_done_at", "visit_done_by"),
            ("qa_done", "qa_na", "qa_done_at", "qa_done_by"),
        )
        for done_f, na_f, at_f, by_f in triples:
            if vals.get(na_f):
                vals[done_f] = False
                vals[at_f] = False
                vals[by_f] = False
            if done_f in vals:
                if vals[done_f]:
                    vals[na_f] = False
                    if at_f not in vals:
                        vals[at_f] = fields.Datetime.now()
                    if by_f not in vals:
                        vals[by_f] = self.env.user.id
                else:
                    vals[at_f] = False
                    vals[by_f] = False
        return vals

    def _crm_post_milestone_chatter(self, before_by_id):
        chatter_specs = (
            (_("Submission Date"), "submission_done", "submission_na", "submission_done_at", "submission_done_by"),
            (_("Site Visit"), "visit_done", "visit_na", "visit_done_at", "visit_done_by"),
            (_("Q&A Date"), "qa_done", "qa_na", "qa_done_at", "qa_done_by"),
        )
        for lead in self:
            old = before_by_id.get(lead.id)
            if not old:
                continue
            for label, done_f, na_f, at_f, by_f in chatter_specs:
                od, nd = old[done_f], lead[done_f]
                oa, na_ = old[na_f], lead[na_f]
                if od == nd and oa == na_:
                    continue
                if na_ and not oa:
                    lead.message_post(
                        body=_("%s: marked as N/A.") % label,
                        message_type="notification",
                    )
                    continue
                if oa and not na_:
                    lead.message_post(
                        body=_("%s: N/A cleared.") % label,
                        message_type="notification",
                    )
                if nd and not od:
                    who = lead[by_f].name if lead[by_f] else _("Unknown")
                    when = (
                        format_datetime(self.env, lead[at_f], tz=self.env.user.tz, dt_format="short")
                        if lead[at_f]
                        else ""
                    )
                    lead.message_post(
                        body=_("%s: marked complete by %s at %s.") % (label, who, when),
                        message_type="notification",
                    )
                elif od and not nd and not oa and not na_:
                    lead.message_post(
                        body=_("%s: completion cleared.") % label,
                        message_type="notification",
                    )

    def write(self, vals):
        # Post-proposal lock (must run here: this write() is the MRO entry point and
        # would otherwise skip stage.py's write() when calling super() to crm.lead).
        if not self.env.context.get("skip_crm_post_proposal_lock"):
            if "x_allow_post_proposal_editing" in vals and not self.env.user.has_group(
                "crm_custom_fields.group_crm_post_proposal_unlock"
            ):
                raise AccessError(
                    _(
                        "Only users in the group “CRM: Allow editing after proposal sent” "
                        "can change “Allow editing after proposal sent”."
                    )
                )
            for lead in self:
                violation = lead._crm_post_proposal_locked_field_violation(vals)
                if violation:
                    raise AccessError(
                        _(
                            "This opportunity is locked because the proposal has been sent. "
                            "Saving is blocked for fields: %s. "
                            "Someone in the group “CRM: Allow editing after proposal sent” must first enable "
                            "“Allow editing after proposal sent” on this record (that save may contain only that checkbox); "
                            "after that, editing other fields is allowed again."
                        )
                        % ", ".join(sorted(violation))
                    )
        vals = self._crm_apply_milestone_write_vals(dict(vals))
        before_by_id = {}
        milestone_snap = (
            "submission_done",
            "submission_na",
            "visit_done",
            "visit_na",
            "qa_done",
            "qa_na",
            "submission_done_at",
            "visit_done_at",
            "qa_done_at",
        )
        if not self.env.context.get("skip_crm_milestone_chatter"):
            for lead in self:
                before_by_id[lead.id] = {f: lead[f] for f in milestone_snap}
        # Trigger only if 'is_business_development' is being checked (True)
        if vals.get("is_business_development"):
            for record in self:
                record._send_bd_notification_via_graph()
        res = super(CrmLead, self).write(vals)
        if before_by_id:
            self._crm_post_milestone_chatter(before_by_id)
        return res

    def _send_bd_notification_via_graph(self):
        client = GraphClient(self.env)
        icp = self.env["ir.config_parameter"].sudo()
        raw_recipients = icp.get_param(BD_NOTIFICATION_ICP_RECIPIENTS)
        parsed = _parse_bd_notification_recipient_emails(raw_recipients)
        recipient_addresses = list(parsed) if parsed else list(BD_NOTIFICATION_DEFAULT_RECIPIENTS)
        if not recipient_addresses:
            _logger.warning(
                "BD notification skipped for lead id=%s: no recipient addresses after parse and fallback.",
                self.id,
            )
            return

        mailbox_upn = (icp.get_param(BD_NOTIFICATION_ICP_MAILBOX) or "").strip()
        if not mailbox_upn:
            mailbox_upn = (client.mail_acg or "").strip()
        if not mailbox_upn:
            _logger.warning(
                "BD notification skipped for lead id=%s: no Graph mailbox UPN (config and default empty).",
                self.id,
            )
            return

        base_url = icp.get_param("web.base.url")
        record_url = f"{base_url}/web#id={self.id}&model=crm.lead&view_type=form"
        odoo_purple = "#714B67"
        odoo_teal = "#017E84"
        background_light = "#F8F9FA"

        html_content = f"""
            <div style="background-color: {background_light}; padding: 20px; border: 2px solid {odoo_purple}; border-radius: 8px; font-family: 'Lucid Grande', Helvetica, Verdana, Arial, sans-serif;">
                <h2 style="color: {odoo_purple}; margin-top: 0;">Business Development Alert</h2>
                <p style="font-size: 14px; color: #333;">The <strong>Business Development</strong> status has been activated for the following opportunity:</p>

                <div style="margin: 15px 0; padding: 10px; border-left: 4px solid {odoo_teal}; background: #ffffff;">
                    <p style="margin: 5px 0;"><strong>Opportunity:</strong> {self.name}</p>
                    <p style="margin: 5px 0;"><strong>Customer:</strong> {self.partner_id.name or 'New Lead'}</p>
                    <p style="margin: 5px 0;"><strong>Expected Revenue:</strong> {self.expected_revenue or 0.0}</p>
                </div>

                <p style="margin-top: 25px;">
                    <a href="{record_url}"
                    style="background-color: {odoo_purple}; padding: 10px 18px; text-decoration: none; color: white; border-radius: 4px; font-weight: bold; display: inline-block;">
                    View Opportunity
                    </a>
                </p>
                <p style="font-size: 11px; color: #999; margin-top: 20px;">
                    This is an automated notification sent via Microsoft Graph Integration.
                </p>
            </div>
            """
        to_recipients = [{"emailAddress": {"address": addr}} for addr in recipient_addresses]
        payload = {
            "message": {
                "subject": f"BD Opportunity Alert: {self.name}",
                "body": {
                    "contentType": "HTML",
                    "content": html_content,
                },
                "toRecipients": to_recipients,
            },
            "saveToSentItems": "true",
        }
        endpoint = f"/users/{mailbox_upn}/sendMail"
        client.call_api("POST", endpoint, payload=payload)


    @api.model
    @api.model
    def _default_lead_seq(self):
        year_digit = datetime.now().year % 10
        # This looks for leads starting with the year digit followed by digits only
        existing = self.search([
            ('lead_seq', '=like', f'{year_digit}___') # Finds '6001', '6002', etc.
        ], order='lead_seq desc', limit=1)

        last_counter = 0
        if existing and existing.lead_seq:
            try:
                # strip the year digit and convert
                last_counter = int(existing.lead_seq[1:])
            except (ValueError, TypeError):
                # find the most recent valid numeric one or start at 0
                last_numeric = self.search([
                    ('lead_seq', '=like', f'{year_digit}%')
                ], order='id desc') # Search by ID as a fallback for sequence
                
                for rec in last_numeric:
                    try:
                        last_counter = int(rec.lead_seq[1:])
                        break # Stop at the first valid number found
                    except:
                        continue

        return f"{year_digit}{str(last_counter + 1).zfill(3)}"
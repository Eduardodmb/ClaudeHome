<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree view for Estimating Pipeline (Stages 0 to 4.1) -->
    <record id="crm_lead_estimating_pipeline_tree" model="ir.ui.view">
        <field name="name">crm.lead.estimating.pipeline.tree</field>
        <field name="model">crm.lead</field>
        <field name="arch" type="xml">
            <list default_order="stage_id, next_duedate"
                  decoration-danger="x_has_dates_this_week">
                <field name="name" string="Opportunity"/>
                <field name="x_division_display" string="Division"/>
                <field name="next_duedate" string="Next Due Date"/>
                <field name="next_visit" string="Site Visit"/>
                <field name="qa_date" string="Q&amp;A Date"/>
                <field name="submission_date" string="Submission Date"/>
                <field name="bonding_id" string="Bonding"/>
                <field name="lead_source_custom_id" string="Lead Source"/>
                <field name="user_id" string="Salesperson"/>
                <field name="stage_id" string="Stage"/>
                <field name="x_has_dates_this_week" invisible="1"/>
                <field name="x_division_bom_ids" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Action for Estimating Pipeline -->
    <record id="action_crm_lead_estimating_pipeline" model="ir.actions.act_window">
        <field name="name">Estimating Pipeline</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="view_id" ref="crm_lead_estimating_pipeline_tree"/>
        <field name="domain">[('stage_id.name', '&gt;=', '0'), ('stage_id.name', '&lt;=', '4.1'), ('type', '=', 'opportunity')]</field>
        <field name="context">{'group_by': 'stage_id'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No opportunities in estimating pipeline yet.
            </p>
            <p>Opportunities in stages 0 to 4.1 appear here.</p>
        </field>
    </record>

    <!-- Menu item for Estimating Pipeline -->
    <menuitem
        id="menu_crm_lead_estimating_pipeline"
        name="Estimating Pipeline"
        parent="crm.crm_menu_sales"
        action="action_crm_lead_estimating_pipeline"
        sequence="5"/>
</odoo>

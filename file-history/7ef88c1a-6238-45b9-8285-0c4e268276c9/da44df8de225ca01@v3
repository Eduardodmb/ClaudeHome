    @api.depends('submission_date', 'next_visit', 'qa_date')
    def _compute_next_duedate(self):
        for lead in self:
            # Collect all dates that are actually set
            dates = []
            if lead.submission_date:
                dates.append(lead.submission_date)
            if lead.next_visit:
                dates.append(lead.next_visit)
            if lead.qa_date:
                dates.append(lead.qa_date)
            
            # Find the minimum (earliest) date from the list
            if dates:
                lead.next_duedate = min(dates)
            else:
                lead.next_duedate = False


        private void btn_SaveTolerance_Click(object sender, RoutedEventArgs e)
        {
            if (txb_Tolerance.Text != "")
            {
                int value = Convert.ToInt32(txb_Tolerance.Text);

                if (value >= 0 && value <= 800)
                {
                    PLCFoundation.Properties.Settings.Default.EncoderTolerance = value;
                    PLCFoundation.Properties.Settings.Default.Save();
                    C_Globals.Encoder_SetTolerance = true;

                }
            }
        }


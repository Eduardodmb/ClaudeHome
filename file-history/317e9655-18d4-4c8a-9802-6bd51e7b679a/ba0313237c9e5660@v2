        private void Dg_PartNumbers_SelectionChanged_1(object sender, System.Windows.Controls.SelectionChangedEventArgs e)
        {
            if (dg_PartNumbers.SelectedIndex != -1)
            {
                C_Globals.SelectedPartNumber = (C_Fill_PartNumber)dg_PartNumbers.SelectedItem;
            }
            else
            {
                C_Globals.SelectedPartNumber = null;
            }
        }

        private void Dg_PartNumbers_KeyDown_1(object sender, KeyEventArgs e)
        {
            if (e.Key == Key.Delete || e.Key == Key.Back)
            {
                for (int i = 0; i < C_Globals.PartNumbers.Count; i++)
                {
                    if (C_Globals.PartNumbers[i].PartNumber == C_Globals.SelectedPartNumber.PartNumber && C_Globals.PartNumbers[i].Model == C_Globals.SelectedPartNumber.Model)
                    {
                        C_Globals.PartNumbers.RemoveAt(i);
                        break;
                    }
                }
                C_Globals.PartNumbers.Save();
                C_Globals.PartNumbers.Fill();
                dg_PartNumbers.ItemsSource = null;
                dg_PartNumbers.ItemsSource = C_Globals.PartNumbers;
                C_Globals.SelectedPartNumber = null;
            }
        }


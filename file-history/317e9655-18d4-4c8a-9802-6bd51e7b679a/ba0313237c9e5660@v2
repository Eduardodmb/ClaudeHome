        public W_Engineering()
        {
            InitializeComponent();

            if (C_Globals.InterfaceType == "MODBUS")
            {
                tab_EPS.Visibility = Visibility.Visible;
                tab_Encoder.Visibility = Visibility.Visible;
                tab_Encoder.Visibility = Visibility.Visible;
                tab_Manual.Visibility = Visibility.Visible;

                tab_Manual.IsSelected = true;
                tab_Manual.Visibility = Visibility.Hidden;
                tab_ManualPLC.Visibility = Visibility.Collapsed;


                this.DataContext = C_Globals.MainData;
                C_Globals.MODBUS_Data.R_Engineering = true;
                C_Globals.WaitNmiliseconds(1000);
                C_Communication_Modbus_2_Communication.ModbusClient.WriteRegisters(0, 1, new int[] { C_Globals.ConvertWordToInt(C_Globals.MODBUS_Data.Replies_W1()) });

                if ((int)C_Globals.CurrentAccess >= 2)
                {
                    SetPartNumbers();
                    SetEPS();
                }
            }


            if (C_Globals.InterfaceType == "PLC_TCP")
            {
                tab_EPS.Visibility = Visibility.Hidden;
                tab_Encoder.Visibility = Visibility.Hidden;
                tab_Encoder.Visibility = Visibility.Hidden;
                tab_Manual.Visibility = Visibility.Hidden;

                tab_ManualPLC.IsSelected = true;
                tab_ManualPLC.Visibility = Visibility.Visible;
                tab_Manual.Visibility = Visibility.Collapsed;

            }
        }

        public void SetPartNumbers()
        {
            dg_PartNumbers.ItemsSource = null;
            dg_PartNumbers.ItemsSource = C_Globals.PartNumbers;

            if (PLCFoundation.Properties.Settings.Default.OnlyBaseModel == true)
            {
                check_AllModels.IsChecked = false;
            }
            else if (PLCFoundation.Properties.Settings.Default.OnlyBaseModel == false)
            {
                check_AllModels.IsChecked = true;
            }

        }

        public void SetEPS()
        {
            txb_epsInicial1.Text = PLCFoundation.Properties.Settings.Default.EPS1_Initial;
            txb_epsFinal1.Text = PLCFoundation.Properties.Settings.Default.EPS1_Final;

            check_EPS.IsChecked = PLCFoundation.Properties.Settings.Default.EPS_Status;
        }

        private void Window_Closing(object sender, System.ComponentModel.CancelEventArgs e)
        {
            if (C_Globals.InterfaceType == "MODBUS")
            {
                C_Globals.WaitNmiliseconds(1000);
                C_Communication_Modbus_2_Communication.ModbusClient.WriteRegisters(4, 1, new int[] { C_Globals.ConvertWordToInt(C_Globals.MODBUS_Data.ManualMode_W5()) });
                C_Globals.MODBUS_Data.R_Engineering = false;
                C_Globals.WaitNmiliseconds(1000);
                C_Communication_Modbus_2_Communication.ModbusClient.WriteRegisters(0, 1, new int[] { C_Globals.ConvertWordToInt(C_Globals.MODBUS_Data.Replies_W1()) });
            }

            if (C_Globals.InterfaceType == "PLC_TCP")
            {



            }
        }

        private void txb_Nombre_PreviewTextInput(object sender, TextCompositionEventArgs e)
        {
            Regex regex = new Regex("[^0-9]");
            e.Handled = regex.IsMatch(e.Text);
            if (txb_NP.Text.Length >= 4)
            {
                e.Handled = true;
            }
        }

        private void btn_Save_Click(object sender, RoutedEventArgs e)
        {
            if (txb_NP.Text.Length == 4)
            {
                bool exists = false;
                foreach (var item in C_Globals.PartNumbers)
                {
                    if (item.PartNumber == txb_NP.Text)
                    {
                        exists = true;
                    }
                }
                if (!exists)
                {
                    C_Globals.PartNumbers.Add(new C_Fill_PartNumber(txb_NP.Text, "1"));
                    C_Globals.PartNumbers.Save();
                    C_Globals.PartNumbers.Fill();
                    dg_PartNumbers.ItemsSource = null;
                    dg_PartNumbers.ItemsSource = C_Globals.PartNumbers;
                    txb_NP.Text = "";
                    //cb_Chamber.SelectedIndex = -1;
                }
                else
                {
                    txb_NP.Text = "";
                    //cb_Chamber.SelectedIndex = -1;
                    MessageBox.Show("Número de parte ya existe");
                }

            }

        }


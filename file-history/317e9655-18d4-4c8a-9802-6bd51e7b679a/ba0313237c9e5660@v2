        private void btn_SaveEPS_Click(object sender, RoutedEventArgs e)
        {
            if (txb_epsInicial1.Text.Length == 1 && txb_epsFinal1.Text.Length == 1)
            {
                PLCFoundation.Properties.Settings.Default.EPS1_Initial = txb_epsInicial1.Text;


                PLCFoundation.Properties.Settings.Default.EPS1_Final = txb_epsFinal1.Text;


                PLCFoundation.Properties.Settings.Default.EPS_Status = (bool)check_EPS.IsChecked;

                PLCFoundation.Properties.Settings.Default.Save();
            }
            else
            {
                MessageBox.Show("Llene todos los espacios antes de guardar");
            }
        }


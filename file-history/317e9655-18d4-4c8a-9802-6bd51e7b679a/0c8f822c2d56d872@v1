        // 4.0 Initialize Serials

        public static void InitializeSerialPorts()
        {
            if (InterfaceType == "PLC_TCP")
            {
                Scanner = new C_Class_Serial(SerialPort_Options.COM21, SerialPort_Type.Scanner);
                Scanner.CycleScan += Scanner_CycleScan;
                Scanner.QualityReleaseScan += Scanner_QualityReleaseScan;
                Scanner.OpenPort();

                if (DebugDatabase == false)
                {
                    EPS = new C_Class_Serial(SerialPort_Options.COM02, SerialPort_Type.EPS);  //Electronic Positioning System
                    EPS.OpenPort();
                }
            }

            if (InterfaceType == "MODBUS")
            {
                EPS = new C_Class_Serial(SerialPort_Options.COM02, SerialPort_Type.EPS);  //Electronic Positioning System
                Desoutter = new C_Class_Serial(SerialPort_Options.COM04, SerialPort_Type.Desoutter);
                //Printer = new C_Serial(SerialPort_Options.COM09, SerialPort_Type.Printer);//7

                Scanner.QualityReleaseScan += Scanner_QualityReleaseScan;
                Desoutter.DesoutterDataIncoming += Desoutter_DesoutterDataIncoming;

                EPS.OpenPort();
                Desoutter.OpenPort();
                //Printer.OpenPort();
            }

            if (DebugScanner == false)
            {
                Scanner.Start();
            }
            if (DebugDesoutter == false && InterfaceType == "MODBUS")
            {
                Desoutter.Start();
            }

        }

        #region "Desoutter"

        private static void Desoutter_DesoutterDataIncoming(object sender, ScannerArgs e)
        {
            if (e.ReadData.Length >= 69)
            {
                string tqvalue = e.ReadData.Substring(34, 6);
                string dgvalue = e.ReadData.Substring(42, 6);
                string resulvalue = e.ReadData.Substring(66, 3).StartsWith("A") ? "OK" : "NOOK";


                if (C_Globals.MODBUS_Data.ApplyingTorque1)
                {
                    SN1Result.T1 = tqvalue + "Nm";
                    SN1Result.A1 = dgvalue + "deg";
                    SN1Result.R1 = resulvalue;

                    if (resulvalue == "OK")
                    {
                        ResultReceived = true;
                    }

                }
            }
        }

        #endregion

        #region "Scanner"

        private static void Scanner_QualityReleaseScan(object sender, ScannerArgs e)
        {
            C_Fill_Users ListOfUsers = new C_Fill_Users();
            ListOfUsers.FillCollection();

            if (ListOfUsers.Contains(e.ReadData))
            {
                if (ListOfUsers.Item(e.ReadData).Access == C_Globals.AccessMode.Calidad || ListOfUsers.Item(e.ReadData).Access == C_Globals.AccessMode.Divisional)
                {
                    if (CurrentStatus == MachineStatus.ReleaseStation)
                    {
                        QualityWindow1.UserID = e.ReadData;
                        QualityWindow1.Message = "Usuario Aceptado";
                        C_Communication_PLC_2_Communication.PlcClient.WriteWord("DM18.U", 1); //Notify Read
                        QualityWindow1.CloseWindow();
                        StationReleased = true;
                        WaitNmiliseconds(600);
                    }
                }
                else
                {
                    if (CurrentStatus == MachineStatus.ReleaseStation)
                    {
                        QualityWindow1.UserID = e.ReadData;
                        QualityWindow1.Message = "Usuario NO Aceptado";
                        QualityWindow1.Message = "";
                    }
                }
            }
            else
            {
                if (CurrentStatus == MachineStatus.ReleaseStation)
                {
                    QualityWindow1.UserID = e.ReadData;
                    QualityWindow1.Message = "Usuario NO Aceptado";
                    QualityWindow1.Message = "";
                }
            }
        }

        private static void Scanner_CycleScan(object sender, ScannerArgs e)
        {
            if (CurrentStatus == MachineStatus.ReadZcode)
            {
                if (e.ReadData.Length >= 3)
                {
                    string tempCode = e.ReadData.Trim();
                    ZCODE = tempCode;
                    ZCodeOK = true;
                    ZCodeResult = new C_Excel_Result_Desoutter(ZCODE);
                    return;
                }

                ShowCycleMessage(1000);
            }

            if (CurrentStatus == MachineStatus.ReadTcode)
            {
                if (e.ReadData.Length >= 3)
                {
                    string tempCode = e.ReadData.Trim();
                    TCODE = tempCode;
                    TCodeOK = true;
                    ZCodeResult = new C_Excel_Result_Desoutter(ZCODE + "|" + TCODE);
                    return;
                }

                ShowCycleMessage(1000);
            }
        }


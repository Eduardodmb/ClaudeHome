        // 1.0 MainInitialization: Start of the program!

        public static void MainInitialization()
        {
            Splash.Show(); // It is just a splash windows, no action required.

            // Get Debug variables.
            C_Settings_DebugFolder.Initialize();

            // Get PLC variables.
            PLC = C_Settings_PLCFolder.InitializeAndLoad(); 

            // Prelaod Images 
            InitializeImages();
            // Preload Collections
            InitializeCollections();
            // Preload for support (Scanner, Printer, Dessouters)
            InitializeSerialPorts(); 

            // 1.1 Initialize la communicatoin
            if (InterfaceType == "MODBUS")
            {
                C_Communication_Modbus_2_Communication.InitializePLCcommunication();
            }

            if(InterfaceType == "PLC_TCP")
            {
                C_Communication_PLC_2_Communication.InitializePLCcommunication();
            }

            CurrentAccess = AccessMode.Manufactura;
            CurrentStatus = MachineStatus.ApplicationStarted;

            if (InterfaceType == "MODBUS")
            {
                C_Communication_Modbus_2_Communication.StartWorkers(true);
            }

            if (InterfaceType == "PLC_TCP")
            {
                C_Communication_PLC_2_Communication.StartWorkers(true);
            }

            MainW.Show();
            Splash.Close();
        }


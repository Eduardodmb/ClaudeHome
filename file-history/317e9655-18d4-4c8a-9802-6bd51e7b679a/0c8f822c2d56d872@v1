        public static int ConvertWordToInt(bool[] word)
        {
            int res = 0;
            for (int i = 0; i < 16; i++)
            {
                if (word[i] == true)
                    res += ((int)Math.Pow(2, i));
            }
            return res;
        }

        public static void WaitNmiliseconds(int miliseconds)
        {
            DateTime _desired = DateTime.Now.AddMilliseconds(miliseconds);
            while (DateTime.Now < _desired)
            {
                Thread.Sleep(1);
                System.Windows.Forms.Application.DoEvents();
            }
        }

        public static void ShowCycleMessage(int MsgIndex)
        {
            if (MainW != null && !C_Globals.showingfail)
            {

                switch (MsgIndex)
                {

                    case 5: //Ciclo Aceptado
                        C_Globals.MainData.Message = Messages.Item(MsgIndex);
                        C_Globals.MainData.MessageBackground = Brushes.LightGreen;
                        //C_Globals.WaitNmiliseconds(1500);
                        break;

                    case 500://Rechazado
                        C_Globals.MainData.Message = Messages.Item(MsgIndex);
                        C_Globals.MainData.MessageBackground = Brushes.Red;
                        break;
                    case 1000:
                        C_Globals.showingfail = true;
                        C_Globals.MainData.Message = "Este número de parte no esta dado de alta";
                        C_Globals.MainData.MessageBackground = Brushes.Red;
                        C_Globals.WaitNmiliseconds(1500);
                        C_Globals.showingfail = false;
                        break;

                    default:
                        C_Globals.MainData.Message = Messages.Item(MsgIndex);
                        C_Globals.MainData.MessageBackground = Brushes.LightGray;
                        break;
                }

            }
        }

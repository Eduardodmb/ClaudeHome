        #region "Main Cycle"
        public static void MainCycleRoutine()
        {
            switch (InterfaceType)
            {
                case "PLC_TCP":
                    try
                    {


                        /*
                        =========================================================
                         MACHINE STATUS SEQUENCE FLOW (SUMMARY)
                        =========================================================
                         STEP | STATUS NAME              | MAIN ACTION
                        ---------------------------------------------------------
                          1   | ApplicationStarted      | Delay → Go to CleanForNewCycle
                          2   | CleanForNewCycle        | Clear variables, reset PLC outputs,
                                                        | load EPS status, retries, tolerances
                                                        | → Go to Ready
                        ---------------------------------------------------------
                          3   | Ready                   | System idle, waiting for new cycle
                        ---------------------------------------------------------
                          4   | ResetCycle              | Send Reset to PLC → CleanForNewCycle
                        ---------------------------------------------------------
                          5   | NewCycle                | Acknowledge new cycle from PLC
                        ---------------------------------------------------------
                          8   | ReadZcode               | Read Part Number (PN)
                                                        | Send Scanner OK to PLC
                                                        | Select Job 1 & Job 2
                        ---------------------------------------------------------
                         10   | InCycle                 | Wait for torque result
                                                        | Acknowledge torque received to PLC
                        ---------------------------------------------------------
                         12   | CycleOK                 | Save result, export XML
                                                        | Acknowledge OK to PLC
                                                        | → CleanForNewCycle
                        ---------------------------------------------------------
                         13   | CycleRejected           | Save rejected result (XML)
                        ---------------------------------------------------------
                         14   | ReleaseStation          | Open Quality window
                                                        | Release station in PLC
                                                        | → CleanForNewCycle
                        ---------------------------------------------------------
                         15   | EndCycle                | Force transition to CleanForNewCycle
                        =========================================================
                        */


                        switch (CurrentStatus)
                        {
                            case MachineStatus.ApplicationStarted:
                                ShowCycleMessage(911);
                                WaitNmiliseconds(500);

                                CurrentStatus = MachineStatus.CleanForNewCycle;
                                break;

                            case MachineStatus.CleanForNewCycle: // CLEAR VARIABLES AND PLC
                                ShowCycleMessage(912);
                                ShowFaultMessage(0);

                                PLC_TCP_Data.ClearOutputs();
                                MainData.PN = "";
                                ZCODE = "";
                                TCODE = "";
                                StationReleased = false;
                                ResultReceived = false;
                                ZCodeOK = false;
                                TCodeOK = false;  
                                CurrentPartNumber = null;
                                scannertypeInit = 0;
                                ResultSaved = false;
                                EPSFinalSent = false;
                                EPSInitialSent = false;

                                /*PLCDATA*/

                                CurrentStatus = MachineStatus.Ready;


                                //SET MODE AUTOMATICO
                                C_Communication_PLC_2_Communication.PlcClient.WriteWord("DM12.U", 1);

                                break;

                            case MachineStatus.Ready: // WAIT FOR SCAN CODE

                                ShowCycleMessage(913);

                                CurrentStatus = MachineStatus.EPS_Initial;
                                break;    

                            case MachineStatus.EPS_Initial:


                                if (DebugDatabase == true)
                                {
                                    CurrentStatus = MachineStatus.NewCycle;
                                }
                                else
                                {
                                    if (!EPSInitialSent)
                                    {
                                        EPSInitialSent = true;
                                        EPS.WriteToPort(1);
                                    }

                                    if (!PLCFoundation.Properties.Settings.Default.EPS_Status)
                                    {
                                        CurrentStatus = MachineStatus.NewCycle;
                                    }
                                }

                                WaitNmiliseconds(500);

                                break;

                            case MachineStatus.NewCycle:
                                ShowCycleMessage(915);
                                ResultSaved = false;

                                //PLC WRITE - 1 to start cycle
                                C_Communication_PLC_2_Communication.PlcClient.WriteWord("DM11.U", 1);  
                                WaitNmiliseconds(500);
                                CurrentStatus = MachineStatus.InCycle;
                                WaitNmiliseconds(500);

                                break;

                            case MachineStatus.ResetCycle: // SEND MESSAGE TO PLC AND START PLC CYCLE
                                ShowCycleMessage(916);
                                ResultSaved = false;

                                //PLC WRITE - 1 to start cycle
                                C_Communication_PLC_2_Communication.PlcClient.WriteWord("DM11.U", 1);
                                WaitNmiliseconds(500);
                                CurrentStatus = MachineStatus.CleanForNewCycle;
                                WaitNmiliseconds(500);

                                break;                            

                            case MachineStatus.InCycle:
                                ShowCycleMessage(917);

                                if (ResultReceived)
                                {
                                    ResultReceived = false;

                                }

                                break;

                            case MachineStatus.ReadZcode:
                                ShowCycleMessage(914);

                                if (DebugScanner == true)
                                {
                                    WaitNmiliseconds(1200);
                                    string tempCode = "TESTING" + DateTime.Now.ToString("ddMMyyyHHmmss");
                                    ZCODE = tempCode;
                                    ZCodeOK = true;
                                    //ZCodeResult = new C_Excel_Result_Desoutter(ZCODE);
                                }


                                if (ZCodeOK)
                                {

                                    C_Communication_PLC_2_Communication.PlcClient.WriteWord("DM17.U", 1); //Notify Read
                                    ResultReceived = false;
                                    //ShowCycleMessage(916);
                                    CurrentStatus = MachineStatus.InCycle;
                                    WaitNmiliseconds(500);

                                }
                                break;

                            case MachineStatus.ReadTcode:
                                MainData.PN = "";
                                ShowCycleMessage(922);

                                if (DebugScanner == true)
                                {
                                    WaitNmiliseconds(1200);
                                    string tempCode = "TESTING" + DateTime.Now.ToString("ddMMyyyHHmmss");
                                    TCODE = tempCode;
                                    TCodeOK = true;
                                    ZCodeResult = new C_Excel_Result_Desoutter(ZCODE + "-" + TCODE);
                                }


                                if (TCodeOK)
                                {
                                    C_Communication_PLC_2_Communication.PlcClient.WriteWord("DM17.U", 2); //Notify Read
                                    //ShowCycleMessage(916);
                                    CurrentStatus = MachineStatus.InCycle;
                                    WaitNmiliseconds(500);
                                }
                                break;

                            case MachineStatus.CycleOK:
                                ShowCycleMessage(918);
                                //contar ciclo
                                if (!ResultSaved)
                                {
                                    ResultSaved = true;
                                    ZCodeResult.R1 = "OK";
                                    ZCodeResult.ToXML();
                                    //PrintLabel();
                                    MainData.PN = ZCODE + " UNIDAD BUENA ";
                                }
                               
                                CurrentStatus = MachineStatus.EndCycle;
                                WaitNmiliseconds(500);
                                break;

                            case MachineStatus.CycleRejected:
                                ShowFaultMessage(919);
                                //contar ciclo Malo
                                if (!ResultSaved)
                                {
                                    ResultSaved = true;
                                    ZCodeResult.R1 = "NOOK";
                                    ZCodeResult.ToXML();
                                    MainData.PN = ZCODE + " UNIDAD MALA ";

                                }
                                CurrentStatus = MachineStatus.ReleaseStation;
                                WaitNmiliseconds(500);
                                break;

                            case MachineStatus.EndCycle:
                                ShowCycleMessage(920);

                                CurrentStatus = MachineStatus.EPS_Final;
                                WaitNmiliseconds(1500);
                                break;

                            case MachineStatus.EPS_Final:

                                if (DebugDatabase == true)
                                {

                                }
                                else
                                {
                                    if (!EPSFinalSent)
                                    {
                                        EPS.WriteToPort(2);
                                        EPSFinalSent = true;

                                    }
                                }

                                CurrentStatus = MachineStatus.CleanForNewCycle;

                                WaitNmiliseconds(500);
                                break;

                            case MachineStatus.ReleaseStation:
                                ShowCycleMessage(921);
                                if (!StationReleased)
                                {
                                    QualityWindow1 = new W_ReleaseStation(1);
                                    QualityWindow1.ShowDialog();
                                }
                               
                                C_Globals.scannertypeInit = 0;
                                C_Globals.CurrentStatus = C_Globals.MachineStatus.CleanForNewCycle;
                                break;
                                
                            case MachineStatus.Engineering:

                                bool[] DM5 = new bool[16];
                                DM5.Populate(false);

                                //SET MODE MANUAL
                                C_Communication_PLC_2_Communication.PlcClient.WriteWord("DM12.U", 2);
                                WaitNmiliseconds(500);

                                DM5[3] = Manual_ClampFrontalIzqExt; DM5[2] = !Manual_ClampFrontalIzqExt;
                                DM5[11] = Manual_ClampTraseroIzqExt; DM5[10] = !Manual_ClampTraseroIzqExt;
                                DM5[9] = Manual_ClampFrontalDerExt; DM5[8] = !Manual_ClampFrontalDerExt;
                                DM5[5] = Manual_ClampTraseroDerExt; DM5[4] = !Manual_ClampTraseroDerExt;
                                DM5[15] = !Manual_SlideDerExt;
                                DM5[14] = Manual_CortinaExt; DM5[13] = !Manual_CortinaExt;
                                //DM5[2] = Manual_SlideIzqExt;

                                //WRITE VALUES TO PLC 
                                C_Communication_PLC_2_Communication.PlcClient.WriteWord("DM5.U", C_Communication_PLC_2_Communication.PlcClient.Array16ToWord(DM5));

                                WaitNmiliseconds(500);

                                break;
                        }
                    }
                    catch (Exception)
                    {


                    }
                    break;
                case "MODBUS":
                    try
                    {


                        /*
                        =========================================================
                         MACHINE STATUS SEQUENCE FLOW (SUMMARY)
                        =========================================================
                         STEP | STATUS NAME              | MAIN ACTION
                        ---------------------------------------------------------
                          1   | ApplicationStarted      | Delay → Go to CleanForNewCycle
                          2   | CleanForNewCycle        | Clear variables, reset PLC outputs,
                                                      | load EPS status, retries, tolerances
                                                      | → Go to Ready
                        ---------------------------------------------------------
                          3   | Ready                   | System idle, waiting for new cycle
                        ---------------------------------------------------------
                          4   | ResetCycle              | Send Reset to PLC → CleanForNewCycle
                        ---------------------------------------------------------
                          5   | NewCycle                | Acknowledge new cycle from PLC
                        ---------------------------------------------------------
                          8   | ReadZcode               | Read Part Number (PN)
                                                      | Send Scanner OK to PLC
                                                      | Select Job 1 & Job 2
                        ---------------------------------------------------------
                          9   | EPS_Initial             | Send Initial EPS trigger
                                                      | If EPS disabled → Go to InCycle
                        ---------------------------------------------------------
                         10   | InCycle                 | Wait for torque result
                                                      | Acknowledge torque received to PLC
                        ---------------------------------------------------------
                         11   | EPS_Final               | Send Final EPS trigger to PLC
                        ---------------------------------------------------------
                         12   | CycleOK                 | Save result, export XML
                                                      | Acknowledge OK to PLC
                                                      | → CleanForNewCycle
                        ---------------------------------------------------------
                         13   | CycleRejected           | Save rejected result (XML)
                        ---------------------------------------------------------
                         14   | ReleaseStation          | Open Quality window
                                                      | Release station in PLC
                                                      | → CleanForNewCycle
                        ---------------------------------------------------------
                         15   | EndCycle                | Force transition to CleanForNewCycle
                        =========================================================
                        */


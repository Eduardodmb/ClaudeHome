            <TabItem x:Name="tab_ManualPLC" HorizontalAlignment="Center" Height="19" Header="Manual PLC" VerticalAlignment="Top" Width="83" Margin="0,-1,0,0">
                <Grid Background="#FFE5E5E5">
                    <Grid.Resources>
                        <Style x:Key="LatchButtonStyle" TargetType="ToggleButton">
                            <Setter Property="Width" Value="130"/>
                            <Setter Property="Height" Value="50"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontFamily" Value="Century Gothic"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid>
                                            <!-- Main body with gradient -->
                                            <Border x:Name="outerBorder"
                                                    CornerRadius="22"
                                                    BorderThickness="2"
                                                    BorderBrush="#FF1A1A1A">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#FF6A6A6A" Offset="0"/>
                                                        <GradientStop Color="#FF303030" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <!-- Gloss highlight on upper half -->
                                            <Border x:Name="gloss"
                                                    CornerRadius="22,22,6,6"
                                                    Margin="3,3,3,0"
                                                    Height="22"
                                                    VerticalAlignment="Top">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#55FFFFFF" Offset="0"/>
                                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <!-- ON / Latched -->
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="outerBorder" Property="BorderBrush" Value="#FF005500"/>
                                                <Setter TargetName="outerBorder" Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#FF33EE33" Offset="0"/>
                                                            <GradientStop Color="#FF008800" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <!-- Hover -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="outerBorder" Property="BorderBrush" Value="#FFCCCCCC"/>
                                            </Trigger>
                                            <!-- Pressed — invert gradient to feel "pushed in" -->
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="outerBorder" Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#FF252525" Offset="0"/>
                                                            <GradientStop Color="#FF585858" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter TargetName="gloss" Property="Opacity" Value="0.3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Grid.Resources>
                    <ToggleButton x:Name="tb_izq_frontal" Content="Izquierdo Frontal" Style="{StaticResource LatchButtonStyle}" HorizontalAlignment="Left" Margin="15,30,0,0"  VerticalAlignment="Top" Click="tb_izq_frontal_Click"/>

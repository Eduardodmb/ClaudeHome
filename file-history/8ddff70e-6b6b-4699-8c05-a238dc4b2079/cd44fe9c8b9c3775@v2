<?php

namespace Database\Seeders;

use App\Models\User;
use Illuminate\Database\Seeder;
use Illuminate\Support\Facades\Hash;

class AdminUserSeeder extends Seeder
{
    public function run(): void
    {
        // Super-admin: no customer_id — sees all data across all customers
        $admin = User::firstOrCreate(
            ['email' => 'admin@cmmcunlock.com'],
            [
                'customer_id' => null,
                'first_name'  => 'Super',
                'last_name'   => 'Admin',
                'password'    => Hash::make('Admin@CMMCUnlock2026!'),
                'is_active'   => true,
            ]
        );
        $admin->syncRoles(['super_admin']);

        // Demo customer for the assessor demo user
        $demoCustomer = \App\Models\Customer::firstOrCreate(
            ['slug' => 'demo'],
            [
                'name'          => 'Demo Organization',
                'contact_name'  => 'Demo Contact',
                'contact_email' => 'demo@example.com',
                'status'        => 'trial',
                'plan'          => 'professional',
            ]
        );

        $assessor = User::firstOrCreate(
            ['email' => 'assessor@cmmcunlock.com'],
            [
                'customer_id' => $demoCustomer->id,
                'first_name'  => 'Demo',
                'last_name'   => 'Assessor',
                'password'    => Hash::make('Assessor@CMMCUnlock2026!'),
                'is_active'   => true,
            ]
        );
        $assessor->syncRoles(['assessor']);
    }
}

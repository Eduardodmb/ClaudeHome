<?php

namespace App\Models;

use App\Traits\BelongsToCustomer;
use Illuminate\Database\Eloquent\Model;
use Illuminate\Database\Eloquent\SoftDeletes;
use Spatie\Activitylog\Traits\LogsActivity;
use Spatie\Activitylog\LogOptions;

class Task extends Model
{
    use BelongsToCustomer, SoftDeletes, LogsActivity;

    protected $fillable = [
        'customer_id', 'framework_id', 'framework_app_id', 'subcontrol_id',
        'subject', 'action_items', 'assigned_to', 'owned_by',
        'due_date', 'create_alert', 'status', 'priority',
        'tags', 'recurrence_rule', 'notes', 'include_in_poam',
    ];

    protected $casts = [
        'due_date'        => 'date',
        'create_alert'    => 'boolean',
        'include_in_poam' => 'boolean',
        'tags'            => 'array',
    ];

    public function getActivitylogOptions(): LogOptions
    {
        return LogOptions::defaults()->logOnly(['subject', 'status', 'assigned_to'])->logOnlyDirty();
    }

    public function framework()    { return $this->belongsTo(Framework::class); }
    public function frameworkApp() { return $this->belongsTo(FrameworkApp::class); }
    public function subcontrol()   { return $this->belongsTo(Subcontrol::class); }
    public function assignee()     { return $this->belongsTo(User::class, 'assigned_to'); }
    public function owner()        { return $this->belongsTo(User::class, 'owned_by'); }

    public function comments()
    {
        return $this->hasMany(TaskComment::class);
    }

    public function documents()
    {
        return $this->belongsToMany(Document::class, 'task_documents');
    }
}

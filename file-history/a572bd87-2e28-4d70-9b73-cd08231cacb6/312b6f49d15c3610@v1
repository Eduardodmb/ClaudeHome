    def _get_graph_meeting_payload(self, is_online, location_display, email_subject, all_attendees, online_provider=None):
        """Build the JSON payload for Graph API event create/update (subject, start/end UTC, attendees, body)."""
        self.ensure_one()
        start_utc = self._convert_to_utc(self.start_datetime)
        end_utc = self._convert_to_utc(self.end_datetime)
        
        # Format as ISO 8601 with Z suffix for UTC
        start_time_iso = start_utc.strftime('%Y-%m-%dT%H:%M:%S.000Z')
        end_time_iso = end_utc.strftime('%Y-%m-%dT%H:%M:%S.000Z')
        
        meeting_payload = {
            'subject': email_subject,
            'start': {
                'dateTime': start_time_iso,
                'timeZone': 'UTC',
            },
            'end': {
                'dateTime': end_time_iso,
                'timeZone': 'UTC',
            },
            'attendees': all_attendees, 
            'isOnlineMeeting': is_online, 
            'location': {
                'displayName': location_display
            },
            'body': {
                'contentType': 'HTML',
                'content': f"<p>You are invited to an interview for the {self.position_text} position. A follow-up email contains the detailed instructions and attachments.</p>",
            },
        }

        if is_online and online_provider:
            meeting_payload['onlineMeetingProvider'] = online_provider
            
        return meeting_payload

    def action_send_invite(self):
        """Create calendar event in Graph (user or group calendar), then send candidate and internal emails."""
        self.ensure_one()
        
        if self.status != 'draft':
            raise UserError(self.env._("The invite must be in 'Draft' status to be sent."))
        candidate_email_clean = (self.candidate_email or '').strip()
        if not candidate_email_clean:
            raise UserError(self.env._("The candidate must have an email address to send the invitation."))
        
        candidate_body_html, _, email_subject = self._get_email_templates()
        candidate_attendee = {
            'emailAddress': {'address': candidate_email_clean, 'name': self.candidate_id.name},
            'type': 'required'
        }
        internal_attendees = [{
            'emailAddress': {'address': att.work_email.strip(), 'name': att.name},
            'type': 'required'
        } for att in self.acg_attendees_ids if att.work_email]
        # recruiting@acglp.com (or recruitment.recruiting_email) is always included as attendee
        recruiting_email = self._get_recruiting_email()
        internal_attendees.append({
            'emailAddress': {'address': recruiting_email, 'name': 'Recruitment Team'},
            'type': 'optional'
        })
        group_email = self._get_recruitment_group_email()
        use_delegated_group = self._use_delegated_group_calendar()
        if group_email and not use_delegated_group:
            internal_attendees.append({
                'emailAddress': {'address': group_email.strip(), 'name': 'Recruitment Calendar (Group)'},
                'type': 'required'
            })
            _logger.info("Adding HR group as attendee (user calendar): %s", group_email)
        all_attendees = [candidate_attendee] + internal_attendees

        if self.meeting_type == 'Teams':
            is_online = True
            location_display = 'Microsoft Teams'
            online_provider = 'teamsForBusiness'
        elif self.meeting_type == 'In Person':
            is_online = False
            location_display = self.MEETING_LOCATION_IN_PERSON
            online_provider = None
        else:
            is_online = False
            location_display = self.meeting_type
            online_provider = None

        teams_link = None
        # Graph API: create event (either on group calendar with delegated token or on user calendar app-only).
        client = self._get_graph_client()
        if use_delegated_group:
            group_id = self._get_recruitment_group_id().strip()
            calendar_endpoint = f"/groups/{group_id}/calendar/events"
            meeting_payload = self._get_graph_meeting_payload(is_online, location_display, email_subject, all_attendees, online_provider)
            _logger.info("Creating event on HR group calendar (delegated): %s", calendar_endpoint)
            try:
                api_response = client.call_api('POST', calendar_endpoint, meeting_payload, use_delegated=True)
                graph_event_id = api_response.get('id')
                if graph_event_id:
                    self.write({
                        'microsoft_graph_event_id': graph_event_id,
                        'microsoft_graph_calendar_type': 'group',
                        'microsoft_graph_group_id': group_id,
                    })
                    _logger.info("Saved MS Graph Event ID (group calendar): %s", graph_event_id)
                if is_online:
                    teams_link = api_response.get('onlineMeeting', {}).get('joinUrl')
                    if teams_link:
                        self.write({'microsoft_graph_meeting_join_url': teams_link})
                self.message_post(
                    body=self.env._("Calendar event created on HR group calendar (delegated). Meeting Type: %(type)s. Link: %(link)s")
                    % {"type": self.meeting_type, "link": teams_link if is_online else "N/A"},
                    subtype_xmlid="mail.mt_note",
                )
            except UserError:
                raise
            except Exception as e:
                _logger.error("Group calendar create failed: %s", e)
                raise UserError(self.env._("Failed to create event on HR group calendar. Check delegated user and app Group.ReadWrite.All (Delegated). Error: %(error)s") % {"error": e})
        else:
            user_id = client.mail_acg
            self._ensure_calendar_shared_with_hr(client, user_id)
            calendar_endpoint = self.CALENDAR_EVENT_ENDPOINT.format(user_id=user_id)
            meeting_payload = self._get_graph_meeting_payload(is_online, location_display, email_subject, all_attendees, online_provider)
            _logger.info("Creating calendar event on user calendar (app-only)")
            try:
                api_response = client.call_api('POST', calendar_endpoint, meeting_payload)
                graph_event_id = api_response.get('id')
                if graph_event_id:
                    self.write({'microsoft_graph_event_id': graph_event_id})
                    _logger.info(f"Saved MS Graph Event ID: {graph_event_id}")
                if is_online:
                    teams_link = api_response.get('onlineMeeting', {}).get('joinUrl')
                    if teams_link:
                        self.write({'microsoft_graph_meeting_join_url': teams_link})
                if is_online and not teams_link:
                    raise UserError(
                        self.env._("Teams meeting URL not found in API response. The event may have been created without an online meeting link.")
                    )
                self.message_post(
                    body=self.env._("Calendar event created successfully. Meeting Type: %(type)s. Link: %(link)s")
                    % {"type": self.meeting_type, "link": teams_link if teams_link else "N/A"},
                    subtype_xmlid="mail.mt_note",
                )
                if group_email:
                    self.message_post(body=self.env._("Event added to HR group calendar (6.0 HR invited). View in Outlook or in Teams: Calendar > add '6.0 HR' calendar."), subtype_xmlid='mail.mt_note')
            except UserError:
                raise
            except Exception as e:
                _logger.error(f"365 Calendar API Error: {e}")
                raise UserError(self.env._("Failed to create calendar event. Error: %(error)s") % {"error": e})

        # Graph sendMail: mailbox may differ from calendar organizer (mail_sender vs mail_acg on GraphClient).
        client = self._get_graph_client()
        mail_sender = client.mail_sender
        send_mail_endpoint = self.SEND_MAIL_ENDPOINT.format(user_id=mail_sender)

        if teams_link:
            candidate_email_content = candidate_body_html.replace(
                "TEAMS Link", 
                f"<a href='{teams_link}'>Join Microsoft Teams Meeting</a>"
            )
        else:
            candidate_email_content = candidate_body_html

        attachments_list = []
        
        if self.include_sow_rfi_test:
            try:
                file_name, file_content_b64 = self._read_local_file_data(self.FILE_SOW_RFI)
                attachments_list.append({
                    '@odata.type': '#microsoft.graph.fileAttachment',
                    'name': file_name,
                    'contentType': 'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
                    'contentBytes': file_content_b64
                })
                self.message_post(body=self.env._("Prepared attachment: %(name)s") % {"name": file_name}, subtype_xmlid="mail.mt_note")
            except UserError as e:
                self.message_post(body=self.env._("WARNING: SOW/RFI file preparation failed. Error: %(error)s") % {"error": e}, subtype_xmlid="mail.mt_note")
        
        if self.include_excel_test:
            try:
                file_name, file_content_b64 = self._read_local_file_data(self.FILE_EXCEL_TEST)
                attachments_list.append({
                    '@odata.type': '#microsoft.graph.fileAttachment',
                    'name': file_name,
                    'contentType': 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
                    'contentBytes': file_content_b64
                })
                self.message_post(body=self.env._("Prepared attachment: %(name)s") % {"name": file_name}, subtype_xmlid="mail.mt_note")
            except UserError as e:
                self.message_post(body=self.env._("WARNING: Excel file preparation failed. Error: %(error)s") % {"error": e}, subtype_xmlid="mail.mt_note")

        if self.include_employment_application:
            try:
                file_name, file_content_b64 = self._read_local_file_data(self.FILE_EMPLOYMENT_APP)
                attachments_list.append({
                    '@odata.type': '#microsoft.graph.fileAttachment',
                    'name': file_name,
                    'contentType': 'application/pdf',
                    'contentBytes': file_content_b64
                })
                self.message_post(body=self.env._("Prepared attachment: %(name)s") % {"name": file_name}, subtype_xmlid="mail.mt_note")
            except UserError as e:
                self.message_post(body=self.env._("WARNING: Application file preparation failed. Error: %(error)s") % {"error": e}, subtype_xmlid="mail.mt_note")
        
        if self.candidate_cv and self.candidate_cv_filename:
            try:
                cv_content_b64 = self.candidate_cv
                if isinstance(cv_content_b64, bytes):
                    cv_content_b64 = cv_content_b64.decode('utf-8')
                
                cv_mime_type = 'application/octet-stream'
                filename_lower = self.candidate_cv_filename.lower()
                if filename_lower.endswith('.pdf'):
                    cv_mime_type = 'application/pdf'
                elif filename_lower.endswith('.docx'):
                    cv_mime_type = 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
                elif filename_lower.endswith('.doc'):
                    cv_mime_type = 'application/msword'
                elif filename_lower.endswith('.txt'):
                    cv_mime_type = 'text/plain'

                attachments_list.append({
                    '@odata.type': '#microsoft.graph.fileAttachment',
                    'name': self.candidate_cv_filename,
                    'contentType': cv_mime_type,
                    'contentBytes': cv_content_b64
                })
                self.message_post(body=self.env._("Prepared attachment: %(name)s (Candidate CV)") % {"name": self.candidate_cv_filename}, subtype_xmlid="mail.mt_note")
            
            except Exception as e:
                _logger.error(f"Error processing Candidate CV for attachment: {e}")
                self.message_post(body=self.env._("WARNING: Candidate CV file processing failed. Error: %(error)s") % {"error": e}, subtype_xmlid="mail.mt_note")

        recruiting_email = self._get_recruiting_email()
        email_payload = {
            'message': {
                'subject': email_subject,
                'body': {
                    'contentType': 'HTML',
                    'content': candidate_email_content,
                },
                'from': {'emailAddress': {'address': mail_sender, 'name': self._get_mail_from_display_name()}},
                'toRecipients': [{'emailAddress': {'address': candidate_email_clean}}],
                'ccRecipients': [{'emailAddress': att['emailAddress']} for att in internal_attendees],
                'attachments': attachments_list,
            },
            'saveToSentItems': True
        }
        
        try:
            client.call_api('POST', send_mail_endpoint, email_payload)
            self.message_post(body=self.env._("Invitation email sent to %(email)s (CC: Internal Attendees) with attachments.") % {"email": candidate_email_clean}, subtype_xmlid="mail.mt_comment")

        except UserError:
            raise
        except Exception as e:
            _logger.error(f"365 Email API Error: {e}")
            raise UserError(self.env._("Failed to send invitation email. Error: %(error)s") % {"error": e})
            
        self.write({'status': 'sent'})

        return True

    @api.model_create_multi
    def create(self, vals_list):
        """Trigger next_interview_date recompute on applicant when interview is created."""
        records = super().create(vals_list)
        applicants = records.mapped('applicant_id').filtered(lambda a: a)
        if applicants:
            applicants._compute_next_interview_date()
        return records

    def write(self, vals):
        """On save: if sync_fields changed and invite has a Graph event, push update to Graph (no resend)."""
        if self.env.context.get('skip_graph_sync'):
            return super().write(vals)

        # Only trigger sync when a field that affects the calendar event was changed
        # We also only sync if the event was already created in MS Graph
        sync_fields = ['start_datetime', 'duration', 'meeting_type', 'position_text', 'candidate_id', 'acg_attendees_ids']
        needs_sync = any(field in vals for field in sync_fields)

        res = super(RecruitmentInterviewInvite, self).write(vals)

        if needs_sync:
            for record in self:
                if record.microsoft_graph_event_id and record.status not in ['draft', 'cancelled']:
                    try:
                        record._sync_update_to_graph()
                    except Exception as e:
                        _logger.error(f"Failed to sync update to Graph API for record {record.id}: {e}")
                        record.message_post(body=record.env._("Failed to sync update to MS Graph Calendar. Error: %(error)s") % {"error": e}, subtype_xmlid="mail.mt_note")

        # Trigger next_interview_date recompute on applicant when interview is updated
        if any(field in vals for field in ['start_datetime', 'status', 'applicant_id']):
            applicants = self.mapped('applicant_id').filtered(lambda a: a)
            if applicants:
                applicants._compute_next_interview_date()

        return res

    def unlink(self):
        """Before delete: cancel/delete the event in Graph if it exists, then remove the record."""
        # Store applicants before deletion to recompute next_interview_date
        applicants = self.mapped('applicant_id').filtered(lambda a: a)

        for record in self:
            if record.microsoft_graph_event_id or record.microsoft_graph_online_meeting_id:
                try:
                    record._sync_delete_to_graph()
                except Exception as e:
                    _logger.error(f"Failed to delete event/meeting from Graph API for record {record.id}: {e}")

        res = super().unlink()

        # Trigger next_interview_date recompute after deletion
        if applicants:
            applicants._compute_next_interview_date()

        return res

    def _sync_update_to_graph(self):
        """PATCH the existing Graph event with current start, end, subject, location, and attendees (no new email)."""
        self.ensure_one()
        if not self.microsoft_graph_event_id:
            return

        client = self._get_graph_client()
        if self.microsoft_graph_calendar_type == 'group' and self.microsoft_graph_group_id:
            calendar_endpoint = f"/groups/{self.microsoft_graph_group_id}/events/{self.microsoft_graph_event_id}"
            use_delegated = True
        else:
            user_id = client.mail_acg
            calendar_endpoint = f"/users/{user_id}/events/{self.microsoft_graph_event_id}"
            use_delegated = False
        _, _, email_subject = self._get_email_templates()
        candidate_email_clean = self.candidate_email.strip() if self.candidate_email else ""
        candidate_attendee = {'emailAddress': {'address': candidate_email_clean, 'name': self.candidate_id.name}, 'type': 'required'}
        internal_attendees = [{'emailAddress': {'address': att.work_email.strip(), 'name': att.name}, 'type': 'required'} for att in self.acg_attendees_ids if att.work_email]
        # recruiting@acglp.com (or recruitment.recruiting_email) is always included
        recruiting_email = self._get_recruiting_email()
        internal_attendees.append({'emailAddress': {'address': recruiting_email, 'name': 'Recruitment Team'}, 'type': 'optional'})
        group_email = self._get_recruitment_group_email()
        if group_email:
            internal_attendees.append({'emailAddress': {'address': group_email.strip(), 'name': 'Recruitment Calendar (Group)'}, 'type': 'optional'})
        all_attendees = [candidate_attendee] + internal_attendees
        if self.meeting_type == 'Teams':
            is_online, location_display, online_provider = True, 'Microsoft Teams', 'teamsForBusiness'
        elif self.meeting_type == 'In Person':
            is_online, location_display, online_provider = False, self.MEETING_LOCATION_IN_PERSON, None
        else:
            is_online, location_display, online_provider = False, self.meeting_type, None
        meeting_payload = self._get_graph_meeting_payload(is_online, location_display, email_subject, all_attendees, online_provider)
        _logger.info(f"Syncing UPDATE to Graph API. Endpoint: {calendar_endpoint}")
        client.call_api('PATCH', calendar_endpoint, meeting_payload, use_delegated=use_delegated)
        self.message_post(body=self.env._("Successfully synced updates to Microsoft Graph Calendar."), subtype_xmlid='mail.mt_note')

    def _sync_delete_to_graph(self):
        """Delete the calendar event in Graph (user or group endpoint); clear Graph IDs on the record."""
        self.ensure_one()
        if not self.microsoft_graph_event_id:
            return

        client = self._get_graph_client()
        if self.microsoft_graph_calendar_type == 'group' and self.microsoft_graph_group_id:
            calendar_endpoint = f"/groups/{self.microsoft_graph_group_id}/events/{self.microsoft_graph_event_id}"
            use_delegated = True
        else:
            user_id = client.mail_acg
            calendar_endpoint = f"/users/{user_id}/events/{self.microsoft_graph_event_id}"
            use_delegated = False
        _logger.info(f"Syncing DELETE to Graph API. Endpoint: {calendar_endpoint}")
        try:
            client.call_api('DELETE', calendar_endpoint, use_delegated=use_delegated)
        except Exception as e:
            _logger.warning(f"Could not delete calendar event from Graph: {e}")

        self.write({
            'microsoft_graph_event_id': False,
            'microsoft_graph_online_meeting_id': False,
            'microsoft_graph_meeting_join_url': False,
            'microsoft_graph_calendar_type': 'user',
            'microsoft_graph_group_id': False,
        })

    def _acg_attendee_ids_from_graph_event(self, event):
        """
        Build acg_attendees_ids from Graph event attendees (Teams → Odoo sync).
        Excludes candidate, recruiting email, and group calendar email; maps remaining to hr.employee by work_email.
        Returns None if event has no 'attendees' key (no change); else {'acg_attendees_ids': [(6, 0, ids)]}.
        """
        if 'attendees' not in event:
            return None
        attendees = event.get('attendees') or []
        exclude = set()
        if self.candidate_email:
            exclude.add((self.candidate_email or '').strip().lower())
        recruiting = (self._get_recruiting_email() or '').strip().lower()
        if recruiting:
            exclude.add(recruiting)
        group_email = (self._get_recruitment_group_email() or '').strip().lower()
        if group_email:
            exclude.add(group_email)
        employee_ids = []
        for att in attendees:
            addr = (att.get('emailAddress') or {}).get('address')
            if not addr or not isinstance(addr, str):
                continue
            addr = addr.strip().lower()
            if addr in exclude:
                continue
            emp = self.env['hr.employee'].sudo().search([('work_email', 'ilike', addr)], limit=1)
            if emp:
                employee_ids.append(emp.id)
        return {'acg_attendees_ids': [(6, 0, employee_ids)]}

    def action_sync_calendar(self):
        """Run Graph delta sync now (user + group calendar) and show a notification."""
        self.env['recruitment.interview.invite']._cron_sync_graph_events()
        return {
            'type': 'ir.actions.client',
            'tag': 'display_notification',
            'params': {
                'title': 'Calendar synced',
                'message': 'Sync with Microsoft Graph completed.',
                'type': 'success',
                'sticky': False,
            },
        }

    def action_update_calendar(self):
        """Push current start/duration/attendees to the existing Teams/Outlook event (no resend). Use after changing time on a sent invite."""
        self.ensure_one()
        if self.status in ('draft', 'cancelled'):
            raise UserError(self.env._("Only sent or confirmed invites can be updated. Save your changes first."))
        if not self.microsoft_graph_event_id:
            raise UserError(self.env._("No calendar event linked. Send the invite first."))
        self._sync_update_to_graph()
        return {
            'type': 'ir.actions.client',
            'tag': 'display_notification',
            'params': {
                'title': 'Calendar updated',
                'message': 'The Teams/Outlook event was updated with the new time and attendees.',
                'type': 'success',
                'sticky': False,
            },
        }

    @api.model
    def _cron_sync_graph_events(self):
        """
        Pull changes from MS Graph into Odoo. Runs two deltas when configured:
        1) User calendar delta (app token): reschedule/cancel/attendees for organizer's events.
        2) Group calendar delta (delegated): same for HR group calendar. Handles 410 Gone by
           clearing the stored delta link so the next run restarts from scratch.
        """
        ICPSudo = self.env['ir.config_parameter'].sudo()
        delta_link = ICPSudo.get_param('recruitment.graph_delta_link')
        
        client = self._get_graph_client()
        user_id = client.mail_acg
        
        # --- User calendar delta: events created on organizer's calendar (app-only token) ---
        if not delta_link:
            endpoint = f"/users/{user_id}/events/delta"
            full_url = f"{client.api_base_url}{endpoint}"
        else:
            full_url = delta_link
            
        try:
            access_token = client._get_access_token()
        except UserError as e:
            _logger.error(f"Cron Pull Graph Events Failed to get token: {e}")
            return
            
        headers = {
            'Authorization': f'Bearer {access_token}',
            'Content-Type': 'application/json'
        }
        
        _logger.info("Starting Graph API Pull Delta Query sync...")
        
        # Loop over the @odata.nextLink until we get a @odata.deltaLink
        while full_url:
            try:
                response = requests.get(full_url, headers=headers, timeout=20)
                if response.status_code == 410:
                    ICPSudo.set_param('recruitment.graph_delta_link', '')
                    _logger.warning("Graph delta link expired (410 Gone). Cleared; next sync will restart from scratch.")
                    full_url = None
                    continue
                response.raise_for_status()
                data = response.json()
            except requests.exceptions.HTTPError as e:
                _logger.error("Error fetching Graph Delta link: %s", e)
                return
            except Exception as e:
                _logger.error("Error fetching Graph Delta link: %s", e)
                return
                
            events = data.get('value', [])
            for event in events:
                graph_id = event.get('id')
                if not graph_id:
                    continue
                    
                # Find matching Odoo record
                invite = self.search([('microsoft_graph_event_id', '=', graph_id)], limit=1)
                
                # If event was deleted in Graph
                if '@removed' in event:
                    if invite:
                        _logger.info(f"Graph delta sync: Cancelling invite {invite.id} (Deleted in Graph)")
                        invite.with_context(skip_graph_sync=True).write({
                            'status': 'cancelled',
                            'microsoft_graph_event_id': False,
                            'microsoft_graph_online_meeting_id': False,
                            'microsoft_graph_meeting_join_url': False,
                            'microsoft_graph_calendar_type': 'user',
                            'microsoft_graph_group_id': False,
                        })
                        invite.message_post(body=invite.env._("Event was deleted in Microsoft Calendar. Setting status to Cancelled."), subtype_xmlid='mail.mt_note')
                    continue
                    
                # Ignore if we don't have a record for this event (eg. normally created calendar events)
                if not invite:
                    continue
                    
                # Event cancelled in Outlook/Teams (isCancelled: true) but not deleted
                if event.get('isCancelled'):
                    _logger.info("Graph delta sync: Cancelling invite %s (event marked cancelled in Graph)", invite.id)
                    invite.with_context(skip_graph_sync=True).write({
                        'status': 'cancelled',
                        'microsoft_graph_event_id': False,
                        'microsoft_graph_online_meeting_id': False,
                        'microsoft_graph_meeting_join_url': False,
                        'microsoft_graph_calendar_type': 'user',
                        'microsoft_graph_group_id': False,
                    })
                    invite.message_post(
                        body=invite.env._("Event was cancelled in Microsoft Calendar. Status set to Cancelled."),
                        subtype_xmlid='mail.mt_note',
                    )
                    continue
                    
                # It's an update. Check Start and End datetimes.
                start_str = event.get('start', {}).get('dateTime')
                end_str = event.get('end', {}).get('dateTime')
                
                if start_str and end_str:
                    try:
                        # Graph API returns UTC time in ISO format (e.g. 2024-03-01T15:00:00.0000000)
                        start_dt = parser.isoparse(start_str).replace(tzinfo=None)
                        end_dt = parser.isoparse(end_str).replace(tzinfo=None)
                        
                        duration_seconds = (end_dt - start_dt).total_seconds()
                        duration_hours = duration_seconds / 3600.0
                        
                        # Match duration selection drop-down, fallback to 1 Hour
                        duration_selection = '1.0'
                        valid_durations = [0.5, 1.0, 1.5, 2.0]
                        closest = min(valid_durations, key=lambda x: abs(x - duration_hours))
                        if abs(closest - duration_hours) < 0.25:
                            duration_selection = str(closest)
                            
                        # Prevent sync loop; sync time and attendees from Graph
                        write_vals = {
                            'start_datetime': start_dt,
                            'duration': duration_selection,
                            'status': 'confirmed',
                        }
                        attendee_vals = invite._acg_attendee_ids_from_graph_event(event)
                        if attendee_vals:
                            write_vals.update(attendee_vals)
                        invite.with_context(skip_graph_sync=True).write(write_vals)
                        invite.message_post(body=invite.env._("Event was updated from Microsoft Calendar. New time and attendees synced."), subtype_xmlid='mail.mt_note')
                    except Exception as e:
                        _logger.error(f"Graph delta sync: Error parsing dates for {invite.id}: {e}")
            
            # Navigate pagination
            if '@odata.nextLink' in data:
                full_url = data['@odata.nextLink']
            elif '@odata.deltaLink' in data:
                # We have hit the end of current changes! Save the deltaLink for the next cron run
                ICPSudo.set_param('recruitment.graph_delta_link', data['@odata.deltaLink'])
                _logger.info("Graph Delta Query complete. Saved delta token.")
                full_url = None
            else:
                full_url = None

        # --- Group calendar delta: sync deletions/updates from 6.0 HR group calendar ---
        if self._use_delegated_group_calendar():
            group_id = (self._get_recruitment_group_id() or '').strip()
            if group_id:
                try:
                    delegated_token = client._get_delegated_access_token()
                except UserError:
                    delegated_token = None
                if delegated_token:
                    group_delta_link = ICPSudo.get_param('recruitment.graph_group_delta_link')
                    if not group_delta_link:
                        now_utc = datetime.datetime.utcnow()
                        start_dt = (now_utc - datetime.timedelta(days=365)).strftime('%Y-%m-%dT%H:%M:%S.000Z')
                        end_dt = (now_utc + datetime.timedelta(days=365 * 2)).strftime('%Y-%m-%dT%H:%M:%S.000Z')
                        group_delta_link = (
                            f"{client.api_base_url}/groups/{group_id}/calendar/calendarView/delta"
                            f"?startDateTime={start_dt}&endDateTime={end_dt}"
                        )
                    group_url = group_delta_link
                    group_headers = {
                        'Authorization': f'Bearer {delegated_token}',
                        'Content-Type': 'application/json',
                    }
                    _logger.info("Starting Graph API Group Calendar Delta sync...")
                    while group_url:
                        try:
                            resp = requests.get(group_url, headers=group_headers, timeout=20)
                            if resp.status_code == 410:
                                ICPSudo.set_param('recruitment.graph_group_delta_link', '')
                                _logger.warning("Graph group delta link expired (410 Gone). Cleared; next sync will restart.")
                                break
                            resp.raise_for_status()
                            data = resp.json()
                        except requests.exceptions.HTTPError as e:
                            _logger.error("Error fetching Graph Group Calendar Delta: %s", e)
                            break
                        except Exception as e:
                            _logger.error("Error fetching Graph Group Calendar Delta: %s", e)
                            break
                        for event in data.get('value', []):
                            graph_id = event.get('id')
                            if not graph_id:
                                continue
                            invite = self.search([
                                ('microsoft_graph_event_id', '=', graph_id),
                                ('microsoft_graph_calendar_type', '=', 'group'),
                            ], limit=1)
                            if '@removed' in event:
                                if invite:
                                    _logger.info(
                                        "Graph group delta sync: Cancelling invite %s (deleted in group calendar)",
                                        invite.id,
                                    )
                                    invite.with_context(skip_graph_sync=True).write({
                                        'status': 'cancelled',
                                        'microsoft_graph_event_id': False,
                                        'microsoft_graph_online_meeting_id': False,
                                        'microsoft_graph_meeting_join_url': False,
                                        'microsoft_graph_calendar_type': 'user',
                                        'microsoft_graph_group_id': False,
                                    })
                                    invite.message_post(
                                        body=invite.env._("Event was deleted in Microsoft (Teams/Outlook) group calendar. Status set to Cancelled."),
                                        subtype_xmlid='mail.mt_note',
                                    )
                                continue
                            if not invite:
                                continue
                            if event.get('isCancelled'):
                                _logger.info(
                                    "Graph group delta sync: Cancelling invite %s (event marked cancelled in group calendar)",
                                    invite.id,
                                )
                                invite.with_context(skip_graph_sync=True).write({
                                    'status': 'cancelled',
                                    'microsoft_graph_event_id': False,
                                    'microsoft_graph_online_meeting_id': False,
                                    'microsoft_graph_meeting_join_url': False,
                                    'microsoft_graph_calendar_type': 'user',
                                    'microsoft_graph_group_id': False,
                                })
                                invite.message_post(
                                    body=invite.env._("Event was cancelled in Microsoft (group) calendar. Status set to Cancelled."),
                                    subtype_xmlid='mail.mt_note',
                                )
                                continue
                            start_str = event.get('start', {}).get('dateTime')
                            end_str = event.get('end', {}).get('dateTime')
                            if start_str and end_str:
                                try:
                                    start_dt = parser.isoparse(start_str).replace(tzinfo=None)
                                    end_dt = parser.isoparse(end_str).replace(tzinfo=None)
                                    duration_seconds = (end_dt - start_dt).total_seconds()
                                    duration_hours = duration_seconds / 3600.0
                                    duration_selection = '1.0'
                                    valid_durations = [0.5, 1.0, 1.5, 2.0]
                                    closest = min(valid_durations, key=lambda x: abs(x - duration_hours))
                                    if abs(closest - duration_hours) < 0.25:
                                        duration_selection = str(closest)
                                    write_vals = {
                                        'start_datetime': start_dt,
                                        'duration': duration_selection,
                                        'status': 'confirmed',
                                    }
                                    attendee_vals = invite._acg_attendee_ids_from_graph_event(event)
                                    if attendee_vals:
                                        write_vals.update(attendee_vals)
                                    invite.with_context(skip_graph_sync=True).write(write_vals)
                                    invite.message_post(
                                        body=invite.env._("Event was updated from Microsoft (group) calendar. New time and attendees synced."),
                                        subtype_xmlid='mail.mt_note',
                                    )
                                except Exception as e:
                                    _logger.error("Graph group delta sync: Error parsing dates for invite %s: %s", invite.id, e)
                        if '@odata.nextLink' in data:
                            group_url = data['@odata.nextLink']
                        elif '@odata.deltaLink' in data:
                            ICPSudo.set_param('recruitment.graph_group_delta_link', data['@odata.deltaLink'])
                            _logger.info("Graph Group Calendar Delta complete. Saved delta token.")
                            group_url = None
                        else:
                            group_url = None
                else:
                    _logger.debug("Group calendar delta skipped: no delegated token.")
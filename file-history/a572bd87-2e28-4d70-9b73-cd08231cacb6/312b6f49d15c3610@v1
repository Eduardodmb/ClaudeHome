    @api.model
    def _use_delegated_group_calendar(self):
        """
        True if events should be created on the HR group calendar using a delegated token.
        Requires: recruitment.use_delegated_group_calendar=True, recruitment.group_id set,
        and either recruitment.delegated_refresh_token (from Connect) or
        recruitment.delegated_user_email + recruitment.delegated_user_password (ROPC).
        """
        ICPSudo = self.env['ir.config_parameter'].sudo()
        use = (ICPSudo.get_param('recruitment.use_delegated_group_calendar') or 'False').strip().lower() in ('true', '1', 'yes')
        if not use:
            return False
        group_id = (ICPSudo.get_param('recruitment.group_id') or '').strip()
        if not group_id:
            return False
        refresh_token = (ICPSudo.get_param('recruitment.delegated_refresh_token') or '').strip()
        if refresh_token:
            return True
        email = (ICPSudo.get_param('recruitment.delegated_user_email') or '').strip()
        password = ICPSudo.get_param('recruitment.delegated_user_password') or ''
        return bool(email and password)

    def _ensure_calendar_shared_with_hr(self, client, user_id):
        """
        Ensure the organizer's calendar is shared with the HR principal (recruitment.calendar_share_with_email)
        with write permission so anyone with HR access can edit interview events.
        Idempotent: lists existing permissions and only POSTs if the principal does not already have write.
        """
        ICPSudo = self.env['ir.config_parameter'].sudo()
        share_email = (ICPSudo.get_param('recruitment.calendar_share_with_email') or '').strip()
        if not share_email:
            return
        share_email_lower = share_email.lower()
        permissions_endpoint = f"/users/{user_id}/calendar/calendarPermissions"
        write_roles = ('write', 'readWrite', 'delegateWithoutPrivateEventAccess', 'delegateWithPrivateEventAccess')
        try:
            response = client.call_api('GET', permissions_endpoint)
            existing = response.get('value') or []
            for perm in existing:
                addr = (perm.get('emailAddress') or {}).get('address') or ''
                if addr.lower() == share_email_lower and (perm.get('role') or '').lower() in write_roles:
                    _logger.debug("Calendar already shared with HR principal with write: %s", share_email)
                    return
            body = {
                'emailAddress': {'name': 'HR (Recruitment)', 'address': share_email},
                'isInsideOrganization': True,
                'isRemovable': True,
                'role': 'write',
            }
            client.call_api('POST', permissions_endpoint, body)
            _logger.info("Shared organizer calendar with HR principal (write): %s", share_email)
        except Exception as e:
            err_str = str(e).lower()
            if '500' in err_str or 'internal server' in err_str:
                _logger.warning(
                    "Calendar share with HR failed (interview will still be created). "
                    "Sharing with an M365 group often returns 500. Try setting recruitment.calendar_share_with_email "
                    "to a user mailbox email, or share the organizer's calendar manually in Outlook. Error: %s",
                    e,
                )
            else:
                _logger.warning(
                    "Could not ensure calendar shared with HR (interview will still be created): %s",
                    e,
                    exc_info=True,
                )

    def _convert_to_utc(self, odoo_datetime):
        """
        Odoo datetime fields are ALREADY stored in UTC.
        This function just adds timezone info for proper ISO formatting.
        """
        # Odoo stores datetimes as naive UTC, so just add UTC timezone info
        if odoo_datetime.tzinfo is None:
            utc_dt = pytz.utc.localize(odoo_datetime)
        else:
            utc_dt = odoo_datetime
        
        return utc_dt
    
    def _convert_from_utc(self, utc_datetime):
        """
        Convert a UTC datetime to user's local timezone for display.
        """
        user_tz_name = self.env.user.tz or 'America/Denver'
        user_tz = pytz.timezone(user_tz_name)
        
        # Add UTC timezone info if not present
        if utc_datetime.tzinfo is None:
            utc_dt = pytz.utc.localize(utc_datetime)
        else:
            utc_dt = utc_datetime
        
        # Convert to user's timezone
        local_dt = utc_dt.astimezone(user_tz)
        
        return local_dt
        
    @api.model
    def _read_local_file_data(self, relative_path):
        try:
            module_dir = os.path.dirname(os.path.abspath(__file__))
            full_path = os.path.join(module_dir, '..', relative_path)
            
            with open(full_path, 'rb') as f:
                file_content = f.read()
            
            encoded_content = base64.b64encode(file_content).decode('utf-8')
            file_name = os.path.basename(full_path)
            
            return file_name, encoded_content
        
        except FileNotFoundError:
            _logger.error(f"File not found: {full_path}")
            raise UserError(self.env._("Configuration Error: File not found at %(path)s.") % {"path": relative_path})
        except Exception as e:
            _logger.error(f"Error reading file {relative_path}: {e}")
            raise UserError(self.env._("Error reading file %(path)s: %(error)s") % {"path": relative_path, "error": e})


import logging

from odoo import models

_logger = logging.getLogger(__name__)


class RecruitmentInterviewInvitePortal(models.Model):
    _inherit = 'recruitment.interview.invite'

    def _get_portal_credentials_html(self):
        """Return an HTML block with temporary portal credentials for the candidate email.

        Called by _get_email_templates in the base module. Returns empty string if no
        applicant is linked or if token generation fails.
        """
        if not self.applicant_id:
            return ""
        email = (self.applicant_id.email_from or '').strip()
        if not email:
            return ""
        try:
            token_rec = self.env['hr.applicant.portal.token'].generate_for_applicant(
                self.applicant_id
            )
        except Exception as exc:
            _logger.warning(
                "Could not generate portal token for applicant %s: %s",
                self.applicant_id.id, exc,
            )
            return ""
        if not token_rec:
            return ""

        base_url = self.env['ir.config_parameter'].sudo().get_param('web.base.url')
        magic_link = f"{base_url}/recruitment/portal/login/{token_rec.token}"
        detail_url = f"{base_url}/my/application/{self.applicant_id.id}"
        expiry_str = (
            token_rec.expiry.strftime('%B %d, %Y %I:%M %p UTC')
            if token_rec.expiry
            else 'N/A'
        )

        return f"""
            <div style="background:#f4f8ff;border:1px solid #c0d4ef;border-radius:6px;
                        padding:16px 20px;margin:20px 0;">
                <p style="margin:0 0 10px;font-weight:bold;color:#1a3a6c;font-size:13pt;">
                    Candidate Portal Access
                </p>
                <p style="margin:0 0 8px;">
                    <strong>One-click access</strong> (no password needed — click to log in automatically):
                </p>
                <p style="margin:0 0 12px;word-break:break-all;">
                    <a href="{magic_link}" style="color:#0056b3;">{magic_link}</a>
                </p>
                <p style="margin:0 0 6px;">
                    Or log in manually at
                    <a href="{base_url}/web/login" style="color:#0056b3;">{base_url}/web/login</a>:
                </p>
                <p style="margin:0 0 4px;">
                    &nbsp;&nbsp;<strong>Username&nbsp;(email):</strong>&nbsp; {email}
                </p>
                <p style="margin:0 0 12px;">
                    &nbsp;&nbsp;<strong>Temporary Password:</strong>&nbsp; {token_rec.temp_password}
                </p>
                <p style="margin:0 0 6px;">
                    After logging in you can view your application status and upload any requested
                    documents at: <a href="{detail_url}" style="color:#0056b3;">My Application</a>
                </p>
                <p style="margin:0;font-size:10pt;color:#777;">
                    This link and password expire on {expiry_str}.
                </p>
            </div>
        """

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_applicant_checklist_item_view_form" model="ir.ui.view">
        <field name="name">hr.applicant.checklist.item.form</field>
        <field name="model">hr.applicant.checklist.item</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_template_attachments"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-download"
                                invisible="template_attachment_count == 0">
                            <field name="template_attachment_count" widget="statinfo" string="Template Files"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="completed"/>
                        </group>
                        <group>
                            <field name="completed_by" readonly="1"/>
                            <field name="completed_date" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Template">
                            <field name="sharepoint_url" widget="url"/>
                            <field name="template_attachment_filename" invisible="1"/>
                            <field name="template_attachment" string="Template Document" filename="template_attachment_filename" readonly="1"/>
                        </group>
                        <group string="Result">
                            <field name="result_url" widget="url"/>
                            <field name="result_attachment_filename" invisible="1"/>
                            <field name="result_attachment" string="Result Document" filename="result_attachment_filename"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Additional notes or comments..."/>
                    </group>
                    <notebook>
                        <page string="Template Attachments" name="template_attachments" invisible="template_attachment_count == 0">
                            <field name="template_attachment_ids" widget="many2many_binary" readonly="1" nolabel="1"/>
                        </page>
                        <page string="Multiple Result Attachments" name="result_attachments">
                            <field name="result_attachment_ids" widget="many2many_binary" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_applicant_checklist_item_view_list" model="ir.ui.view">
        <field name="name">hr.applicant.checklist.item.list</field>
        <field name="model">hr.applicant.checklist.item</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="template_attachment_filename" optional="show" string="Template Doc"/>
                <field name="result_attachment_filename" optional="show" string="Result Doc"/>
                <field name="sharepoint_url" widget="url" optional="hide"/>
                <field name="template_attachment_count" optional="hide" string="Template Files"/>
                <field name="result_attachment_count" optional="hide" string="Result Files"/>
                <field name="completed" widget="boolean_toggle"/>
                <field name="completed_by" readonly="1" optional="show"/>
                <field name="completed_date" readonly="1" optional="show"/>
                <field name="result_url" widget="url" optional="hide"/>
                <field name="notes" optional="hide"/>
            </list>
        </field>
    </record>
</odoo>

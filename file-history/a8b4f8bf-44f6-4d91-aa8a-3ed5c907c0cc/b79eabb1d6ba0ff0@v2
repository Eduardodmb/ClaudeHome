<?php

namespace App\Models;

use Illuminate\Database\Eloquent\Model;

class AssessmentFinding extends Model
{
    protected $fillable = [
        'assessment_id', 'subcontrol_id', 'status',
        'implementation_details', 'notes', 'recommendations',
        'ai_generated_recommendations', 'ai_generated_at',
        'assessed_by', 'assessed_at',
    ];

    protected $casts = [
        'ai_generated_recommendations' => 'boolean',
        'ai_generated_at'              => 'datetime',
        'assessed_at'                  => 'datetime',
    ];

    public function assessment()
    {
        return $this->belongsTo(Assessment::class);
    }

    public function subcontrol()
    {
        return $this->belongsTo(Subcontrol::class);
    }

    public function assessor()
    {
        return $this->belongsTo(User::class, 'assessed_by');
    }

    public function documents()
    {
        return $this->belongsToMany(Document::class, 'assessment_finding_documents');
    }

    public function risks()
    {
        return $this->hasMany(Risk::class, 'subcontrol_id', 'subcontrol_id');
    }
}

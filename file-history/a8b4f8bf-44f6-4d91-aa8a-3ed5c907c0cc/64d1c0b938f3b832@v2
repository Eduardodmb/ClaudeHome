    <script>
    function assessmentFindings() {
        return {};
    }

    function findingPanel(findingId, assessmentId, subcontrolId, currentStatus) {
        return {
            findingId,
            assessmentId,
            subcontrolId,
            currentStatus,
            expanded: false,
            saving: false,
            saved: false,
            aiLoading: false,
            aiTimestamp: '',
            details: '',
            notes: '',
            recommendations: '',

            async setStatus(status) {
                this.currentStatus = status;
                this.expanded = true;
                await this.save();
            },

            async save() {
                this.saving = true;
                this.saved = false;
                try {
                    const res = await fetch(`/assessments/${this.assessmentId}/findings`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content,
                            'Accept': 'application/json',
                        },
                        body: JSON.stringify({
                            subcontrol_id: this.subcontrolId,
                            status: this.currentStatus,
                            implementation_details: this.details,
                            notes: this.notes,
                            recommendations: this.recommendations,
                        }),
                    });
                    if (res.ok) { this.saved = true; setTimeout(() => this.saved = false, 2000); }
                } finally { this.saving = false; }
            },

            async generateAI() {
                this.aiLoading = true;
                try {
                    const res = await fetch(`/assessments/${this.assessmentId}/ai-recommendations`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content,
                            'Accept': 'application/json',
                        },
                        body: JSON.stringify({ subcontrol_id: this.subcontrolId }),
                    });
                    const data = await res.json();
                    if (data.recommendation) {
                        this.recommendations = data.recommendation;
                        this.aiTimestamp = new Date(data.generated_at).toLocaleString();
                    } else {
                        alert(data.error || 'AI generation failed.');
                    }
                } catch(e) { alert('Error generating recommendations.'); }
                finally { this.aiLoading = false; }
            },
        };
    }
    </script>

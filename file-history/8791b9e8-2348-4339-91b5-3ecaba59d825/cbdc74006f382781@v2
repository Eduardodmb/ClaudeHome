<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Security Group: Project Accounting User -->
        <record id="group_project_accounting_user" model="res.groups">
            <field name="name">Accounting / Project Viewer</field>
            <field name="category_id" ref="base.module_category_accounting"/>
            <field name="comment">Read-only access to project information for accounting department</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Record Rule: Accounting users can read all projects -->
        <record id="project_accounting_read_all_rule" model="ir.rule">
            <field name="name">Project Accounting: Read All Projects</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_project_accounting_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Accounting Read-Only List View -->
    <record id="view_project_accounting_list" model="ir.ui.view">
        <field name="name">project.project.accounting.list</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <list string="Projects - Accounting View"
                  create="false"
                  edit="false"
                  delete="false"
                  export_xlsx="true">
                <!-- Basic Project Information -->
                <field name="name" readonly="1"/>
                <field name="project_no_id" readonly="1" optional="show"/>

                <!-- Partner/Customer Information -->
                <field name="partner_id" readonly="1" optional="show"/>

                <!-- Project Status -->
                <field name="stage_id" readonly="1" optional="show"/>
                <field name="active" readonly="1" optional="hide"/>

                <!-- Dates -->
                <field name="date_start" readonly="1" optional="show"/>
                <field name="date" readonly="1" optional="hide"/>

                <!-- Financial Fields (from project_custom_fields and project_dashboard) -->
                <field name="x_bom_summary_total" readonly="1" optional="show" widget="monetary"/>
                <field name="dashboard_total_co" readonly="1" optional="show" widget="monetary"/>
                <field name="dashboard_po_total" readonly="1" optional="show" widget="monetary"/>
                <field name="dashboard_project_balance" readonly="1" optional="show" widget="monetary"
                       decoration-success="dashboard_project_balance &gt;= 0"
                       decoration-danger="dashboard_project_balance &lt; 0"/>

                <!-- Hours Tracking -->
                <field name="dashboard_allocated_hours" readonly="1" optional="hide" widget="float_time"/>
                <field name="dashboard_total_spent_hours" readonly="1" optional="hide" widget="float_time"/>
                <field name="dashboard_hours_balance" readonly="1" optional="hide" widget="float_time"/>

                <!-- User Assignment -->
                <field name="user_id" readonly="1" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Accounting Read-Only Form View -->
    <record id="view_project_accounting_form" model="ir.ui.view">
        <field name="name">project.project.accounting.form</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <form string="Project - Accounting View" create="false" edit="false" delete="false">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <!-- Optional: Add smart buttons here if needed -->
                    </div>

                    <group>
                        <group name="basic_info" string="Project Information">
                            <field name="name" readonly="1"/>
                            <field name="project_no_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                            <field name="company_id" readonly="1" groups="base.group_multi_company"/>
                        </group>

                        <group name="status_dates" string="Status &amp; Dates">
                            <field name="stage_id" readonly="1"/>
                            <field name="active" readonly="1"/>
                            <field name="date_start" readonly="1"/>
                            <field name="date" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Financial Information Tab -->
                        <page name="financial" string="Financial Information">
                            <group>
                                <group name="revenue" string="Revenue">
                                    <field name="x_bom_summary_total" readonly="1" widget="monetary"/>
                                    <field name="dashboard_internal_co_total" readonly="1" widget="monetary"/>
                                    <field name="dashboard_external_co_total" readonly="1" widget="monetary"/>
                                    <field name="dashboard_total_co" readonly="1" widget="monetary"/>
                                </group>

                                <group name="costs" string="Costs">
                                    <field name="dashboard_po_total" readonly="1" widget="monetary"/>
                                </group>
                            </group>

                            <group>
                                <group name="balance" string="Balance">
                                    <field name="dashboard_project_balance" readonly="1" widget="monetary"/>
                                </group>
                            </group>
                        </page>

                        <!-- BOM Details Tab -->
                        <page name="bom_details" string="BOM Details">
                            <group>
                                <group name="bom_items" string="Items &amp; Materials">
                                    <field name="x_bom_summary_items" readonly="1" widget="monetary"/>
                                    <field name="x_bom_summary_items_current_expense" readonly="1" widget="monetary"/>
                                </group>

                                <group name="bom_labor" string="Labor">
                                    <field name="x_bom_summary_labor" readonly="1" widget="monetary"/>
                                    <field name="x_bom_summary_labor_current_expense" readonly="1" widget="monetary"/>
                                </group>
                            </group>

                            <group>
                                <group name="bom_subcontractor" string="Subcontractor">
                                    <field name="x_bom_summary_subcontractor" readonly="1" widget="monetary"/>
                                    <field name="x_bom_summary_subcontractor_current_expense" readonly="1" widget="monetary"/>
                                </group>

                                <group name="bom_other" string="Other Expenses">
                                    <field name="x_bom_summary_travel" readonly="1" widget="monetary"/>
                                    <field name="x_bom_summary_travel_current_expense" readonly="1" widget="monetary"/>
                                    <field name="x_bom_summary_miscellaneous" readonly="1" widget="monetary"/>
                                    <field name="x_bom_summary_miscellaneous_current_expense" readonly="1" widget="monetary"/>
                                    <field name="x_bom_summary_reserve" readonly="1" widget="monetary"/>
                                    <field name="x_bom_summary_reserve_current_expense" readonly="1" widget="monetary"/>
                                </group>
                            </group>
                        </page>

                        <!-- Hours Tracking Tab -->
                        <page name="hours" string="Hours Tracking">
                            <group>
                                <group name="hours_allocated" string="Allocated Hours">
                                    <field name="dashboard_allocated_hours" readonly="1" widget="float_time"/>
                                </group>

                                <group name="hours_spent" string="Spent Hours">
                                    <field name="dashboard_timesheet_hours" readonly="1" widget="float_time"/>
                                    <field name="dashboard_daily_report_hours" readonly="1" widget="float_time"/>
                                    <field name="dashboard_total_spent_hours" readonly="1" widget="float_time"/>
                                </group>
                            </group>

                            <group>
                                <group name="hours_balance" string="Balance">
                                    <field name="dashboard_hours_balance" readonly="1" widget="float_time"/>
                                </group>
                            </group>
                        </page>

                        <!-- Additional Information Tab -->
                        <page name="additional" string="Additional Information">
                            <group>
                                <field name="description" readonly="1" nolabel="1" placeholder="No description..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for Accounting View -->
    <record id="action_project_accounting_view" model="ir.actions.act_window">
        <field name="name">Projects (Accounting)</field>
        <field name="res_model">project.project</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_project_accounting_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_project_accounting_form')})]"/>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No projects found
            </p>
            <p>
                This is a read-only view for the accounting department.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_project_accounting"
              name="Projects (Accounting)"
              parent="project.menu_main_pm"
              action="action_project_accounting_view"
              groups="group_project_accounting_user"
              sequence="100"/>

</odoo>

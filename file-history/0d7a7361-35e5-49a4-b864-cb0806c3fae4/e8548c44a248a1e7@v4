# -*- coding: utf-8 -*-
"""Bulk ticket upload wizard using Excel templates."""

import base64
import io
import json
import logging
from datetime import datetime, timedelta

from odoo import _, api, fields, models
from odoo.exceptions import UserError

try:
    import xlsxwriter
    import openpyxl
except ImportError:
    xlsxwriter = None
    openpyxl = None

_logger = logging.getLogger(__name__)


class TicketBulkUpload(models.TransientModel):
    _name = 'ticket.bulk.upload'
    _description = 'Bulk Upload Tickets from Excel'

    upload_file = fields.Binary(
        string='Upload Excel File',
        help='Upload an Excel file with ticket data'
    )
    upload_filename = fields.Char(string='Filename')

    template_file = fields.Binary(
        string='Template File',
        readonly=True,
        attachment=False
    )
    template_filename = fields.Char(
        string='Template Filename',
        default='ticket_upload_template.xlsx',
        readonly=True
    )

    import_summary = fields.Html(
        string='Import Summary',
        readonly=True
    )

    # Abbreviation mapping fields
    state = fields.Selection([
        ('upload', 'Upload File'),
        ('map_abbreviations', 'Map Abbreviations'),
        ('import', 'Import Complete'),
    ], default='upload', string='State')

    unmapped_abbreviations = fields.Text(
        string='Unmapped Abbreviations',
        help='JSON data of abbreviations that need mapping'
    )

    abbreviation_line_ids = fields.One2many(
        'ticket.bulk.upload.abbreviation.line',
        'wizard_id',
        string='Abbreviation Mappings'
    )

    def _resolve_user(self, user_input):
        """
        Resolve user by abbreviation or email.
        Returns user or None if not found.
        """
        if not user_input:
            return None

        user_input = str(user_input).strip()
        User = self.env['res.users']

        # Try 1: Exact abbreviation match
        user = User.search([('ticket_abbreviation', '=', user_input)], limit=1)
        if user:
            return user

        # Try 2: Search by login/email
        if '@' in user_input:
            user = User.search([('login', '=ilike', user_input)], limit=1)
            if user:
                return user

        return None

    def action_download_template(self):
        """Generate and download Excel template with proper columns and instructions."""
        if not xlsxwriter:
            raise UserError(_('Python library xlsxwriter is required. Please install it.'))

        output = io.BytesIO()
        workbook = xlsxwriter.Workbook(output, {'in_memory': True})

        # Create main data sheet
        worksheet = workbook.add_worksheet('Tickets')

        # Define formats
        header_format = workbook.add_format({
            'bold': True,
            'bg_color': '#4472C4',
            'font_color': 'white',
            'border': 1,
            'align': 'center',
            'valign': 'vcenter',
            'text_wrap': True
        })

        required_format = workbook.add_format({
            'bold': True,
            'bg_color': '#E7E6E6',
            'border': 1,
            'align': 'center',
            'valign': 'vcenter',
            'text_wrap': True
        })

        # Define columns
        columns = [
            ('Summary', 50, True, 'Brief description of the ticket (required)'),
            ('Description', 60, False, 'Detailed description in HTML or plain text'),
            ('Assigned To', 30, False, 'User abbreviation or email (e.g., EMAR, user@example.com)'),
            ('Due Date', 15, False, 'Due date in YYYY-MM-DD format (e.g., 2026-05-15)'),
            ('Priority', 10, False, 'P1, P2, or P3'),
        ]

        # Write headers
        for col, (name, width, required, help_text) in enumerate(columns):
            worksheet.write(0, col, name, header_format if not required else required_format)
            worksheet.write_comment(0, col, help_text)
            worksheet.set_column(col, col, width)

        # Add sample data
        sample_data = [
            [
                'Fix server connectivity issue',
                '<p>Server is not responding to ping requests. Need to investigate network configuration.</p>',
                'EMAR',  # Using abbreviation
                (datetime.now() + timedelta(days=7)).strftime('%Y-%m-%d'),
                'P1',
            ],
            [
                'Update employee handbook',
                'Review and update the employee handbook with new policies',
                'AE',  # Using abbreviation
                (datetime.now() + timedelta(days=14)).strftime('%Y-%m-%d'),
                'P2',
            ],
        ]

        for row, data in enumerate(sample_data, start=1):
            for col, value in enumerate(data):
                worksheet.write(row, col, value)

        # Create instructions sheet
        instructions = workbook.add_worksheet('Instructions')
        instructions.set_column(0, 0, 80)

        instructions_text = [
            ('Ticket Bulk Upload Instructions', header_format),
            ('', None),
            ('1. Fill in the "Tickets" sheet with your ticket data', None),
            ('2. Required field: Summary (highlighted in gray)', None),
            ('3. Optional fields will use defaults if left empty:', None),
            ('   - Assigned To: Leave empty to assign to yourself', None),
            ('   - Due Date: Leave empty to use default (today)', None),
            ('   - Priority: P1, P2, or P3 (leave empty for no priority)', None),
            ('', None),
            ('4. Save the file and upload it using the bulk upload wizard', None),
            ('5. If new abbreviations are found, you will be asked to map them', None),
            ('6. The system will create tickets and show you a summary', None),
            ('', None),
            ('Important Notes:', header_format),
            ('- Activity Type is always "To Do" (automatic)', None),
            ('- Department is taken from the assigned user or employee record (automatic)', None),
            ('- Assigned To supports:', None),
            ('  * User abbreviations (e.g., EMAR, AE, OMO)', None),
            ('  * Email addresses (e.g., user@example.com)', None),
            ('- New abbreviations will prompt for user selection', None),
            ('- Abbreviations are saved for future uploads', None),
            ('- Date format must be YYYY-MM-DD', None),
            ('- Delete the sample rows before uploading', None),
            ('- Duplicate tickets (same summary + department + user) will be skipped', None),
        ]

        for row, (text, fmt) in enumerate(instructions_text):
            instructions.write(row, 0, text, fmt)

        workbook.close()
        output.seek(0)

        # Save to wizard
        template_data = base64.b64encode(output.read())
        self.write({
            'template_file': template_data,
            'template_filename': 'ticket_upload_template.xlsx'
        })

        return {
            'type': 'ir.actions.act_url',
            'url': f'/web/content?model={self._name}&id={self.id}&field=template_file&filename={self.template_filename}&download=true',
            'target': 'self',
        }

    def _scan_file_for_abbreviations(self):
        """Scan uploaded Excel file and return list of unique 'Assigned To' values."""
        if not self.upload_file or not openpyxl:
            return []

        file_data = base64.b64decode(self.upload_file)
        workbook = openpyxl.load_workbook(io.BytesIO(file_data))

        if 'Tickets' not in workbook.sheetnames:
            raise UserError(_('Excel file must contain a "Tickets" sheet.'))

        sheet = workbook['Tickets']
        header_row = list(sheet.iter_rows(min_row=1, max_row=1, values_only=True))[0]
        col_map = {name.strip(): idx for idx, name in enumerate(header_row) if name}

        assigned_to_col = col_map.get('Assigned To', 2)
        assigned_values = set()

        for row in sheet.iter_rows(min_row=2, values_only=True):
            if not any(row):
                continue
            assigned_to = row[assigned_to_col]
            if assigned_to:
                assigned_values.add(str(assigned_to).strip())

        return list(assigned_values)

    def action_validate_file(self):
        """Validate uploaded file and check for unmapped abbreviations."""
        if not self.upload_file:
            raise UserError(_('Please upload an Excel file first.'))

        # Scan for all assigned_to values
        assigned_values = self._scan_file_for_abbreviations()

        # Check which ones don't have mappings
        unmapped = []
        for value in assigned_values:
            if not value or '@' in value:  # Skip empty or email
                continue
            user = self._resolve_user(value)
            if not user:
                unmapped.append(value)

        if unmapped:
            # Create abbreviation lines for mapping
            self.abbreviation_line_ids.unlink()
            for abbr in unmapped:
                self.env['ticket.bulk.upload.abbreviation.line'].create({
                    'wizard_id': self.id,
                    'abbreviation': abbr,
                })

            self.state = 'map_abbreviations'

            return {
                'type': 'ir.actions.act_window',
                'res_model': self._name,
                'res_id': self.id,
                'view_mode': 'form',
                'target': 'new',
            }
        else:
            # No unmapped abbreviations, proceed directly to import
            return self.action_import_tickets()

    def action_save_abbreviations(self):
        """Save abbreviation mappings to user records."""
        for line in self.abbreviation_line_ids:
            if not line.user_id:
                raise UserError(_('Please select a user for abbreviation: %s') % line.abbreviation)

            # Update user's abbreviation field
            line.user_id.ticket_abbreviation = line.abbreviation

        # Proceed to import
        return self.action_import_tickets()

    def _check_duplicate(self, summary, user_id, department_id):
        """Check if a similar ticket already exists to prevent duplicates."""
        domain = [
            ('summary', '=ilike', summary.strip()),
            ('user_id', '=', user_id),
        ]

        if department_id:
            domain.append(('target_department_id', '=', department_id))

        existing = self.env['mail.activity'].search(domain, limit=1)
        return bool(existing)

    def action_import_tickets(self):
        """Parse uploaded Excel file and create tickets."""
        if not self.upload_file:
            raise UserError(_('Please upload an Excel file first.'))

        if not openpyxl:
            raise UserError(_('Python library openpyxl is required. Please install it.'))

        # Decode the file
        file_data = base64.b64decode(self.upload_file)
        workbook = openpyxl.load_workbook(io.BytesIO(file_data))

        if 'Tickets' not in workbook.sheetnames:
            raise UserError(_('Excel file must contain a "Tickets" sheet.'))

        sheet = workbook['Tickets']

        # Parse tickets
        created_count = 0
        error_count = 0
        duplicate_count = 0
        errors = []

        # Get column indices from header row
        header_row = list(sheet.iter_rows(min_row=1, max_row=1, values_only=True))[0]
        col_map = {name.strip(): idx for idx, name in enumerate(header_row) if name}

        # Get "To Do" activity type (default for all tickets)
        todo_type = self.env['mail.activity.type'].search([('name', '=ilike', 'To Do')], limit=1)
        if not todo_type:
            todo_type = self.env['mail.activity.type'].create({'name': 'To Do'})

        # Process data rows (skip header)
        for row_num, row in enumerate(sheet.iter_rows(min_row=2, values_only=True), start=2):
            if not any(row):  # Skip empty rows
                continue

            try:
                # Extract values
                summary = row[col_map.get('Summary', 0)]
                if not summary:
                    errors.append(f'Row {row_num}: Summary is required')
                    error_count += 1
                    continue

                description = row[col_map.get('Description', 1)] or ''
                assigned_input = row[col_map.get('Assigned To', 2)]
                due_date_str = row[col_map.get('Due Date', 3)]
                priority = row[col_map.get('Priority', 4)]

                # Prepare ticket values
                vals = {
                    'summary': summary,
                    'note': description,
                    'activity_type_id': todo_type.id,
                }

                # Resolve assigned user (exact abbreviation match or email)
                user = None
                if assigned_input:
                    user = self._resolve_user(assigned_input)
                    if user:
                        vals['user_id'] = user.id
                    else:
                        errors.append(f'Row {row_num}: User abbreviation not found: {assigned_input}')
                        error_count += 1
                        continue
                else:
                    user = self.env.user
                    vals['user_id'] = user.id

                # Get department from user's department
                if user.department_id:
                    vals['target_department_id'] = user.department_id.id
                    vals['res_model_id'] = self.env['ir.model']._get_id('hr.department')
                    vals['res_id'] = user.department_id.id
                else:
                    # Fallback: link to employee record if user has no department
                    employee = self.env['hr.employee'].search([('user_id', '=', user.id)], limit=1)
                    if employee:
                        vals['res_model_id'] = self.env['ir.model']._get_id('hr.employee')
                        vals['res_id'] = employee.id
                        if employee.department_id:
                            vals['target_department_id'] = employee.department_id.id
                    else:
                        # No employee record found - skip this ticket
                        errors.append(f'Row {row_num}: User "{user.name}" has no department or employee record. Ticket skipped.')
                        error_count += 1
                        continue

                # Check for duplicates
                if self._check_duplicate(summary, vals['user_id'], vals.get('target_department_id')):
                    errors.append(f'Row {row_num}: Duplicate ticket skipped (same summary, user, and department)')
                    duplicate_count += 1
                    continue

                # Parse due date
                if due_date_str:
                    if isinstance(due_date_str, datetime):
                        vals['date_deadline'] = due_date_str.date()
                    else:
                        try:
                            vals['date_deadline'] = datetime.strptime(str(due_date_str), '%Y-%m-%d').date()
                        except ValueError:
                            errors.append(f'Row {row_num}: Invalid date format: {due_date_str}. Use YYYY-MM-DD')
                            error_count += 1
                            continue
                else:
                    vals['date_deadline'] = fields.Date.today()

                # Set priority
                if priority and str(priority).upper() in ['P1', 'P2', 'P3']:
                    vals['priority'] = str(priority).lower()

                # Create the ticket
                self.env['mail.activity'].create(vals)
                created_count += 1

            except Exception as e:
                _logger.exception(f'Error processing row {row_num}')
                errors.append(f'Row {row_num}: {str(e)}')
                error_count += 1
                continue

        # Generate summary
        summary_html = f"""
        <div style="padding: 10px;">
            <h3>Import Complete</h3>
            <p><strong>Successfully created:</strong> {created_count} tickets</p>
            <p><strong>Duplicates skipped:</strong> {duplicate_count}</p>
            <p><strong>Errors:</strong> {error_count}</p>
        """

        if errors:
            summary_html += '<h4>Error Details:</h4><ul>'
            for error in errors[:50]:  # Limit to first 50 errors
                summary_html += f'<li>{error}</li>'
            if len(errors) > 50:
                summary_html += f'<li>... and {len(errors) - 50} more errors</li>'
            summary_html += '</ul>'

        summary_html += '</div>'

        self.import_summary = summary_html
        self.state = 'import'

        return {
            'type': 'ir.actions.act_window',
            'res_model': self._name,
            'res_id': self.id,
            'view_mode': 'form',
            'target': 'new',
        }


class TicketBulkUploadAbbreviationLine(models.TransientModel):
    _name = 'ticket.bulk.upload.abbreviation.line'
    _description = 'Abbreviation to User Mapping Line'

    wizard_id = fields.Many2one('ticket.bulk.upload', required=True, ondelete='cascade')
    abbreviation = fields.Char(string='Abbreviation', required=True, readonly=True)
    user_id = fields.Many2one('res.users', string='Select User', domain=[('share', '=', False)])

        .a-val a { color: var(--g); text-decoration: none; }
        .a-val a:hover { text-decoration: underline; }

        /* ── Skills ──────────────────────────── */
        .sk-wrap { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px,1fr)); gap: 0 48px; }

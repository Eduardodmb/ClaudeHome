        /* Decorative bg polygons matching Ryan's aesthetic */
        body::before, body::after {
            content: '';
            position: fixed;
            z-index: 0;
            pointer-events: none;
        }
        body::before {
            top: -80px; left: -60px;
            width: 320px; height: 320px;
            background: rgba(255,255,255,.06);
            clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
        }
        body::after {
            bottom: -60px; right: -40px;
            width: 260px; height: 260px;
            background: rgba(255,255,255,.05);
            clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);
        }

        /* ── Layout wrapper ──────────────────── */
        .page {
            position: relative;
            z-index: 1;
            display: flex;
            min-height: 100vh;
            align-items: stretch;
        }

        /* ── Icon nav (far left) ─────────────── */
        .icon-nav {
            width: 70px;
            background: #fff;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            box-shadow: 2px 0 12px rgba(0,0,0,.08);
            position: sticky;
            top: 0;
            height: 100vh;
            z-index: 20;
            overflow: hidden;
        }
        .nav-burger {
            width: 70px;
            height: 62px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-bottom: 1px solid #f4f4f4;
            flex-shrink: 0;
            cursor: pointer;
            color: #aaa;
        }
        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 70px;
            padding: 14px 0;
            gap: 5px;
            cursor: pointer;
            color: #c8c8c8;
            text-decoration: none;
            transition: color .2s;
            border: none;
            background: none;
            font-family: 'Poppins', sans-serif;
        }
        .nav-item:hover { color: #999; }
        .nav-item.on   { color: var(--g); }
        .nav-label {
            font-size: .55rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .8px;
            line-height: 1;
        }

        /* ── Profile card ────────────────────── */
        .profile-card {
            width: 390px;
            flex-shrink: 0;
            background: #fff;
            border-radius: 8px;
            overflow: hidden;
            margin: 22px 12px 22px 18px;
            display: flex;
            flex-direction: column;
            box-shadow: 0 12px 48px rgba(0,0,0,.14);
            align-self: flex-start;
            position: sticky;
            top: 22px;
            max-height: calc(100vh - 44px);
        }
        .photo-wrap {
            width: 100%;
            height: 270px;
            overflow: hidden;
            flex-shrink: 0;
            background: #e8edf2;
        }
        .photo-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center top;
            display: block;
        }
        .photo-fallback {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(145deg, #e8f5ee, #d8eddf);
            font-size: 5rem;
            font-weight: 700;
            color: var(--g);
        }
        .profile-body {
            padding: 22px 24px 20px;
            text-align: center;
            flex: 1;
            overflow-y: auto;
        }
        .profile-name {
            font-size: 1.45rem;

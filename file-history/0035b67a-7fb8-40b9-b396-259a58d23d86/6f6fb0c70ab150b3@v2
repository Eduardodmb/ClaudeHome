            padding: 22px 22px 22px 0;
            display: flex;
            flex-direction: column;
        }
        .content-card {
            background: #fff;
            border-radius: 8px;
            padding: 38px 42px;
            box-shadow: 0 12px 48px rgba(0,0,0,.12);
            flex: 1;
            overflow-y: auto;
        }

        /* ── Section heading (R)esume style ──── */
        .s-head {
            font-size: 1.55rem;
            font-weight: 700;
            color: var(--txt);
            margin-bottom: 28px;
            line-height: 1;
        }
        .s-head .hi { color: var(--g); }

        /* ── Column sub-header ───────────────── */
        .col-top {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 8px;
        }
        .col-icon { color: var(--g); display: flex; }
        .col-label {
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--txt);
        }
        .col-line { height: 1px; background: var(--bdr); margin-bottom: 22px; }

        /* ── Experience / Education entries ───── */
        .xp-item { margin-bottom: 22px; }
        .xp-item:last-child { margin-bottom: 0; }
        .xp-date {
            display: inline-block;
            font-size: .68rem;
            color: var(--sub);
            background: #f5f5f5;
            border: 1px solid #e8e8e8;
            padding: 2px 10px;
            border-radius: 4px;
            margin-bottom: 9px;
        }
        .xp-role    { font-size: .92rem; font-weight: 600; color: var(--txt); margin-bottom: 2px; }
        .xp-company { font-size: .8rem; color: var(--sub); margin-bottom: 7px; }
        .xp-desc    { font-size: .79rem; color: var(--sub); line-height: 1.75; }
        .xp-sep     { height: 1px; background: #f5f5f5; margin: 18px 0; }

        /* ── About info grid ─────────────────── */
        .a-bio { font-size: .875rem; color: #666; line-height: 1.85; margin-bottom: 24px; }
        .a-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px,1fr)); gap: 12px; }
        .a-cell {
            background: #f8f8f8;
            border: 1px solid var(--bdr);
            border-radius: 8px;
            padding: 13px 15px;
        }

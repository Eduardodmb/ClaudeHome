<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Weekly Performance List View -->
    <record id="view_mail_activity_weekly_performance_list" model="ir.ui.view">
        <field name="name">mail.activity.weekly.performance.list</field>
        <field name="model">mail.activity.weekly.performance</field>
        <field name="arch" type="xml">
            <list string="Weekly Performance Dashboard">
                <field name="name"/>
                <field name="week_start"/>
                <field name="week_end"/>
            </list>
        </field>
    </record>

    <!-- Daily Details Popup Form -->
    <record id="view_weekly_performance_line_daily_popup" model="ir.ui.view">
        <field name="name">mail.activity.weekly.performance.line.daily.popup</field>
        <field name="model">mail.activity.weekly.performance.line</field>
        <field name="arch" type="xml">
            <form string="Daily Breakdown">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="employee_id" readonly="1"/>
                        </h1>
                        <h3>Daily Performance Breakdown (Goal: 85% Progress)</h3>
                    </div>

                    <group>
                        <group string="Prior Week Summary">
                            <field name="prior_week_open_vs_completed" widget="percentage"/>
                            <field name="prior_week_p1_strikes"/>
                        </group>
                        <group string="Week Accumulated">
                            <field name="week_progress_percent" widget="percentage"/>
                            <field name="week_open_total"/>
                            <field name="week_completed_total"/>
                            <field name="week_p1_strikes"/>
                        </group>
                    </group>

                    <group>
                        <group string="Activity Breakdown - Where Numbers Come From">
                            <label for="week_total_worked" string="Total Worked On This Week"/>
                            <div>
                                <field name="week_total_worked" class="oe_inline"/>
                                <span class="text-muted"> activities (Open + Completed = full workload)</span>
                            </div>
                            <label for="week_created_count" string="Created This Week"/>
                            <div>
                                <field name="week_created_count" class="oe_inline"/>
                                <span class="text-muted"> new activities created during this week</span>
                            </div>
                            <label for="week_deadline_count" string="Deadline This Week"/>
                            <div>
                                <field name="week_deadline_count" class="oe_inline"/>
                                <span class="text-muted"> activities due this week (includes old tasks)</span>
                            </div>
                            <label for="week_completed_total" string="Completed This Week"/>
                            <div>
                                <field name="week_completed_total" class="oe_inline"/>
                                <span class="text-muted"> activities marked as done during this week</span>
                            </div>
                        </group>
                    </group>

                    <separator string="Daily Breakdown - Monday through Sunday"/>
                    <field name="daily_line_ids" nolabel="1">
                        <list string="Daily Metrics"
                              decoration-success="completed_today &gt; 0 and p1_strikes_day == 0"
                              decoration-warning="past_due_day &gt; 0"
                              decoration-danger="p1_strikes_day &gt; 0">
                            <field name="day_name"/>
                            <field name="day_date"/>
                            <field name="open_total_day" string="Open Total"/>
                            <field name="past_due_day" string="Past Due"/>
                            <field name="missing_date_day" string="Missing Date"/>
                            <field name="completed_today" string="Completed"/>
                            <field name="open_vs_completed" string="Open vs Completed %" widget="percentage"/>
                            <field name="new_p1_items" string="New P1"/>
                            <field name="p1_strikes_day" string="P1 Strikes"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Weekly Performance Form View -->
    <record id="view_mail_activity_weekly_performance_form" model="ir.ui.view">
        <field name="name">mail.activity.weekly.performance.form</field>
        <field name="model">mail.activity.weekly.performance</field>
        <field name="arch" type="xml">
            <form string="Weekly Performance Dashboard">
                <header>
                    <button name="action_refresh_data"
                            string="Refresh Data"
                            type="object"
                            class="oe_highlight"
                            help="Recompute all metrics with latest activity data"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Week Period">
                            <field name="week_start" required="1"/>
                            <field name="week_end" readonly="1"/>
                        </group>
                        <group string="Filters">
                            <field name="employee_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Weekly Dashboard" name="dashboard">
                            <field name="weekly_line_ids" nolabel="1">
                                <list string="Employee Weekly Performance"
                                      decoration-success="week_progress_percent &gt;= 85"
                                      decoration-warning="week_progress_percent &gt;= 70 and week_progress_percent &lt; 85"
                                      decoration-danger="week_progress_percent &lt; 70 or week_p1_strikes &gt; 0">
                                    <field name="employee_id" string="NAME"/>

                                    <!-- PRIOR WEEK -->
                                    <field name="prior_week_open_vs_completed"
                                           string="Prior Wk Daily Rate (O/C %)"
                                           widget="percentage"
                                           decoration-success="prior_week_open_vs_completed &lt;= 15"
                                           decoration-warning="prior_week_open_vs_completed &gt; 15 and prior_week_open_vs_completed &lt;= 50"
                                           decoration-danger="prior_week_open_vs_completed &gt; 50"/>
                                    <field name="prior_week_p1_strikes" string="Prior Wk P1 Strikes"/>

                                    <!-- WEEK ACCUMULATED -->
                                    <field name="week_open_total" string="Wk Open Total"/>
                                    <field name="week_past_due" string="Past Due" decoration-danger="week_past_due &gt; 0"/>
                                    <field name="week_missing_date" string="Missing Date"/>
                                    <field name="week_completed_total" string="Wk Completed"/>
                                    <field name="week_progress_percent"
                                           string="Wk Progress % (Goal 85%)"
                                           widget="percentage"
                                           decoration-success="week_progress_percent &gt;= 85"
                                           decoration-warning="week_progress_percent &gt;= 70 and week_progress_percent &lt; 85"
                                           decoration-danger="week_progress_percent &lt; 70"/>
                                    <field name="week_open_vs_completed"
                                           string="Wk Daily Rate (O/C %)"
                                           widget="percentage"/>
                                    <field name="week_p1_strikes" string="Wk P1 Strikes" decoration-danger="week_p1_strikes &gt; 0"/>

                                    <!-- BREAKDOWN: Where activities come from -->
                                    <field name="week_total_worked" string="Total Worked On"
                                           help="All activities worked on this week (open + completed). This is your total workload."/>
                                    <field name="week_created_count" string="Created This Wk"
                                           help="Activities created during this week"/>
                                    <field name="week_deadline_count" string="Deadline This Wk"
                                           help="Activities with deadline this week (includes old tasks due now)"/>

                                    <button name="action_view_daily_details"
                                            type="object"
                                            string="View Daily Breakdown"
                                            class="oe_highlight"/>
                                </list>
                            </field>
                        </page>

                        <page string="Daily Breakdown (All Days)" name="daily_all">
                            <p>Click on an employee in the Weekly Dashboard tab, then click "View Daily Breakdown" to see Monday-Sunday details</p>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_mail_activity_weekly_performance" model="ir.actions.act_window">
        <field name="name">Weekly Dashboard</field>
        <field name="res_model">mail.activity.weekly.performance</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_mail_activity_weekly_performance"
              name="Weekly Performance Dashboard"
              parent="customization_left_menu.custom_menu_activity_root"
              action="action_mail_activity_weekly_performance"
              sequence="104"/>

</odoo>

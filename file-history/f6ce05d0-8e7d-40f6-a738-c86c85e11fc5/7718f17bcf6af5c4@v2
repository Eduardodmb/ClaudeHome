<odoo>

    <!-- Form view for the Email Leads Wizard -->

    <record id="view_email_leads_wizard_form" model="ir.ui.view">

        <field name="name">daily.search.email_leads_wizard.form</field>

        <field name="model">daily.search.email_leads_wizard</field>

        <field name="arch" type="xml">

            <form string="Email Leads Summary">

                <sheet>

                <!-- Group for selecting email recipients -->

                    <group>

                        <field name="recipient_ids" widget="many2many_tags" 

                               options="{'no_create_edit': True, 'no_create': True}"

                               placeholder="Select contacts to receive the email"/>

                    </group>

                <!-- Group for selecting leads to include in the email -->

                    <group string="Leads to Include">

                        <field name="lead_ids" widget="many2many_tags" 

                               options="{'no_create_edit': True, 'no_create': True}"

                               placeholder="Select leads to be included in the email"/>

                    </group>

                    <!-- Footer buttons for wizard actions -->

                    <footer>

                    <!-- Calls Python method action_send_leads_email when clicked -->

                        <button string="Send Email" type="object" name="action_send_leads_email" class="btn-primary"/>

                        <button string="Cancel" class="btn-secondary" special="cancel"/>

                    </footer>

                </sheet>

            </form>

        </field>

    </record>

    <!-- Action to open the Email Leads Wizard -->

    <record id="action_email_leads_wizard" model="ir.actions.act_window">

        <field name="name">Email Leads</field>

        <field name="res_model">daily.search.email_leads_wizard</field>

        <field name="view_mode">form</field>

        <field name="target">new</field>

    </record>

    <!-- Menu item under the Daily Search root menu -->

    <menuitem id="menu_daily_search_email_leads"

              parent="menu_daily_search_root"

              name="Email Leads"

              action="action_email_leads_wizard"

              sequence="30"/>

    <record id="menu_daily_search_email_leads" model="ir.ui.menu">

        <field name="active" eval="False"/>

    </record>



    <record id="view_email_bid_unassigned_wizard_form" model="ir.ui.view">

        <field name="name">daily.search.email_bid_unassigned_wizard.form</field>

        <field name="model">daily.search.email_bid_unassigned_wizard</field>

        <field name="arch" type="xml">

            <form string="Email Bid Leads (Unassigned)">

                <sheet>

                    <div class="alert alert-info" role="alert">

                        Pre-selected: bid-marked leads on deck for vetting (no company area yet; not in Estimating or on a project).

                    </div>

                    <group>

                        <field name="recipient_employee_ids" widget="many2many_tags"

                               options="{'no_create_edit': True, 'no_create': True}"

                               placeholder="Select employees (work email required)"/>

                        <field name="additional_emails"

                               placeholder="Additional email addresses (comma-separated)"/>

                    </group>

                    <group string="Leads to include">

                        <field name="lead_ids" widget="many2many_tags"

                               options="{'no_create_edit': True, 'no_create': True}"

                               placeholder="Leads in this email (remove a tag to exclude)"/>

                    </group>

                    <group string="Notes">

                        <field name="notes" nolabel="1" colspan="2"
                               placeholder="Optional notes to include in the email body (appears above the leads table)"/>

                    </group>

                    <group string="Email columns">

                        <field name="mail_column_template_id"

                               options="{'no_create': True}"

                               placeholder="Load a saved layout (optional)"/>

                        <label for="new_template_name"/>

                        <div class="o_row">

                            <field name="new_template_name" placeholder="Name for new template"/>

                            <button name="action_save_mail_column_template" type="object" string="Save as template" class="btn-secondary"/>

                        </div>

                    </group>

                    <group string="Columns in email (drag rows to reorder; add/remove lines)">

                        <field name="column_line_ids" nolabel="1" colspan="2">

                            <list editable="bottom" create="1" delete="1">

                                <field name="sequence" widget="handle"/>

                                <field name="column_key"/>

                            </list>

                        </field>

                    </group>

                    <footer>

                        <button string="Send Email" type="object" name="action_send_bid_unassigned_email" class="btn-primary"/>

                        <button string="Cancel" class="btn-secondary" special="cancel"/>

                    </footer>

                </sheet>

            </form>

        </field>

    </record>



    <record id="action_email_bid_unassigned_wizard" model="ir.actions.act_window">
        <field name="name">Send Bids Email</field>
        <field name="res_model">daily.search.email_bid_unassigned_wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>

    </record>



    <menuitem id="menu_daily_search_email_bid_unassigned"
              parent="menu_daily_search_root"
              name="Send Bids Email"
              action="action_email_bid_unassigned_wizard"
              sequence="31"/>

</odoo>


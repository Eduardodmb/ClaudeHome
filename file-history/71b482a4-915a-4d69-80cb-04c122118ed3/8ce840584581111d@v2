<odoo>

    <record id="view_project_activity_table_form" model="ir.ui.view">
        <field name="name">project.project.activity.table.form</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">

            <xpath expr="//page[@name='TEAM']" position="before">
                <page string="Activities" name="activities_table_tab">

                    <div class="d-flex justify-content-end mb-2">
                        <button name="action_add_activity_from_tab" type="object" string="Add activity" class="btn-primary" icon="fa-plus"/>
                    </div>

                    <separator string="Planned"/>

                    <field name="planned_tab_activity_ids" nolabel="1"
                        context="{
                            'default_res_model': 'project.project',
                            'default_res_model_id': %(project.model_project_project)d,
                            'default_res_id': id,
                            'default_custom_state': 'planned',
                            'default_active': True,
                            'mail_create_nosubscribe': True,
                            'mail_create_nolog': True,
                            'active_test': True
                        }">
                        <list create="1" default_order="date_deadline asc, id desc"
                            decoration-bf="activity_type_id.category == 'meeting'"
                            editable="bottom"
                            decoration-danger="date_deadline &lt; current_date and custom_state != 'done'"
                            decoration-warning="date_deadline == current_date and custom_state != 'done'">
                            <button name="action_open_as_wizard" type="object" icon="fa-external-link" string="Open" title="Open Activity Wizard" class="btn-primary" context="{'form_view_ref': 'mail.mail_activity_view_form_popup', 'target': 'new'}"/>
                            <field name="res_model" column_invisible="True"/>
                            <field name="res_model_id" column_invisible="True"/>
                            <field name="activity_type_id"/>
                            <field name="summary"/>
                            <field name="target_department_id" placeholder="Select Department..." column_invisible="context.get('default_res_model') != 'hr.department'"/>
                            <field name="target_document_item_id" placeholder="Select Document..."/>
                            <field name="custom_state" widget="badge" decoration-success="custom_state == 'done'" decoration-info="custom_state == 'planned'" decoration-danger="custom_state == 'cancelled'"/>
                            <field name="date_deadline"/>
                            <field name="user_id"/>
                        </list>
                    </field>

                    <separator string="Done" class="mt-3"/>

                    <field name="done_tab_activity_ids" nolabel="1"
                        context="{
                            'default_res_model': 'project.project',
                            'default_res_model_id': %(project.model_project_project)d,
                            'default_res_id': id,
                            'mail_create_nosubscribe': True,
                            'mail_create_nolog': True,
                            'active_test': False
                        }">
                        <list create="0" default_order="completed_date desc, id desc"
                            decoration-bf="activity_type_id.category == 'meeting'"
                            decoration-success="custom_state == 'done'">
                            <button name="action_open_as_wizard" type="object" icon="fa-external-link" string="Open" title="Open Activity Wizard" class="btn-primary" context="{'form_view_ref': 'mail.mail_activity_view_form_popup', 'target': 'new'}"/>
                            <field name="res_model" column_invisible="True"/>
                            <field name="res_model_id" column_invisible="True"/>
                            <field name="activity_type_id"/>
                            <field name="summary"/>
                            <field name="target_department_id" placeholder="Select Department..." column_invisible="context.get('default_res_model') != 'hr.department'"/>
                            <field name="target_document_item_id" placeholder="Select Document..."/>
                            <field name="custom_state" widget="badge" decoration-success="custom_state == 'done'" decoration-info="custom_state == 'planned'" decoration-danger="custom_state == 'cancelled'"/>
                            <field name="date_deadline"/>
                            <field name="user_id"/>
                        </list>
                    </field>

                </page>
            </xpath>

        </field>
    </record>

</odoo>

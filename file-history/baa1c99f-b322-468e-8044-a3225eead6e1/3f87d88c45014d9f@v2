<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- SYNC QUEUE VIEWS -->
  <record id="view_document_library_sync_queue_search" model="ir.ui.view">
    <field name="name">document.library.sync.queue.search</field>
    <field name="model">document.library.sync.queue</field>
    <field name="arch" type="xml">
      <search>
        <field name="name"/>
        <field name="folder_path"/>
        <field name="sync_target_id"/>
        <field name="state"/>

        <separator/>
        <filter string="Pending" name="pending" domain="[('state', '=', 'pending')]"/>
        <filter string="Processing" name="processing" domain="[('state', '=', 'processing')]"/>
        <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
        <filter string="Failed" name="failed" domain="[('state', '=', 'failed')]"/>

        <separator/>
        <filter string="High Priority" name="high_priority" domain="[('priority', '&gt;=', 50)]"/>
        <filter string="Need Retry" name="need_retry" domain="[('state', '=', 'failed'), ('retry_count', '&lt;', 'max_retries')]"/>

        <group expand="0" string="Group By">
          <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
          <filter string="Sync Target" name="group_sync_target" context="{'group_by': 'sync_target_id'}"/>
          <filter string="Depth Level" name="group_depth" context="{'group_by': 'depth_level'}"/>
        </group>
      </search>
    </field>
  </record>

  <record id="view_document_library_sync_queue_list" model="ir.ui.view">
    <field name="name">document.library.sync.queue.list</field>
    <field name="model">document.library.sync.queue</field>
    <field name="arch" type="xml">
      <list decoration-info="state == 'pending'"
            decoration-warning="state == 'processing'"
            decoration-success="state == 'done'"
            decoration-danger="state == 'failed'">
        <field name="priority" widget="priority"/>
        <field name="name"/>
        <field name="folder_path"/>
        <field name="sync_target_id"/>
        <field name="depth_level"/>
        <field name="state" widget="badge"
               decoration-info="state == 'pending'"
               decoration-warning="state == 'processing'"
               decoration-success="state == 'done'"
               decoration-danger="state == 'failed'"/>
        <field name="files_processed"/>
        <field name="subfolders_queued"/>
        <field name="retry_count" optional="hide"/>
        <field name="create_date"/>
        <field name="processed_date" optional="show"/>
      </list>
    </field>
  </record>

  <record id="view_document_library_sync_queue_form" model="ir.ui.view">
    <field name="name">document.library.sync.queue.form</field>
    <field name="model">document.library.sync.queue</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <field name="state" widget="statusbar" statusbar_visible="pending,processing,done"/>
        </header>

        <sheet>
          <div class="oe_title">
            <h1>
              <field name="name"/>
            </h1>
          </div>

          <group>
            <group>
              <field name="folder_path"/>
              <field name="folder_item_id"/>
              <field name="sync_target_id"/>
              <field name="depth_level"/>
              <field name="priority"/>
            </group>

            <group>
              <field name="drive_id"/>
              <field name="site_id"/>
            </group>
          </group>

          <group string="Processing Results">
            <group>
              <field name="files_processed"/>
              <field name="subfolders_queued"/>
              <field name="processed_date"/>
            </group>

            <group>
              <field name="retry_count"/>
              <field name="max_retries"/>
              <field name="last_error_date"/>
            </group>
          </group>

          <group string="Error Details" invisible="state != 'failed'">
            <field name="error_message" nolabel="1" colspan="2"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- ACTIONS -->
  <record id="action_document_library_sync_queue" model="ir.actions.act_window">
    <field name="name">Sync Queue</field>
    <field name="res_model">document.library.sync.queue</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="view_document_library_sync_queue_search"/>
    <field name="context">{'search_default_pending': 1}</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        The sync queue is empty.
      </p>
      <p>
        The queue processes SharePoint folders independently to prevent timeouts.
        Run "Initialize Sync Queue" to start the sync process.
      </p>
    </field>
  </record>

  <!-- Server Actions for buttons -->
  <record id="server_action_init_sync_queue" model="ir.actions.server">
    <field name="name">Initialize Sync Queue</field>
    <field name="model_id" ref="model_document_library_item"/>
    <field name="state">code</field>
    <field name="code">action = model.action_init_sync_queue()</field>
  </record>

  <record id="server_action_process_sync_queue" model="ir.actions.server">
    <field name="name">Process Sync Queue</field>
    <field name="model_id" ref="model_document_library_item"/>
    <field name="state">code</field>
    <field name="code">action = model.action_process_sync_queue()</field>
  </record>

  <!-- MENUS -->
  <menuitem id="menu_document_library_sync_queue"
            name="Sync Queue"
            parent="menu_document_library_root"
            action="action_document_library_sync_queue"
            groups="base.group_system"
            sequence="6"/>

  <menuitem id="menu_init_sync_queue"
            parent="menu_document_library_root"
            name="Initialize Sync Queue"
            action="server_action_init_sync_queue"
            groups="base.group_system"
            sequence="31"/>

  <menuitem id="menu_process_sync_queue"
            parent="menu_document_library_root"
            name="Process Sync Queue Now"
            action="server_action_process_sync_queue"
            groups="base.group_system"
            sequence="32"/>

</odoo>

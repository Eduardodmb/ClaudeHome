<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- TAG VIEWS -->
  <record id="view_document_library_tag_list" model="ir.ui.view">
    <field name="name">document.library.tag.list</field>
    <field name="model">document.library.tag</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="color" widget="color_picker"/>
      </list>
    </field>
  </record>

  <record id="view_document_library_tag_form" model="ir.ui.view">
    <field name="name">document.library.tag.form</field>
    <field name="model">document.library.tag</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="color" widget="color_picker"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- LIBRARY ITEM VIEWS -->
  <record id="view_document_library_item_search" model="ir.ui.view">
    <field name="name">document.library.item.search</field>
    <field name="model">document.library.item</field>
    <field name="arch" type="xml">
      <search>
        <field name="name" string="Search Documents"
          filter_domain="['|', '|', '|', '|', '|', '|', ('name', 'ilike', self), ('doc_type', 'ilike', self), ('sharepoint_path', 'ilike', self), ('doc_code', 'ilike', self), ('description', 'ilike', self), ('department_ids', 'ilike', self), ('tag_ids', 'ilike', self)]"/>

        <field name="doc_type"/>
        <field name="department_ids"/>
        <field name="tag_ids"/>
        <field name="owner_id"/>
        <field name="status"/>
        <field name="sharepoint_path"/>
        <field name="sync_target_id"/>
        <field name="doc_code"/>
        <field name="related_document_ids"/>

        <separator/>
        <filter string="Active" name="active" domain="[('active', '=', True)]"/>
        <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>

        <separator/>
        <filter string="Policies" name="policies" domain="[('doc_type', '=', 'policy')]"/>
        <filter string="Procedures" name="procedures" domain="[('doc_type', '=', 'procedure')]"/>
        <filter string="Work Instructions" name="work_instructions" domain="[('doc_type', '=', 'work_instruction')]"/>
        <filter string="Forms" name="forms" domain="[('doc_type', '=', 'form')]"/>
        <filter string="Guidelines" name="guidelines" domain="[('doc_type', '=', 'guideline')]"/>

        <separator/>
        <filter string="Link Only" name="status_link" domain="[('status', '=', 'link')]"/>
        <filter string="Draft" name="status_draft" domain="[('status', '=', 'draft')]"/>
        <filter string="In Review" name="status_review" domain="[('status', '=', 'in_review')]"/>
        <filter string="Approved" name="status_approved" domain="[('status', '=', 'approved')]"/>
        <filter string="Obsolete" name="status_obsolete" domain="[('status', '=', 'obsolete')]"/>

        <group expand="0" string="Group By">
          <filter string="Document Type" name="group_doc_type" context="{'group_by': 'doc_type'}"/>
          <filter string="Department" name="group_department" context="{'group_by': 'department_ids'}"/>
          <filter string="Owner" name="group_owner" context="{'group_by': 'owner_id'}"/>
          <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
          <filter string="Sync target" name="group_sync_target" context="{'group_by': 'sync_target_id'}"/>
        </group>
      </search>
    </field>
  </record>

  <record id="view_document_library_item_list" model="ir.ui.view">
    <field name="name">document.library.item.list</field>
    <field name="model">document.library.item</field>
    <field name="arch" type="xml">
      <list>
        <field name="sequence" widget="handle"/>
        <field name="name"/>
        <field name="doc_type"/>
        <field name="sync_target_id" optional="show"/>
        <field name="sharepoint_path"/>
        <field name="department_ids" widget="many2many_tags"/>
        <field name="tag_ids" widget="many2many_tags"/>
        <field name="owner_id"/>
        <field name="status"/>
        <field name="active"/>
        <button name="action_open_sharepoint"
            type="object"
            string="Open"
            icon="fa-external-link"
            class="btn-link"/>
      </list>
    </field>
  </record>

  <record id="view_document_library_item_form" model="ir.ui.view">
    <field name="name">document.library.item.form</field>
    <field name="model">document.library.item</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_open_sharepoint"
                  type="object"
                  string="Open SharePoint"
                  class="btn-primary"
                  icon="fa-external-link"/>

          <button name="action_submit_review"
                  type="object"
                  string="Submit for Review"
                  groups="document_library.group_document_library_editor"/>

          <button name="action_approve"
                  type="object"
                  string="Approve"
                  groups="document_library.group_document_library_approver"/>

          <button name="action_new_revision"
                  type="object"
                  string="New Revision"
                  groups="document_library.group_document_library_approver"/>

          <button name="action_mark_obsolete"
                  type="object"
                  string="Mark Obsolete"
                  groups="document_library.group_document_library_approver"/>

          <field name="active" widget="boolean_toggle"/>
        </header>

        <sheet>
          <group>
            <group>
              <field name="name"/>
              <field name="doc_type"/>
              <field name="department_ids" widget="many2many_tags"/>
              <field name="tag_ids" widget="many2many_tags"/>
              <field name="owner_id"/>
              <field name="sequence"/>
            </group>

            <group>
              <field name="sharepoint_url"/>
              <field name="sharepoint_path"/>
              <field name="sync_target_id"/>
              <separator string="SharePoint Identity" colspan="2"/>
              <field name="sp_site_id"/>
              <field name="sp_drive_id"/>
              <field name="sp_item_id"/>
              <field name="sp_list_id"/>
              <field name="sp_list_item_id"/>
            </group>
          </group>

          <notebook>
            <page string="Description">
              <field name="description" nolabel="1"/>
            </page>

            <page string="Related Documents">
              <field name="related_document_ids" nolabel="1">
                <list>
                  <field name="name"/>
                  <field name="doc_type"/>
                  <field name="doc_code"/>
                  <field name="status"/>
                  <field name="department_ids" widget="many2many_tags"/>
                  <button name="action_open_sharepoint"
                          type="object"
                          string="Open"
                          icon="fa-external-link"
                          class="btn-link"/>
                </list>
              </field>
            </page>

            <page string="Revision Control">
              <group>
                <group>
                  <field name="doc_code"/>
                  <field name="revision"/>
                  <field name="status" readonly="1"/>
                  <field name="change_summary"/>
                </group>
                <group>
                  <field name="approved_by_id" readonly="1"/>
                  <field name="approved_on" readonly="1"/>
                  <field name="effective_on"/>
                  <field name="next_review_on"/>
                </group>
              </group>

              <separator string="Revision History"/>
              <field name="revision_line_ids" nolabel="1">
                <list>
                  <field name="changed_on"/>
                  <field name="revision"/>
                  <field name="changed_by_id"/>
                  <field name="status"/>
                  <field name="notes"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <!-- ACTIONS (must come after views they reference) -->
  <record id="action_document_library_item" model="ir.actions.act_window">
    <field name="name">Document Library</field>
    <field name="res_model">document.library.item</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="view_document_library_item_search"/>
    <field name="context">{'search_default_active': 1}</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Create Document Library items that point to SharePoint QMS documents.
      </p>
    </field>
  </record>

  <record id="action_document_library_tag" model="ir.actions.act_window">
    <field name="name">Document Library Tags</field>
    <field name="res_model">document.library.tag</field>
    <field name="view_mode">list,form</field>
  </record>

  <record id="server_action_document_library_sync_sharepoint" model="ir.actions.server">
    <field name="name">Document Library: Sync from SharePoint</field>
    <field name="model_id" ref="document_library.model_document_library_item"/>
    <field name="state">code</field>
    <field name="code">model.action_sync_from_sharepoint_queue()</field>
  </record>

  <record id="action_sync_from_sharepoint_server" model="ir.actions.server">
      <field name="name">Sync from SharePoint</field>
      <field name="model_id" ref="model_document_library_item"/>
      <field name="state">code</field>
      <field name="code">
  env['document.library.item'].action_sync_from_sharepoint_queue()
      </field>
  </record>

  <!-- MENUS (must come after actions they reference) -->
  <menuitem id="menu_document_library_root"
            name="Document Library"
            action="action_document_library_item"
            sequence="40"/>

  <menuitem id="menu_document_library_sync_target"
            name="SharePoint Sync Targets"
            parent="menu_document_library_root"
            action="action_document_library_sync_target"
            groups="base.group_system"
            sequence="5"/>

  <menuitem id="menu_document_library_tags"
            name="Library Tags"
            parent="menu_document_library_root"
            action="action_document_library_tag"
            sequence="10"/>

  <menuitem id="menu_document_library_sync_sharepoint"
              parent="menu_document_library_root"
              name="Sync from SharePoint"
              action="action_sync_from_sharepoint_server"
              sequence="30"/>

</odoo>

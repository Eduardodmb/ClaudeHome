from odoo import models, fields, api


class HrApplicantChecklistItem(models.Model):
    _name = 'hr.applicant.checklist.item'
    _description = 'Applicant Checklist Item'
    _order = 'sequence, id'

    applicant_id = fields.Many2one(
        'hr.applicant',
        string='Applicant',
        required=True,
        ondelete='cascade'
    )

    template_id = fields.Many2one(
        'hr.job.checklist.template',
        string='Template',
        ondelete='set null',
        help='Reference to the template this item was created from'
    )

    name = fields.Char(
        string='Checklist Item',
        required=True,
        help='Name of the checklist item'
    )

    sequence = fields.Integer(
        string='Sequence',
        default=10,
        help='Order of this checklist item'
    )

    completed = fields.Boolean(
        string='Completed',
        default=False
    )

    completed_by = fields.Many2one(
        'res.users',
        string='Completed By',
        readonly=True,
        help='User who marked this item as completed'
    )

    completed_date = fields.Datetime(
        string='Completed Date',
        readonly=True,
        help='Date and time when this item was completed'
    )

    result_url = fields.Char(
        string='Result URL',
        help='URL to the result document stored in SharePoint or other location'
    )

    result_attachment = fields.Binary(
        string='Result Document',
        attachment=True,
        help='Upload the completed document'
    )

    result_attachment_filename = fields.Char(
        string='Result Filename'
    )

    result_attachment_ids = fields.Many2many(
        'ir.attachment',
        'hr_applicant_checklist_item_attachment_rel',
        'checklist_item_id',
        'attachment_id',
        string='Multiple Result Attachments',
        help='Upload multiple completed documents for this checklist item'
    )

    result_attachment_count = fields.Integer(
        string='Result Attachment Count',
        compute='_compute_result_attachment_count'
    )

    sharepoint_url = fields.Char(
        string='Template URL',
        help='URL to the template document (from template)',
        related='template_id.sharepoint_url',
        readonly=True
    )

    template_attachment = fields.Binary(
        string='Template Document',
        related='template_id.attachment',
        readonly=True,
        help='Template document from job position'
    )

    template_attachment_filename = fields.Char(
        string='Template Filename',
        related='template_id.attachment_filename',
        readonly=True
    )

    template_attachment_ids = fields.Many2many(
        string='Template Attachments',
        related='template_id.attachment_ids',
        readonly=True,
        help='Attachments from the template'
    )

    template_attachment_count = fields.Integer(
        string='Template attachment count',
        related='template_id.attachment_count',
        readonly=True
    )

    upload_by = fields.Selection(
        [
            ('internal', 'Internal (HR staff only)'),
            ('candidate', 'Candidate (candidate uploads)'),
            ('both', 'Both (HR staff and candidate)'),
        ],
        string='Uploaded By',
        default='internal',
        required=True,
        help='Who is responsible for uploading the completed document for this item',
    )

    notes = fields.Text(
        string='Notes',
        help='Additional notes or comments about this checklist item'
    )

    rating = fields.Selection(
        [
            ('0', 'Not Rated (0)'),
            ('5', 'Below Expectations (5)'),
            ('10', 'Meets Expectations (10)'),
        ],
        string='Evaluation Rating',
        help='Evaluation score for this checklist item (0, 5, or 10 points)',
        tracking=True,
    )

    rating_notes = fields.Text(
        string='Rating Notes',
        help='Comments or feedback about the rating',
        tracking=True,
    )

    auto_completed_by_candidate = fields.Boolean(
        string='Auto-Completed by Candidate Upload',
        default=False,
        readonly=True,
        help='Indicates this item was automatically marked complete when candidate uploaded document',
    )

    def _compute_result_attachment_count(self):
        for record in self:
            record.result_attachment_count = len(record.result_attachment_ids)

    def action_view_template_attachments(self):
        self.ensure_one()
        return {
            'name': f'Template Attachments: {self.name}',
            'type': 'ir.actions.act_window',
            'res_model': 'ir.attachment',
            'view_mode': 'list,form',
            'domain': [('id', 'in', self.template_attachment_ids.ids)],
            'context': {'create': False}
        }

    @api.model_create_multi
    def create(self, vals_list):
        for vals in vals_list:
            if vals.get('completed') and not vals.get('completed_by'):
                vals['completed_by'] = self.env.user.id
                vals['completed_date'] = fields.Datetime.now()
        return super().create(vals_list)

    def write(self, vals):
        if vals.get('completed'):
            if not self.completed:
                vals['completed_by'] = self.env.user.id
                vals['completed_date'] = fields.Datetime.now()
        elif 'completed' in vals and not vals['completed']:
            vals['completed_by'] = False
            vals['completed_date'] = False

        return super().write(vals)

    def action_mark_complete_by_candidate(self):
        """Mark checklist item as completed when candidate uploads document.

        This method is called from the portal controller when a candidate uploads
        a document. It auto-completes the item and notifies HR users.
        """
        self.ensure_one()

        if not self.completed:
            self.sudo().write({
                'completed': True,
                'completed_by': self.env.user.id,
                'completed_date': fields.Datetime.now(),
                'auto_completed_by_candidate': True,
            })

            # Notify recruitment users about the upload
            self._notify_hr_users_of_candidate_upload()

    def _notify_hr_users_of_candidate_upload(self):
        """Send notification to HR users when candidate uploads a document."""
        self.ensure_one()

        # Get recruitment users (users with recruitment access)
        recruitment_group = self.env.ref('hr_recruitment.group_hr_recruitment_user', raise_if_not_found=False)
        if not recruitment_group:
            return

        # Build notification message
        candidate_name = self.applicant_id.partner_name or 'Candidate'
        job_title = self.applicant_id.job_id.name if self.applicant_id.job_id else 'Position'

        notification_body = _(
            '<p><strong>Candidate Document Uploaded</strong></p>'
            '<ul>'
            '<li><strong>Candidate:</strong> %(candidate)s</li>'
            '<li><strong>Position:</strong> %(position)s</li>'
            '<li><strong>Checklist Item:</strong> %(item)s</li>'
            '<li><strong>Status:</strong> Auto-completed ✓</li>'
            '</ul>'
            '<p><a href="/web#id=%(applicant_id)s&model=hr.applicant&view_type=form">'
            'View Application</a></p>'
        ) % {
            'candidate': candidate_name,
            'position': job_title,
            'item': self.name,
            'applicant_id': self.applicant_id.id,
        }

        # Post message to applicant with notification to recruitment users
        self.applicant_id.message_post(
            body=notification_body,
            subject=_('Candidate uploaded: %s') % self.name,
            message_type='notification',
            subtype_xmlid='mail.mt_note',
            partner_ids=recruitment_group.users.mapped('partner_id').ids,
        )

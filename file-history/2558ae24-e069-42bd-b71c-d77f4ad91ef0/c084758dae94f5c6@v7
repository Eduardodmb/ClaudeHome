<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Portal menu item -->
    <template id="portal_my_home_menu_applications" name="Portal My Home: Applications" inherit_id="portal.portal_my_home" priority="10">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Job Applications</t>
                <t t-set="url" t-value="'/my/applications'"/>
                <t t-set="placeholder_count" t-value="'applicant_count'"/>
            </t>
        </xpath>
    </template>

    <!-- Applications list page -->
    <template id="portal_my_applications" name="My Applications">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">My Job Applications</t>
            </t>

            <!-- Welcome message for candidates -->
            <div class="alert alert-info mb-3">
                <h5 class="alert-heading">
                    <i class="fa fa-briefcase me-2"/>
                    Welcome to Your Application Portal
                </h5>
                <p class="mb-0">
                    Track your application status, view job details, and upload required documents.
                    If you have questions, contact HR at
                    <a href="mailto:hr@acglp.com" class="alert-link">hr@acglp.com</a>
                    or call <strong>(915) 845-0007</strong>.
                </p>
            </div>

            <t t-if="not applicants">
                <div class="alert alert-warning" role="alert">
                    <i class="fa fa-info-circle me-2"/>
                    You don't have any job applications yet.
                </div>
            </t>
            <t t-if="applicants" t-call="portal.portal_table">
                <thead>
                    <tr>
                        <th>Application #</th>
                        <th>Job Position</th>
                        <th>Stage</th>
                        <th>Application Date</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="applicants" t-as="applicant">
                        <tr>
                            <td><span t-esc="applicant.id"/></td>
                            <td><span t-field="applicant.job_id"/></td>
                            <td>
                                <span class="badge rounded-pill" t-att-style="'background-color: %s;' % (applicant.stage_id.legend_normal or '#CCCCCC')">
                                    <t t-esc="applicant.stage_id.name"/>
                                </span>
                            </td>
                            <td><span t-field="applicant.create_date" t-options='{"widget": "date"}'/></td>
                            <td class="text-end">
                                <a t-attf-href="/my/application/#{applicant.id}" class="btn btn-sm btn-primary">
                                    <i class="fa fa-eye"/> View
                                </a>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </t>
        </t>
    </template>

    <!-- Application detail page -->
    <template id="portal_my_application_detail" name="My Application Detail">
        <t t-call="portal.portal_layout">
            <t t-set="o_portal_fullwidth_alert" groups="hr_recruitment.group_hr_recruitment_user">
                <t t-call="portal.portal_back_in_edit_mode">
                    <t t-set="backend_url" t-value="'/web#model=hr.applicant&amp;id=%s&amp;view_type=form' % (applicant.id)"/>
                </t>
            </t>

            <div class="container mt-4">
                <div class="row">
                    <div class="col-12">

                        <!-- Status alerts -->
                        <t t-if="request.params.get('item_upload') == 'success'">
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                Document uploaded successfully!
                                <button type="button" class="btn-close" data-bs-dismiss="alert"/>
                            </div>
                        </t>
                        <t t-if="request.params.get('item_upload') == 'error'">
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <t t-if="request.params.get('msg') == 'file_too_large'">File too large (max 20 MB).</t>
                                <t t-elif="request.params.get('msg') == 'no_file'">No file was selected.</t>
                                <t t-else="">Upload failed. Please try again.</t>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"/>
                            </div>
                        </t>

                        <div class="card">
                            <div class="card-header">
                                <h3>
                                    Application for <span t-field="applicant.job_id"/>
                                    <t t-if="request.params.get('upload') == 'success'">
                                        <span class="badge bg-success ms-2">Document uploaded successfully!</span>
                                    </t>
                                    <t t-if="request.params.get('upload') == 'error'">
                                        <t t-if="request.params.get('msg') == 'only_pdf'">
                                            <span class="badge bg-danger ms-2">Error: Only PDF files are allowed</span>
                                        </t>
                                        <t t-if="request.params.get('msg') == 'file_too_large'">
                                            <span class="badge bg-danger ms-2">Error: File too large (max 10MB)</span>
                                        </t>
                                        <t t-if="request.params.get('msg') == 'invalid_pdf'">
                                            <span class="badge bg-danger ms-2">Error: Invalid PDF file</span>
                                        </t>
                                    </t>
                                </h3>
                            </div>
                            <div class="card-body">
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <strong>Applicant Name:</strong> <span t-field="applicant.partner_name"/>
                                    </div>
                                    <div class="col-md-6">
                                        <strong>Email:</strong> <span t-field="applicant.email_from"/>
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <strong>Phone:</strong> <span t-field="applicant.partner_phone"/>
                                    </div>
                                    <div class="col-md-6">
                                        <strong>Application Date:</strong> <span t-field="applicant.create_date" t-options='{"widget": "date"}'/>
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <strong>Current Stage:</strong>
                                        <span class="badge rounded-pill" t-att-style="'background-color: %s;' % (applicant.stage_id.legend_normal or '#CCCCCC')">
                                            <t t-esc="applicant.stage_id.name"/>
                                        </span>
                                    </div>
                                    <div class="col-md-6" t-if="applicant.next_interview_date">
                                        <strong>Next Interview:</strong> <span t-field="applicant.next_interview_date"/>
                                    </div>
                                </div>

                                <!-- Job Description -->
                                <div class="row mb-3" t-if="applicant.job_id.description">
                                    <div class="col-12">
                                        <h5>Job Description</h5>
                                        <div t-field="applicant.job_id.description" class="border p-3 bg-light"/>
                                    </div>
                                </div>

                                <!-- Required Documents (from candidate-facing checklist items) -->
                                <t t-if="candidate_items">
                                    <div class="row mt-4">
                                        <div class="col-12">
                                            <h5>Required Documents</h5>
                                            <p class="text-muted">
                                                Please upload the following documents. Accepted formats: PDF, DOCX, DOC, XLSX, JPG, PNG (max 20 MB each).
                                            </p>

                                            <t t-foreach="candidate_items" t-as="item">
                                                <div class="card mb-3 border">
                                                    <div class="card-body py-3">
                                                        <div class="d-flex align-items-start justify-content-between mb-2">
                                                            <div>
                                                                <strong t-esc="item.name"/>
                                                                <t t-if="item.notes">
                                                                    <p class="text-muted mb-1 mt-1" style="font-size:0.9em;" t-esc="item.notes"/>
                                                                </t>
                                                                <t t-if="item.sharepoint_url">
                                                                    <a t-att-href="item.sharepoint_url" target="_blank" class="btn btn-sm btn-outline-secondary mt-1">
                                                                        <i class="fa fa-download"/> Download Template
                                                                    </a>
                                                                </t>
                                                            </div>
                                                            <t t-if="item.completed">
                                                                <span class="badge bg-success" t-att-title="'Completed by: ' + (item.completed_by.name if item.completed_by else 'System')">
                                                                    <i class="fa fa-check"/> Completed
                                                                    <t t-if="item.auto_completed_by_candidate">
                                                                        <span class="ms-1" title="Automatically marked complete when you uploaded">✓</span>
                                                                    </t>
                                                                </span>
                                                            </t>
                                                        </div>

                                                        <!-- Already uploaded files for this item -->
                                                        <t t-if="item.result_attachment_ids">
                                                            <div class="mb-2">
                                                                <small class="text-muted">Uploaded files:</small>
                                                                <ul class="list-unstyled mb-0 mt-1">
                                                                    <t t-foreach="item.result_attachment_ids" t-as="att">
                                                                        <li>
                                                                            <i class="fa fa-file-o me-1"/>
                                                                            <a t-attf-href="/web/content/#{att.id}?download=true">
                                                                                <t t-esc="att.name"/>
                                                                            </a>
                                                                        </li>
                                                                    </t>
                                                                </ul>
                                                            </div>
                                                        </t>

                                                        <!-- Upload form for this item -->
                                                        <form method="post"
                                                              t-attf-action="/my/application/#{applicant.id}/checklist/#{item.id}/upload"
                                                              enctype="multipart/form-data"
                                                              class="mt-2">
                                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                            <div class="input-group input-group-sm">
                                                                <input type="file" class="form-control form-control-sm"
                                                                       t-attf-id="doc_item_#{item.id}"
                                                                       name="document" required="required"/>
                                                                <button type="submit" class="btn btn-sm btn-primary">
                                                                    <i class="fa fa-upload"/> Upload
                                                                </button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </t>

                                <!-- Generic Document Upload Section -->
                                <div class="row mt-4">
                                    <div class="col-12">
                                        <h5>Upload Additional Documents</h5>
                                        <form method="post" t-attf-action="/my/application/#{applicant.id}/upload" enctype="multipart/form-data">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <div class="mb-3">
                                                <label for="document" class="form-label">Select a PDF file to upload</label>
                                                <input type="file" class="form-control" id="document" name="document" accept=".pdf" required="required"/>
                                                <div class="form-text">Only PDF files are accepted (max 10MB)</div>
                                            </div>
                                            <button type="submit" class="btn btn-primary">
                                                <i class="fa fa-upload"/> Upload Document
                                            </button>
                                        </form>
                                    </div>
                                </div>

                                <!-- Uploaded Documents -->
                                <div class="row mt-4" t-if="applicant.attachment_ids">
                                    <div class="col-12">
                                        <h5>Your Uploaded Documents</h5>
                                        <table class="table table-sm">
                                            <thead>
                                                <tr>
                                                    <th>Document Name</th>
                                                    <th>Upload Date</th>
                                                    <th>Size</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="applicant.attachment_ids" t-as="attachment">
                                                    <tr>
                                                        <td><span t-field="attachment.name"/></td>
                                                        <td><span t-field="attachment.create_date" t-options='{"widget": "date"}'/></td>
                                                        <td><span t-field="attachment.file_size" t-options='{"widget": "integer"}'/> bytes</td>
                                                        <td class="text-end">
                                                            <a t-attf-href="/web/content/#{attachment.id}?download=true" class="btn btn-sm btn-secondary">
                                                                <i class="fa fa-download"/> Download
                                                            </a>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                            <div class="card-footer text-end">
                                <a href="/my/applications" class="btn btn-secondary">
                                    <i class="fa fa-arrow-left"/> Back to Applications
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Portal login redirect page -->
    <template id="portal_login_redirect" name="Portal Login Redirect">
        <t t-call="portal.portal_layout">
            <div class="container mt-5">
                <div class="row justify-content-center">
                    <div class="col-md-8">
                        <div class="card border-primary">
                            <div class="card-header bg-primary text-white">
                                <h4 class="mb-0"><i class="fa fa-sign-in me-2"/> Candidate Portal Login</h4>
                            </div>
                            <div class="card-body">
                                <div class="alert alert-info">
                                    <h5 class="alert-heading">
                                        <i class="fa fa-info-circle me-2"/>
                                        Welcome to ACG Recruitment Portal
                                    </h5>
                                    <p class="mb-0">
                                        Please use the login credentials from your interview invitation email.
                                    </p>
                                </div>

                                <div class="mb-4 p-3 bg-light border rounded">
                                    <h6 class="fw-bold mb-3">Your Login Credentials:</h6>
                                    <ul class="list-unstyled mb-0">
                                        <li class="mb-2">
                                            <strong>📧 Username:</strong> Your email address
                                        </li>
                                        <li class="mb-2">
                                            <strong>🔑 Password:</strong> Temporary password from email
                                        </li>
                                    </ul>
                                </div>

                                <div class="d-grid gap-2">
                                    <a href="/web/login" class="btn btn-primary btn-lg">
                                        <i class="fa fa-sign-in me-2"/> Go to Login Page
                                    </a>
                                </div>

                                <hr class="my-4"/>

                                <h6 class="fw-bold mb-3">Need Help?</h6>
                                <div class="row">
                                    <div class="col-md-6 mb-2">
                                        <i class="fa fa-envelope me-2"/>
                                        <a href="mailto:hr@acglp.com">hr@acglp.com</a>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <i class="fa fa-phone me-2"/>
                                        <strong>(915) 845-0007</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>

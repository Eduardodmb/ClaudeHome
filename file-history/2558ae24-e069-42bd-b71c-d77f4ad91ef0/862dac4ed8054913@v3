<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_applicant_checklist_item_view_form" model="ir.ui.view">
        <field name="name">hr.applicant.checklist.item.form</field>
        <field name="model">hr.applicant.checklist.item</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_template_attachments"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-download"
                                invisible="template_attachment_count == 0">
                            <field name="template_attachment_count" widget="statinfo" string="Template Files"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="upload_by"/>
                            <field name="completed"/>
                            <field name="auto_completed_by_candidate" invisible="1"/>
                        </group>
                        <group>
                            <field name="completed_by" readonly="1"/>
                            <field name="completed_date" readonly="1"/>
                        </group>
                    </group>
                    <group string="Evaluation" name="evaluation">
                        <group>
                            <field name="rating" widget="radio" options="{'horizontal': true}"/>
                        </group>
                        <group>
                            <field name="rating_notes" placeholder="Add evaluation comments or feedback..." nolabel="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Template">
                            <field name="sharepoint_url" widget="url"/>
                            <field name="template_attachment_filename" invisible="1"/>
                            <field name="template_attachment" string="Template Document" filename="template_attachment_filename" readonly="1"/>
                        </group>
                        <group string="Result">
                            <field name="result_url" widget="url"/>
                            <field name="result_attachment_filename" invisible="1"/>
                            <field name="result_attachment" string="Result Document" filename="result_attachment_filename"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Additional notes or comments..."/>
                    </group>
                    <notebook>
                        <page string="Template Attachments" name="template_attachments" invisible="template_attachment_count == 0">
                            <field name="template_attachment_ids" widget="many2many_binary" readonly="1" nolabel="1"/>
                        </page>
                        <page string="Multiple Result Attachments" name="result_attachments">
                            <field name="result_attachment_ids" widget="many2many_binary" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="hr_applicant_checklist_item_view_list" model="ir.ui.view">
        <field name="name">hr.applicant.checklist.item.list</field>
        <field name="model">hr.applicant.checklist.item</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="applicant_id" optional="show"/>
                <field name="name"/>
                <field name="upload_by" optional="show"/>
                <field name="template_attachment_filename" optional="show" string="Template Doc"/>
                <field name="result_attachment_filename" optional="show" string="Result Doc"/>
                <field name="sharepoint_url" widget="url" optional="hide"/>
                <field name="template_attachment_count" optional="hide" string="Template Files"/>
                <field name="result_attachment_count" optional="hide" string="Result Files"/>
                <field name="completed" widget="boolean_toggle"/>
                <field name="auto_completed_by_candidate" optional="hide" readonly="1" string="Auto-Completed"/>
                <field name="rating" optional="show" string="Rating"/>
                <field name="rating_notes" optional="hide"/>
                <field name="completed_by" readonly="1" optional="show"/>
                <field name="completed_date" readonly="1" optional="show"/>
                <field name="result_url" widget="url" optional="hide"/>
                <field name="notes" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="action_hr_applicant_checklist_items" model="ir.actions.act_window">
        <field name="name">Applicant Checklist Items</field>
        <field name="res_model">hr.applicant.checklist.item</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="hr_applicant_checklist_item_view_list"/>
        <field name="context">{'search_default_pending': 1}</field>
    </record>

    <record id="hr_applicant_checklist_item_search" model="ir.ui.view">
        <field name="name">hr.applicant.checklist.item.search</field>
        <field name="model">hr.applicant.checklist.item</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="applicant_id"/>
                <filter string="Pending" name="pending" domain="[('completed', '=', False)]"/>
                <filter string="Completed" name="completed" domain="[('completed', '=', True)]"/>
                <filter string="Candidate Upload" name="candidate_upload" domain="[('upload_by', 'in', ['candidate', 'both'])]"/>
                <separator/>
                <filter string="Auto-Completed by Candidate" name="auto_completed" domain="[('auto_completed_by_candidate', '=', True)]"/>
                <filter string="Not Rated" name="not_rated" domain="[('rating', '=', False)]"/>
                <filter string="Rated" name="rated" domain="[('rating', '!=', False)]"/>
                <separator/>
                <filter string="Rating: 0" name="rating_0" domain="[('rating', '=', '0')]"/>
                <filter string="Rating: 5" name="rating_5" domain="[('rating', '=', '5')]"/>
                <filter string="Rating: 10" name="rating_10" domain="[('rating', '=', '10')]"/>
                <group expand="0" string="Group By">
                    <filter string="Applicant" name="group_applicant" context="{'group_by': 'applicant_id'}"/>
                    <filter string="Upload By" name="group_upload_by" context="{'group_by': 'upload_by'}"/>
                    <filter string="Completed" name="group_completed" context="{'group_by': 'completed'}"/>
                    <filter string="Rating" name="group_rating" context="{'group_by': 'rating'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
